cmd_process() {
    _help_check "$@"
    local cid="" repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --repo) repo_arg="${2:-}"; shift 2 ;;
            --*)    die "unknown flag: $1" ;;
            *)
                if [[ -z "$cid" ]]; then cid="$1"
                else die "unexpected extra positional: $1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$cid" ]] || die "usage: ng process <comment-id> [--repo <owner/name>]"
    local target
    target=$(_resolve_repo write "$repo_arg") || exit $?
    local meta author body issue_url issue_number
    meta=$(api "/repos/$target/issues/comments/$cid" 2>/dev/null) || die "fetch comment $cid failed"
    author=$(jq -r '.user.login // empty' <<<"$meta")
    body=$(jq -r   '.body // empty'        <<<"$meta")
    issue_url=$(jq -r '.issue_url // empty' <<<"$meta")
    issue_number=${issue_url##*/}

    [[ -n "$author" && -n "$issue_number" ]] || die "comment $cid: malformed metadata"
    [[ "$author" == "$USER_LOGIN" ]] || die "comment not authored by $USER_LOGIN (got: $author)"

    # Eligibility markers:
    #   - non-user EYES  → bot is actively handling
    #   - any ROCKET     → done (bot) OR "skip this" (user self-rocket)
    local marks
    marks=$(api "/repos/$target/issues/comments/$cid/reactions?per_page=100" 2>/dev/null \
        | jq --arg login "$USER_LOGIN" \
             '[.[] | select(.content == "rocket" or (.content == "eyes" and .user.login != $login))] | length')
    [[ "$marks" =~ ^[0-9]+$ ]] || die "could not list reactions"
    (( marks == 0 )) || die "comment already marked processed (rocket, or non-user eyes)"

    api -X POST "/repos/$target/issues/comments/$cid/reactions" \
        -f content=eyes >/dev/null \
        || die "posting eyes reaction failed"
    _mark_processed comment "$cid"

    printf 'issue=%s\nauthor=%s\nbody<<EOF\n%s\nEOF\n' "$issue_number" "$author" "$body"
}

# Eligibility check + post EYES + print body (heredoc) for an ISSUE
# (the issue itself, not one of its comments). Mirrors cmd_process
# but reads /repos/{repo}/issues/{n} and looks at the issue's own
# reactions. Surfaces the issue body so the agent can decide the
# action without an extra fetch.
cmd_process_issue() {
    _help_check "$@"
    local n="" repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --repo) repo_arg="${2:-}"; shift 2 ;;
            --*)    die "unknown flag: $1" ;;
            *)
                if [[ -z "$n" ]]; then n="$1"
                else die "unexpected extra positional: $1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$n" ]] || die "usage: ng process-issue <issue-number> [--repo <owner/name>]"
    local target
    target=$(_resolve_repo write "$repo_arg") || exit $?
    local meta author body
    meta=$(api "/repos/$target/issues/$n" 2>/dev/null) || die "fetch issue $n failed"
    author=$(jq -r '.user.login // empty' <<<"$meta")
    body=$(jq -r   '.body // empty'        <<<"$meta")

    [[ -n "$author" ]] || die "issue $n: malformed metadata"
    [[ "$author" == "$USER_LOGIN" ]] || die "issue not authored by $USER_LOGIN (got: $author)"

    # Same eligibility markers as comments: non-user EYES = bot
    # already processing, ANY ROCKET = done (bot) or "skip" (user
    # self-rocket from mobile).
    local marks
    marks=$(api "/repos/$target/issues/$n/reactions?per_page=100" 2>/dev/null \
        | jq --arg login "$USER_LOGIN" \
             '[.[] | select(.content == "rocket" or (.content == "eyes" and .user.login != $login))] | length')
    [[ "$marks" =~ ^[0-9]+$ ]] || die "could not list issue reactions"
    (( marks == 0 )) || die "issue already marked processed (rocket, or non-user eyes)"

    api -X POST "/repos/$target/issues/$n/reactions" \
        -f content=eyes >/dev/null \
        || die "posting eyes reaction failed"
    _mark_processed issue "$n"

    printf 'issue=%s\nauthor=%s\nbody<<EOF\n%s\nEOF\n' "$n" "$author" "$body"
}

cmd_reply() {
    _help_check "$@"
    local issue="${1:-}"; shift || true
    [[ -n "$issue" ]] || die "usage: ng reply <issue> [--repo <owner/name>] [--body-file <path>]"
    local body_file="" repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --body-file) body_file="${2:-}"; shift 2 ;;
            --repo)      repo_arg="${2:-}";  shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    local target
    target=$(_resolve_repo write "$repo_arg") || exit $?
    _post_body "/repos/$target/issues/$issue/comments" "$(_read_body "$body_file")"
}

# `ng comment <issue>` — alias for `ng reply`. Posts a comment to an
# issue or PR thread via the bot (PR conversation comments go through
# the issues endpoint). `comment` is the verb operators reach for first
# (#236 B4); `reply` predates it and stays for back-compat. Identical
# surface to both `ng reply` and `ng issue comment`.
cmd_comment() {
    _help_check "$@"
    cmd_reply "$@"
}

# `ng comment-edit <comment-id>` — compare-and-swap edit of an existing
# issue/PR comment (#524 defect 1). The safe read-modify-write loop:
#
#   ng show <cid> --meta          # 1. read: body + updated_at snapshot
#   <edit the body locally>       # 2. modify
#   ng comment-edit <cid> --body-file new.md \
#       --expect-updated-at <ts>  # 3. write: refused (rc 4) if the
#                                 #    comment moved since your read
#
# --expect-updated-at is REQUIRED: without it the verb cannot tell a
# clean write from a clobber, and last-writer-wins on a shared bot
# identity is exactly the silent-lost-update incident this verb exists
# to prevent. `--force` is the loud, deliberate opt-out (plain PATCH,
# no precondition) for comments you provably own alone.
#
# Prefer APPENDING (`ng reply`) over mutating a long-lived shared
# comment — an append can't lose anyone's edit. Reach for comment-edit
# only when the comment must be corrected in place.
cmd_comment_edit() {
    _help_check "$@"
    local cid="${1:-}"; shift || true
    [[ -n "$cid" ]] || die "usage: ng comment-edit <comment-id> (--expect-updated-at <ts> | --force) [--repo <owner/name>] [--body-file <path>]"
    local body_file="" repo_arg="" expect="" force=0
    while (( $# > 0 )); do
        case "$1" in
            --body-file)         body_file="${2:-}"; shift 2 ;;
            --repo)              repo_arg="${2:-}";  shift 2 ;;
            --expect-updated-at) expect="${2:-}";    shift 2 ;;
            --force)             force=1;            shift   ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    if [[ -n "$expect" ]] && (( force == 1 )); then
        die "comment-edit: --expect-updated-at and --force are mutually exclusive"
    fi
    local target body
    target=$(_resolve_repo write "$repo_arg") || exit $?
    body=$(_read_body "$body_file")
    [[ -n "$body" ]] || die "empty body"
    if (( force == 1 )); then
        {
            printf 'ng comment-edit: --force — writing WITHOUT a concurrency precondition\n'
            printf '(last-writer-wins; a concurrent edit of comment %s would be clobbered).\n' "$cid"
        } >&2
        local resp url
        resp=$(jq -n --arg b "$body" '{body: $b}' \
               | api -X PATCH "/repos/$target/issues/comments/$cid" --input -) \
            || die "comment-edit: PATCH failed (id=$cid)"
        url=$(jq -r '.html_url // empty' <<<"$resp")
        [[ -n "$url" ]] || die "comment-edit: PATCH returned no html_url (id=$cid)"
        printf '%s\n' "$url"
        return 0
    fi
    if [[ -z "$expect" ]]; then
        die "comment-edit is compare-and-swap by design: pass --expect-updated-at <ts> (from \`ng show $cid --meta\`), or --force to deliberately clobber. Prefer \`ng reply\` (append) on contended threads."
    fi
    local url rc=0
    url=$(_comment_patch_cas "$target" "$cid" "$body" "$expect") || rc=$?
    (( rc == 0 )) || exit "$rc"
    printf '%s\n' "$url"
}

cmd_close() {
    _help_check "$@"
    local issue="${1:-}"; shift || true
    [[ -n "$issue" ]] || die "usage: ng close <issue> [--comment <text>]"
    local comment=""
    while (( $# > 0 )); do
        case "$1" in --comment) comment="${2:-}"; shift 2 ;; *) die "unknown flag: $1" ;; esac
    done
    if [[ -n "$comment" ]]; then
        jq -n --arg b "$comment" '{body: $b}' \
            | api -X POST "/repos/$REPO/issues/$issue/comments" --input - >/dev/null \
            || die "pre-close comment failed"
    fi
    local state
    state=$(api -X PATCH "/repos/$REPO/issues/$issue" -f state=closed \
            | jq -r '.state // empty')
    [[ "$state" == "closed" ]] || die "close PATCH failed (state=$state)"
    printf 'CLOSED\n'
}

cmd_upload() {
    _help_check "$@"
    (( $# > 0 )) || die "usage: ng upload <local-path> [--issue N] [--repo-path <path>] [--shape pin|latest] [--message <msg>]"
    exec "$_script_dir/upload-asset.sh" "$@"
