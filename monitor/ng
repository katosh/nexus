# Best-effort session-id capture for `ng report-init` frontmatter.
# Layers in priority order:
#   0. $CLAUDE_CODE_SESSION_ID — the env var Claude Code exports into
#      every Bash tool call, naming the CALLER's own session
#      authoritatively. This is the only source that can't misattribute:
#      it is the running session, not "whatever wrote most recently in
#      some project dir". Issue #203: the freshest-jsonl heuristic below
#      stamped two workers' reports with the ORCHESTRATOR's pinned sid
#      (the workers ran `ng report-init` from the orchestrator's cwd, so
#      layer 2 picked the orchestrator's actively-written jsonl). That
#      breaks crash-resume, which keys off the report's session-id.
#   1. $CLAUDE_PROJECT_DIR/sessions/current_session_id — Claude Code
#      writes this when it knows; cheap and reliable.
#   2. Most-recently-modified ~/.claude/projects/<cwd-slug>/<uuid>.jsonl
#      where <cwd-slug> mirrors Claude Code's path normalisation:
#      every non-alphanumeric character (including '/' AND '_') becomes
#      '-', and the leading '-' from a leading '/' is preserved.
#      e.g. /shared/your-lab-m/user/operator/nexus → -fh-fast-setty-m-user-your-nexus.
#      LAST-RESORT ONLY: freshest-jsonl is a heuristic, not the caller.
#   3. Fallback: scan ~/.claude/projects/ for any project dir whose name
#      contains the slugified cwd tail; pick the most-recently-modified.
#      A stderr warning fires so future divergences in Claude Code's
#      slug rule are visible.
#   4. Empty string — caller substitutes "unknown".
_report_session_id() {
    # Layer 0: the caller's own session, straight from Claude Code.
    if [[ -n "${CLAUDE_CODE_SESSION_ID:-}" ]]; then
        local env_sid="${CLAUDE_CODE_SESSION_ID//[$'\n\r\t ']/}"
        if [[ "$env_sid" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]]; then
            printf '%s' "$env_sid"
            return 0
        fi
    fi
    if [[ -n "${CLAUDE_PROJECT_DIR:-}" && -f "$CLAUDE_PROJECT_DIR/sessions/current_session_id" ]]; then
        local sid
        sid=$(<"$CLAUDE_PROJECT_DIR/sessions/current_session_id")
        sid="${sid//[$'\n\r\t ']/}"
        if [[ -n "$sid" ]]; then
            printf '%s' "$sid"
            return 0
        fi
    fi
    local cwd cwd_slug latest projects_dir
    cwd=$(pwd)
    cwd_slug=$(printf '%s' "$cwd" | sed 's|[^a-zA-Z0-9]|-|g')
    projects_dir="$HOME/.claude/projects"
    if [[ -d "$projects_dir/$cwd_slug" ]]; then
        latest=$(ls -t "$projects_dir/$cwd_slug"/*.jsonl 2>/dev/null | head -1)
        [[ -n "$latest" ]] && { basename -s .jsonl "$latest"; return 0; }
    fi
    # Fallback: cwd-tail substring match. Slugify the tail so dirs
    # under work/<project_with_underscores> still resolve.
    [[ -d "$projects_dir" ]] || return 0
    local tail tail_slug match
    tail="${cwd##*/}"
    tail_slug=$(printf '%s' "$tail" | sed 's|[^a-zA-Z0-9]|-|g')
    [[ -n "$tail_slug" ]] || return 0
    match=$(ls -t -d "$projects_dir"/*"$tail_slug"* 2>/dev/null | head -1)
    [[ -n "$match" && -d "$match" ]] || return 0
    echo "ng: warning: session-id slug '$cwd_slug' not found; falling back to '$(basename "$match")' (Claude Code's slug rule may have changed)" >&2
    latest=$(ls -t "$match"/*.jsonl 2>/dev/null | head -1)
    [[ -n "$latest" ]] && basename -s .jsonl "$latest"
}

# Resolve the tmux window the verb was invoked from. Empty when the
# caller isn't inside a tmux session.
#
# Target by $TMUX_PANE explicitly. Without `-t`, `tmux display-message`
# returns the ACTIVE window of the session — wrong when the verb runs
# in a non-active worker window (the orchestrator's window is active,
# the worker's isn't, and the report-init / wrap-up calls happen in
# the worker's pane). $TMUX_PANE is set by tmux for every pane and
# gives an unambiguous pane id (e.g. %110) for -t.
_report_tmux_window() {
    [[ -n "${TMUX:-}" ]] || return 0
    command -v tmux >/dev/null 2>&1 || return 0
    if [[ -n "${TMUX_PANE:-}" ]]; then
        tmux display-message -p -t "$TMUX_PANE" '#{window_name}' 2>/dev/null
    else
        tmux display-message -p '#{window_name}' 2>/dev/null
    fi
}

# Resolve a project slug for the report filename / frontmatter:
#   1. Explicit value (arg 1, may be empty).
#   2. The current `work/<project>` parent if cwd is inside one.
#   3. The literal "nexus" (workspace-level work).
#
# Issue #95 / #236 B4: when cwd is outside work/<project> AND the
# caller is a spawned worker (NEXUS_WORKER_WINDOW set by
# spawn-worker.sh), INFER the project from the window name instead of
# defaulting to the generic "nexus" and nagging. A worker that runs
# `ng report-init` from outside its worktree (e.g. inheriting the
# orchestrator's cwd) used to silently ship a `project=nexus`
# misattributed stub; the prior warning-then-write was the worst of
# both worlds — it still wrote the wrong stub and trained operators to
# ignore a false-positive warning. The window name is a worker-specific
# attribution that ties the report to its task. The orchestrator
# (NEXUS_WORKER_WINDOW unset) still resolves to "nexus" for genuine
# workspace-level work, and an explicit `--project nexus` always wins
# for cross-project worker reports.
_report_project_slug() {
    local explicit="${1:-}"
    if [[ -n "$explicit" ]]; then
        printf '%s' "$explicit"
        return 0
    fi
    local cwd
    cwd=$(pwd)
    if [[ "$cwd" == */work/* ]]; then
        printf '%s' "$cwd" | sed -E 's|.*/work/([^/]+).*|\1|'
        return 0
    fi
    if [[ -n "${NEXUS_WORKER_WINDOW:-}" ]]; then
        # Never trust an env value verbatim in a filename: sanitize to
        # the slug charset and strip leading/trailing separators. Window
        # names are kebab-case already, so this is belt-and-suspenders.
        local wslug="${NEXUS_WORKER_WINDOW//[^A-Za-z0-9._-]/-}"
        wslug="${wslug#-}"; wslug="${wslug%-}"
        if [[ -n "$wslug" ]]; then
            printf '%s' "$wslug"
            return 0
        fi
    fi
    printf 'nexus'
}

# Resolve the reports-dir for `ng report-init`:
#   1. Explicit --reports-dir.
#   2. $NEXUS_ROOT/reports if NEXUS_ROOT is set and the dir exists.
#   3. Walk up from cwd looking for a `reports/` sibling — the
#      first such directory wins (handles workers in `work/<project>`
#      whose nexus root is two levels up).
#   4. `pwd/reports` (will be created).
_report_reports_dir() {
    local explicit="${1:-}"
    if [[ -n "$explicit" ]]; then
        printf '%s' "$explicit"
        return 0
    fi
    if [[ -n "${NEXUS_ROOT:-}" && -d "$NEXUS_ROOT/reports" ]]; then
        printf '%s' "$NEXUS_ROOT/reports"
        return 0
    fi
    local d
    d=$(pwd)
    while [[ "$d" != / && -n "$d" ]]; do
        if [[ -d "$d/reports" ]]; then
            printf '%s' "$d/reports"
            return 0
        fi
        d=$(dirname "$d")
    done
    printf '%s/reports' "$(pwd)"
}

# `ng report-init <slug> [--project N] [--issue N] [--comment-id ID] [--reports-dir P]`
#
# Writes a frontmatter'd report skeleton at the canonical path
# `<reports-dir>/<project>_<YYYY-MM-DD>_<HHMMSS>_<slug>.md`.
# Captures session-id and tmux window automatically. Prints the
# absolute path on stdout so the worker can `Write`/`Edit` against
# it directly.
#
# The frontmatter schema is enforced by `ng report-check`; both
# verbs read the same set of required fields.
cmd_report_init() {
    _help_check "$@"
    local slug="${1:-}"
    [[ -n "$slug" ]] || die "usage: ng report-init <slug> [--project <name>] [--issue <#>] [--comment-id <id>] [--reports-dir <path>]"
    shift
    local project_arg="" issue_arg="" comment_id_arg="" reports_dir_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --project)     project_arg="${2:-}";     shift 2 ;;
            --issue)       issue_arg="${2:-}";       shift 2 ;;
            --comment-id)  comment_id_arg="${2:-}";  shift 2 ;;
            --reports-dir) reports_dir_arg="${2:-}"; shift 2 ;;
            --repo)
                # Structured rejection: reports/ centralization is
                # intentional, so silently accepting --repo (and
                # ignoring it, or routing the report somewhere else)
                # would be worse than a bare "unknown flag". Spell
                # out the reason here once instead of making every
                # confused operator re-derive it.
                cat >&2 <<'EOF'
ng: report-init does not accept --repo
  reports/ is always written under $NEXUS_ROOT (the primary
  clone), regardless of which worktree or secondary clone the
  worker is running from. This is intentional — centralized
  reports survive worktree cleanup.
  See `monitor/ng` top-of-file usage block for the full flag set.
EOF
                exit 1
                ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    # Reject a numeric / leading-digit explicit --project. It lands
    # verbatim in both the filename and the YAML frontmatter, where
    # `project: 34` parses as an integer and the report misattributes to
    # a non-existent "34" project — operators have passed an issue
    # number here by mistake (#236 B4). Only the EXPLICIT arg is
    # validated; the cwd-/window-derived slugs are orchestrator-
    # controlled and trusted.
    if [[ -n "$project_arg" && ! "$project_arg" =~ ^[A-Za-z][A-Za-z0-9._-]*$ ]]; then
        die "report-init: --project must start with a letter and contain only [A-Za-z0-9._-] (got: '$project_arg') — pass a project name, not an issue number"
    fi

    local project reports_dir session_id window trigger
    project=$(_report_project_slug "$project_arg")
    reports_dir=$(_report_reports_dir "$reports_dir_arg")
    session_id=$(_report_session_id)
    [[ -n "$session_id" ]] || session_id="unknown"
    window=$(_report_tmux_window)
    [[ -n "$window" ]] || window="<unset>"
    if [[ -n "$issue_arg" ]]; then
        if [[ -n "$comment_id_arg" ]]; then
            trigger="#${issue_arg} (comment ${comment_id_arg})"
        else
            trigger="#${issue_arg}"
        fi
    else
        trigger="<unset>"
    fi

    mkdir -p "$reports_dir" || die "report-init: could not create reports dir: $reports_dir"

    local date_part time_part path
    date_part=$(date +%Y-%m-%d)
    time_part=$(date +%H%M%S)
    path="${reports_dir}/${project}_${date_part}_${time_part}_${slug}.md"
    [[ ! -e "$path" ]] || die "report-init: refusing to overwrite existing file: $path"

    # The skeleton intentionally uses `_(fill in)_` for body placeholders
    # instead of literal TODO/FIXME so a worker who runs the skeleton
    # through `report-check` immediately gets actionable failures rather
    # than a generic placeholder flag.
    cat > "$path" <<EOF
---
project: ${project}
date: ${date_part}
session-id: ${session_id}
window: ${window}
trigger: ${trigger}
status: partial
---

# ${slug}

## Summary

_(one or two sentences — ng wrap-up quotes this into the link comment)_

## What Was Done

_(fill in)_

## Current State

_(fill in)_

## What Remains

_(fill in)_

## How to Resume

_(fill in)_
EOF

    printf '%s\n' "$path"
}

# `ng report-check <path> [--allow-todo]`
#
# Validates a report against the schema in `nexus.report`:
#   - YAML-style frontmatter delimited by `---` lines, with required
#     fields {project, date, session-id, status}.
#   - All five canonical sections present (## Summary, ## What Was
#     Done, ## Current State, ## What Remains, ## How to Resume).
#   - Body length ≥ monitor.report_min_chars (default 500).
#   - No literal `TODO`, `FIXME`, `<...>`, or `_(fill in)_`
#     placeholder text — unless `--allow-todo` is passed for
#     intentional in-progress checkpoints.
#
# Exit codes:
#   0  complete
#   1  incomplete (specifics on stderr)
#   2  file missing or unreadable
cmd_report_check() {
    _help_check "$@"
    local path="${1:-}"
    [[ -n "$path" ]] || die "usage: ng report-check <path> [--allow-todo]"
    shift
    local allow_todo=0
    while (( $# > 0 )); do
        case "$1" in
            --allow-todo) allow_todo=1; shift ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    if [[ ! -f "$path" || ! -r "$path" ]]; then
        echo "ng report-check: file missing or unreadable: $path" >&2
        return 2
    fi

    local min_chars
    min_chars=$("$_cfg" monitor.report_min_chars 500 2>/dev/null || echo 500)
    [[ "$min_chars" =~ ^[0-9]+$ ]] || min_chars=500
    if [[ -n "${MONITOR_REPORT_MIN_CHARS:-}" && "${MONITOR_REPORT_MIN_CHARS}" =~ ^[0-9]+$ ]]; then
        min_chars="${MONITOR_REPORT_MIN_CHARS}"
    fi

    local -a missing=()

    # Frontmatter: file must start with `---` line, frontmatter ends
    # at the next `---` line. The awk extracts the YAML body.
    #
    # Deliberately NOT on _fm_lib.sh:_fm_get: this verb VALIDATES the
    # canonical writer form (`ng report-init`'s exact shape — bare `---`
    # fences, `key: value` with a space and a non-empty value), so the
    # strict fence match and the `^key:[[:space:]]+[^[:space:]]` presence
    # greps below ARE the contract being enforced. The lenient shared
    # reader is for CONSUMING frontmatter (spawn-worker, channels);
    # using it here would blur what this validator accepts.
    local first_line
    first_line=$(head -n1 "$path")
    if [[ "$first_line" != "---" ]]; then
        missing+=("frontmatter: file must start with a '---' line")
    fi
    local fm
    fm=$(awk 'NR==1 && /^---$/{flag=1; next} flag && /^---$/{exit} flag' "$path")
    if [[ -n "$fm" ]]; then
        local key
        for key in project date session-id status; do
            if ! grep -qE "^${key}:[[:space:]]+[^[:space:]]" <<<"$fm"; then
                missing+=("frontmatter field: ${key}")
            fi
        done
        # session-id must not be literal "unknown" — that means the
        # capture heuristics failed and the report can't be resumed.
        if grep -qE '^session-id:[[:space:]]+unknown[[:space:]]*$' <<<"$fm"; then
            missing+=("frontmatter field: session-id (resolved to 'unknown'; set explicitly or fix capture)")
        fi
        # status must be one of the canonical values. Reads the
        # already-captured strict-form $fm string, not the file, so it
        # stays on the same strict parse as the checks above (see the
        # _fm_lib.sh note at the frontmatter extraction).
        if grep -qE '^status:[[:space:]]' <<<"$fm"; then
            local status
            status=$(awk -F': *' '/^status:/{print $2; exit}' <<<"$fm" | tr -d ' \t')
            case "$status" in
                completed|partial|blocked) ;;
                *) missing+=("frontmatter field: status (must be completed|partial|blocked, got '${status}')") ;;
            esac
        fi
    fi

    # Required sections.
    local section
    for section in "## Summary" "## What Was Done" "## Current State" "## What Remains" "## How to Resume"; do
        if ! grep -qFx "$section" "$path"; then
            missing+=("section: ${section}")
        fi
    done

    # Body length: file minus frontmatter.
    local body_chars
    body_chars=$(awk '
        BEGIN { in_fm=0; passed_fm=0 }
        NR==1 && /^---$/ { in_fm=1; next }
        in_fm && /^---$/ { in_fm=0; passed_fm=1; next }
        in_fm { next }
        passed_fm || NR>1 { print }
    ' "$path" | wc -c)
    if (( body_chars < min_chars )); then
        missing+=("body too short: ${body_chars} < ${min_chars} chars")
    fi

    # Placeholder text. `_(fill in)_` is the report-init skeleton
    # marker; TODO/FIXME are workers' own. `<...>` is the angle-bracket
    # placeholder common in templates.
    if (( allow_todo == 0 )); then
        if grep -qE '\bTODO\b|\bFIXME\b' "$path"; then
            missing+=("placeholder text: TODO/FIXME present (pass --allow-todo to skip)")
        fi
        if grep -qE '<\.\.\.>' "$path"; then
            missing+=("placeholder text: '<...>' present (pass --allow-todo to skip)")
        fi
        if grep -qE '_\(fill in\)_' "$path"; then
            missing+=("placeholder text: '_(fill in)_' from skeleton present (pass --allow-todo to skip)")
        fi
        if grep -qE '_\(later\)_' "$path"; then
            missing+=("placeholder text: '_(later)_' present (pass --allow-todo to skip)")
        fi
    fi

    if (( ${#missing[@]} == 0 )); then
        printf 'report-check: %s OK (%d body chars)\n' "$(basename "$path")" "$body_chars"
        return 0
    fi
    {
        printf 'ng report-check: %s — incomplete:\n' "$(basename "$path")"
        local m
        for m in "${missing[@]}"; do printf '  - %s\n' "$m"; done
    } >&2
    return 1
}

# Pull the first H1 from a report. Empty stdout if none parseable.
_wrapup_report_title() {
    awk '/^# / { sub(/^# +/, ""); sub(/[[:space:]]+$/, ""); print; exit }' "$1"
}

# Pull a one-sentence summary from a report:
#   1. body of `## Summary` (case-insensitive) if present
#   2. else body of the section under the H1, before the next H2
# Flatten to a single line, drop **Key:** metadata lines, take the first
# sentence (text up to ". "), cap at 200 chars. Empty stdout means
# nothing parseable.
_wrapup_report_summary() {
    local report="$1"
    local text
    text=$(awk '
        BEGIN { IGNORECASE=1 }
        /^## Summary[[:space:]]*$/ { in_section=1; next }
        in_section && /^## /       { exit }
        in_section                 { print }
    ' "$report")
    if [[ -z "${text// /}" ]]; then
        text=$(awk '
            /^# / && !found_h1 { found_h1=1; next }
            found_h1 && /^## / { exit }
            found_h1           { print }
        ' "$report")
    fi
    # Flatten, strip `**Key:** value` metadata lines, collapse whitespace.
    text=$(printf '%s\n' "$text" \
        | grep -v '^\*\*[A-Za-z][A-Za-z ]*:\*\*' \
        | tr '\n' ' ' \
        | sed -e 's/[[:space:]][[:space:]]*/ /g' \
              -e 's/^[[:space:]]*//' \
              -e 's/[[:space:]]*$//')
    [[ -n "$text" ]] || return 0
    local prefix="${text:0:200}"
    # If the first sentence ends within the cap, cut there.
    if [[ "$prefix" == *". "* ]]; then
        prefix="${prefix%%. *}."
    elif (( ${#text} > 200 )); then
        prefix="${prefix}..."
    fi
    printf '%s' "$prefix"
}

# Post-once idempotency for wrap-up step 2 (B15 / your-org/your-nexus#236).
# `ng wrap-up` is the documented retry surface: on a partial failure
# (the rocket step fails, the log append fails, …) the verb returns 1 and
# the worker re-runs the WHOLE verb — there is no per-step retry. Without
# a guard, step 2 re-POSTs the link comment every time, so the issue
# thread accrues duplicate result comments (the symptom cailin reported).
#
# Step 4 already records every successful wrap-up comment in the action
# log with its url, keyed by (issue, report-basename, repo). Scan that log
# for a prior hit and reuse the recorded url instead of posting again.
# Keyed on the LOGICAL wrap-up identity, not the per-upload asset url
# (which the upload step regenerates on every retry). Echoes the most
# recent matching comment url on stdout; empty when none exists (the
# first, legitimate post). Failed prior attempts logged no comment-url,
# so a retry after a genuine comment failure correctly posts fresh.
_wrapup_prior_comment_url() {
    local issue="$1" report_basename="$2" repo="$3"
    local log_file="$STATE_DIR/action-log.jsonl"
    [[ -f "$log_file" ]] || return 0
    command -v jq >/dev/null 2>&1 || return 0
    jq -rs --arg i "$issue" --arg r "$report_basename" --arg repo "$repo" '
        [ .[]
          | select(.event == "wrap-up")
          | select(.issue == $i and .report == $r and .repo == $repo)
          | (."comment-url" // "")
          | select(. != "")
        ] | last // empty' "$log_file" 2>/dev/null
}

# Re-point a prior wrap-up link comment at a fresh asset upload (#524
# defect 2). Every `ng wrap-up` run re-uploads the report to a NEW
# SHA-pinned blob, so a re-wrap that merely REUSES the prior comment
# leaves the thread linking the PRE-correction report while printing
# success (observed: `#523` — the reused comment linked a stale blob
# with 0 mentions of the corrected finding; the new blob had 9).
#
# Reads the prior comment, splices every asset link ending in this
# report's basename over to <new-asset-url>, and writes back through
# the CAS path (_comment_patch_cas) so the re-point can't itself
# reintroduce the lost-update race. One retry on a detected concurrent
# edit (re-read + re-splice), then fail loud.
#
#   _wrapup_repoint_link_comment <target> <prior-comment-html-url>
#                                <report-basename> <new-asset-url>
#   stdout: comment html_url
#   rc 0  re-pointed (or already pointing at the new blob)
#   rc 2  cannot re-point (comment deleted / id unparseable / body no
#         longer references this report) — caller should post fresh
#   rc 1  hard failure (fetch/PATCH/verify), including CAS conflicts
#         that persisted across the retry
_wrapup_repoint_link_comment() {
    local target="$1" prior_url="$2" bname="$3" new_url="$4"
    local cid="${prior_url##*issuecomment-}"
    if [[ ! "$cid" =~ ^[0-9]+$ ]]; then
        printf 'wrap-up: prior comment url has no issuecomment-<id> suffix: %s\n' "$prior_url" >&2
        return 2
    fi
    local attempt meta cur_body cur_updated new_body out rc
    for attempt in 1 2; do
        meta=$(api "/repos/$target/issues/comments/$cid" 2>/dev/null) || {
            printf 'wrap-up: prior link comment %s no longer fetchable (deleted?)\n' "$cid" >&2
            return 2
        }
        cur_body=$(jq -r '.body // empty' <<<"$meta")
        cur_updated=$(jq -r '.updated_at // empty' <<<"$meta")
        if [[ -z "$cur_body" || -z "$cur_updated" ]]; then
            printf 'wrap-up: prior link comment %s: malformed metadata\n' "$cid" >&2
            return 2
        fi
        new_body=$(_replace_asset_links "$cur_body" "$bname" "$new_url")
        if [[ "$new_body" == "$cur_body" ]]; then
            if [[ "$cur_body" == *"$new_url"* ]]; then
                # Idempotent retry: the comment already links the new blob.
                printf '%s\n' "$prior_url"
                return 0
            fi
            printf 'wrap-up: prior link comment %s no longer references %s — posting fresh instead\n' \
                "$cid" "$bname" >&2
            return 2
        fi
        rc=0
        out=$(_comment_patch_cas "$target" "$cid" "$new_body" "$cur_updated") || rc=$?
        if (( rc == 0 )); then
            printf '%s\n' "$out"
            return 0
        fi
        # rc 4 = someone edited between our read and write; re-read the
        # CURRENT body and re-splice once. Anything else is a hard fail.
        (( rc == 4 )) || return 1
    done
    printf 'wrap-up: comment %s kept moving under concurrent edits; re-run ng wrap-up\n' "$cid" >&2
    return 1
}

# ---- skeptic protocol (skills/nexus.skeptic) ----------------------------
#
# Read a window's spawn-stamped skeptic provenance from
# monitor/.state/windows/<window>.json. Echoes five tab-separated
# fields: mode<TAB>depth<TAB>role<TAB>target<TAB>orig. Missing record /
# missing fields degrade to "auto 0 false '' ''" (back-compat:
# pre-skeptic spawns carry no skeptic fields → treated as auto). The
# `orig` field is the ORIGINAL worker window at the root of the skeptic
# chain — a recursive (second-or-later) skeptic reviews the whole chain
# back to it and may question it (skills/nexus.skeptic Change 2).
_skeptic_provenance() {
    local window="$1"
    local mode=auto depth=0 role=false target="" orig=""
    [[ -n "$window" ]] || { printf '%s\t%s\t%s\t%s\t%s' "$mode" "$depth" "$role" "$target" "$orig"; return 0; }
    local rec="$STATE_DIR/windows/${window//[^a-zA-Z0-9_-]/_}.json"
    if [[ -f "$rec" ]] && command -v jq >/dev/null 2>&1; then
        local m d r t o
        m=$(jq -r '.skeptic_mode   // "auto"'  "$rec" 2>/dev/null) || m=auto
        d=$(jq -r '.skeptic_depth  // 0'       "$rec" 2>/dev/null) || d=0
        r=$(jq -r '.skeptic_role   // false'   "$rec" 2>/dev/null) || r=false
        t=$(jq -r '.skeptic_target // ""'      "$rec" 2>/dev/null) || t=""
        o=$(jq -r '.skeptic_orig   // ""'      "$rec" 2>/dev/null) || o=""
        [[ "$m" =~ ^(require|auto|deny)$ ]] && mode="$m"
        [[ "$d" =~ ^[0-9]+$ ]] && depth="$d"
        [[ "$r" == "true" ]] && role=true
        [[ "$t" != "null" ]] && target="$t"
        [[ "$o" != "null" ]] && orig="$o"
    fi
    printf '%s\t%s\t%s\t%s\t%s' "$mode" "$depth" "$role" "$target" "$orig"
}

# Config reader with env override for skeptic knobs. $1=config-key
# $2=env-var $3=default. Integers only.
_skeptic_cfg_int() {
    local key="$1" env="$2" def="$3" val=""
    val="${!env:-}"
    if [[ ! "$val" =~ ^[0-9]+$ ]]; then
        val=$("$_cfg" "$key" "$def" 2>/dev/null) || val="$def"
    fi
    [[ "$val" =~ ^[0-9]+$ ]] || val="$def"
    printf '%s' "$val"
}

# The responsible-default heuristic, printed when an `auto`-mode worker
# must decide. Single source of truth; mirrored in
# skills/nexus.skeptic/SKILL.md and skills/nexus.report.
_skeptic_print_heuristic() {
    cat <<'EOF'
  Spawn a skeptic when the task:
    (a) touched shared infrastructure (watcher/monitor/skills/spawn/CI), OR
    (b) produced or altered scientific results, figures, gene lists,
        data, or analysis, OR
    (c) made or proposed external (cross-repo / public) writes, OR
    (d) involved non-trivial reasoning you are uncertain about, OR
    (e) has high blast radius / is hard to reverse.
  Skip ONLY genuinely trivial, low-impact, easily-reversible,
  high-confidence work (a doc typo, a one-line config).
  Bias toward skepticism — an unreviewed wrong scientific/infra result
  costs far more than a skeptic pass.
EOF
}

# Emit the orchestrator's skeptic-spawn command template for a target
# window at a given depth. $1=target-window $2=depth $3=orig-window
# (the chain root; defaults to target — the FIRST skeptic's target IS
# the original deliverable). When orig differs from target, this is a
# RECURSIVE (second-or-later) skeptic that must review the WHOLE chain
# and may adjudicate a worker↔skeptic disagreement — the template names
# both windows and threads --skeptic-orig forward (skills/nexus.skeptic
# Change 2).
_skeptic_spawn_cmd() {
    local target="$1" depth="$2" orig="${3:-}"
    [[ -n "$orig" ]] || orig="$target"
    printf '    monitor/spawn-worker.sh -n %s-skeptic -c <workdir> -p <prompt-file> \\\n' "$target"
    if [[ "$orig" != "$target" ]]; then
        printf '        --skeptic-role --skeptic-target %s --skeptic-orig %s --skeptic-depth %s\n' \
            "$target" "$orig" "$depth"
        printf '    # RECURSIVE skeptic: reviews the WHOLE chain, not just the prior skeptic.\n'
        printf '    # prompt-file: brief it per skills/nexus.skeptic/SKILL.md to —\n'
        printf '    #   (1) read the ORIGINAL worker `%s` (its deliverable + report) AND\n' "$orig"
        printf '    #       the prior skeptic `%s` (its critique/findings) — both cold, from files;\n' "$target"
        printf '    #   (2) it MAY question BOTH via the comms channel (both may still be parked\n'
        printf '    #       in await): `ng skeptic ask %s ...` and `ng skeptic ask %s ...`;\n' "$orig" "$target"
        printf '    #   (3) ADJUDICATE any worker↔skeptic disagreement — break the tie with a\n'
        printf '    #       reasoned verdict (worker-right / skeptic-right / both-wrong /\n'
        printf '    #       needs-more), citing evidence.\n'
    else
        printf '        --skeptic-role --skeptic-target %s --skeptic-depth %s\n' "$target" "$depth"
        printf '    # prompt-file: brief the skeptic per skills/nexus.skeptic/SKILL.md\n'
        printf '    # (mandate, bug-first checklist, verdict ladder, comms channel).\n'
    fi
}

# The skeptic decision/enforcement step of wrap-up. Returns non-zero
# ONLY to fail the wrap-up when an auto-mode worker did not decide AND
# config monitor.skeptic.enforce_auto_decision is truthy.
# Args: issue source_window repo
#       role decision rationale waive verdict target depth findings orig
_wrapup_skeptic_step() {
    local issue="$1" source_window="$2" repo="$3"
    local f_role="$4" f_decision="$5" f_rationale="$6" f_waive="$7"
    local f_verdict="$8" f_target="$9" f_depth="${10}" f_findings="${11}"
    local f_orig="${12:-}"

    # Resolve provenance for the source window.
    local prov mode depth role target orig
    prov=$(_skeptic_provenance "$source_window")
    IFS=$'\t' read -r mode depth role target orig <<<"$prov"

    # Flag overrides win over provenance (role spawns may run wrap-up
    # off-tmux where source_window is empty).
    (( f_role == 1 )) && role=true
    [[ -n "$f_depth"  ]] && depth="$f_depth"
    [[ -n "$f_target" ]] && target="$f_target"
    [[ -n "$f_orig"   ]] && orig="$f_orig"
    [[ "$depth" =~ ^[0-9]+$ ]] || depth=0

    local pending_dir="$STATE_DIR/skeptic/pending"
    mkdir -p "$pending_dir" 2>/dev/null || true
    local sw_safe="${source_window//[^a-zA-Z0-9_-]/_}"
    # Window extra only when a source window resolved — off-tmux wrap-ups
    # (orchestrator-side direct call, test harness) must not stamp an
    # empty "window" field, mirroring cmd_wrap_up's own discipline.
    local -a winx=()
    [[ -n "$source_window" ]] && winx=(--extra "window=$source_window")

    # =====================================================================
    # ROLE PATH — this wrap-up is a skeptic reporting its verdict.
    # =====================================================================
    if [[ "$role" == "true" ]]; then
        local verdict="$f_verdict"
        [[ -n "$verdict" ]] || {
            echo "ng wrap-up: --skeptic-role requires --skeptic-verdict <credible|check|suspect|refuted>" >&2
            return 1
        }
        case "$verdict" in
            credible|check|suspect|refuted) ;;
            *) echo "ng wrap-up: --skeptic-verdict must be credible|check|suspect|refuted, got '$verdict'" >&2; return 1 ;;
        esac
        local reviewed="$target"
        [[ -n "$reviewed" ]] || reviewed="<unknown-target>"
        local findings="${f_findings:-0}"
        [[ "$findings" =~ ^[0-9]+$ ]] || findings=0
        # The chain root. Defaults to the immediately-reviewed window —
        # the FIRST skeptic's target IS the original deliverable, so when
        # provenance carries no `orig` they coincide.
        local orig_eff="$orig"
        [[ -n "$orig_eff" ]] || orig_eff="$reviewed"
        # Sanitized chain-member marker keys (reused below).
        local orig_safe=""
        [[ -n "$orig_eff" && "$orig_eff" != "<unknown-target>" ]] \
            && orig_safe="${orig_eff//[^a-zA-Z0-9_-]/_}"

        ( cmd_log_action monitor --event skeptic-verdict \
            --extra "window=${source_window:-skeptic}" \
            --extra "target-window=$reviewed" \
            --extra "orig-window=$orig_eff" \
            --extra "verdict=$verdict" \
            --extra "depth=$depth" \
            --extra "findings=$findings" \
            --extra "issue=$issue" ) 2>/dev/null || true

        # A returned verdict SATISFIES the first-pass require-gate, so clear
        # EVERY blocking marker this validation touches: the immediately
        # reviewed target, the chain-root original worker, AND this skeptic's
        # OWN marker (the park-self marker a prior pass may have left). The
        # gate's contract is "a required skeptic has NOT returned a verdict";
        # once a verdict exists that is false for all three. Leaving any live
        # is exactly the leak this fixes — a substantive-but-minor verdict
        # (e.g. `check` with findings>=1) RECOMMENDS a second pass, but the
        # orchestrator routinely (and legitimately) declines it, and nothing
        # then cleared the speculatively-parked markers → retire-preflight
        # reported safe=0 on a DONE skeptic and its target forever, until a
        # manual `rm`. The block is RE-ESTABLISHED by spawn-worker.sh at the
        # moment an actual second-pass skeptic is spawned (so it is tied to a
        # REAL reviewer, not a recommendation), restoring the
        # parked-awaiting-skeptic exemption exactly when it is warranted.
        [[ -n "$reviewed" && "$reviewed" != "<unknown-target>" ]] \
            && rm -f "$pending_dir/${reviewed//[^a-zA-Z0-9_-]/_}" 2>/dev/null || true
        [[ -n "$orig_safe" ]] && rm -f "$pending_dir/${orig_safe}" 2>/dev/null || true
        [[ -n "$sw_safe"   ]] && rm -f "$pending_dir/${sw_safe}"   2>/dev/null || true

        printf '\n=== SKEPTIC VERDICT (skills/nexus.skeptic) ===\n'
        printf 'reviewed window : %s\n' "$reviewed"
        [[ "$orig_eff" != "$reviewed" ]] && printf 'original worker : %s\n' "$orig_eff"
        printf 'verdict         : %s\n' "$verdict"
        printf 'depth           : %s\n' "$depth"
        printf 'new findings    : %s\n' "$findings"

        # Bounded recursion. A second-pass skeptic is warranted only when
        # this pass found SUBSTANTIVE NEW issues (suspect/refuted verdict,
        # or findings >= threshold) AND depth is below the cap. This is
        # the diminishing-returns rule + the termination guarantee: depth
        # strictly increments and is capped, so the chain ends after at
        # most max_depth+1 passes.
        local max_depth thresh
        max_depth=$(_skeptic_cfg_int monitor.skeptic.max_depth MONITOR_SKEPTIC_MAX_DEPTH 3)
        thresh=$(_skeptic_cfg_int monitor.skeptic.findings_threshold MONITOR_SKEPTIC_FINDINGS_THRESHOLD 1)
        # Floor the threshold at 1. A threshold of 0 makes `findings(0)
        # >= thresh(0)` true, so a clean 0-findings pass would still
        # recommend a second pass — defeating the diminishing-returns
        # rule. A second pass is warranted only on >=1 substantive new
        # finding (or a suspect/refuted verdict), never on none.
        (( thresh < 1 )) && thresh=1
        local substantive=0
        if [[ "$verdict" == "suspect" || "$verdict" == "refuted" ]]; then
            substantive=1
        elif (( findings >= thresh )); then
            substantive=1
        fi

        if (( substantive == 1 )) && (( depth < max_depth )); then
            local next=$((depth + 1))
            # NOTE: no pending markers are (re-)written here. A second pass
            # is only RECOMMENDED — the markers that BLOCK retirement and
            # drive the parked-awaiting-skeptic exemption are re-established
            # by spawn-worker.sh if and when the orchestrator actually spawns
            # the next skeptic (it seeds pending/<target> + pending/<orig>).
            # Writing them here speculatively was the leak: when the
            # orchestrator declined the recommendation, nothing ever cleared
            # them and retire-preflight stayed safe=0 forever.
            ( cmd_log_action monitor --event skeptic-request \
                --extra "target-window=${source_window:-skeptic}" \
                --extra "orig-window=$orig_eff" \
                --extra "depth=$next" \
                --extra "reason=second-pass" \
                --extra "issue=$issue" ) 2>/dev/null || true
            printf '\nSECOND-PASS SKEPTIC RECOMMENDED — this pass found substantive new issues\n'
            printf '(verdict=%s, findings=%s) at depth %s (cap %s). The next skeptic reviews the\n' \
                "$verdict" "$findings" "$depth" "$max_depth"
            printf 'WHOLE chain — the original worker `%s` AND this skeptic — and adjudicates\n' "$orig_eff"
            printf 'any worker↔skeptic disagreement. The orchestrator should spawn:\n\n'
            _skeptic_spawn_cmd "${source_window:-<this-skeptic-window>}" "$next" "$orig_eff"
            printf '\nYOU (this skeptic) are now reviewed by that next skeptic — do NOT go idle.\n'
            printf 'Enter the await loop on YOUR OWN window so its questions reach you, and\n'
            printf 'do NOT close the original worker `%s` channel (leave it parked for the\n' "$orig_eff"
            printf 'next skeptic; only the FINAL skeptic closes it when the chain terminates):\n'
            printf '    monitor/skeptic-channel.sh await %s\n' "${source_window:-<this-skeptic-window>}"
            printf '\nA second pass is the ORCHESTRATOR'\''s call. If it DECLINES (the findings\n'
            printf 'are minor/acceptable and no further pass is warranted), it terminates the\n'
            printf 'chain normally — `ng skeptic close` the worker(s) and retire. The blocking\n'
            printf 'markers were already cleared by THIS verdict, so a declined recommendation\n'
            printf 'leaks nothing; the block returns only if a real next skeptic is spawned.\n'
        elif (( substantive == 1 )) && (( depth >= max_depth )); then
            # Chain terminates at the cap. All markers (reviewed, orig, self)
            # were already cleared above on the verdict — nothing to release.
            ( cmd_log_action monitor --event skeptic-escalate \
                --extra "window=${source_window:-skeptic}" \
                --extra "target-window=$reviewed" \
                --extra "orig-window=$orig_eff" \
                --extra "depth=$depth" \
                --extra "verdict=$verdict" \
                --extra "issue=$issue" ) 2>/dev/null || true
            printf '\nMAX SKEPTIC DEPTH REACHED (depth %s >= cap %s) and issues persist.\n' "$depth" "$max_depth"
            printf 'Do NOT spawn another skeptic — ESCALATE to the operator instead.\n'
            printf 'The chain is bounded by design; persistent issues at the cap are a\n'
            printf 'signal for human judgement, not more automated passes.\n'
        else
            # Clean termination. All markers (reviewed, orig, self) were
            # already cleared above on the verdict — nothing to release.
            printf '\nSkeptic chain TERMINATES: no substantive new issues (verdict=%s, findings=%s).\n' \
                "$verdict" "$findings"
        fi
        return 0
    fi

    # =====================================================================
    # PRODUCER PATH — the original worker's wrap-up.
    # =====================================================================

    # Operator waiver: an explicit override that releases a required
    # skeptic. Operator-scoped + recorded loudly for audit.
    if [[ -n "$f_waive" ]]; then
        # Operator-scoped gate. The waive is an OPERATOR override, not a
        # worker self-service. Every spawned worker runs with
        # NEXUS_WORKER_WINDOW exported by spawn-worker.sh; the
        # orchestrator/operator session does not (ng already keys other
        # operator-vs-worker distinctions on exactly this — see the
        # report-init guard). So refuse a waive attempted from inside a
        # worker context. This is a discipline-and-audit control, not a
        # cryptographic boundary — a worker shares the filesystem and
        # could unset the var — but it blocks the casual self-waive, and
        # any bypass is then a deliberate, auditable act. The honest
        # claim is exactly this: operator-scoped + audited, not
        # cryptographically unforgeable (SKILL.md reconciled to match).
        if [[ -n "${NEXUS_WORKER_WINDOW:-}" ]]; then
            echo "ng wrap-up: --skeptic-waive is an operator override and was invoked from inside a" >&2
            echo "  worker context (NEXUS_WORKER_WINDOW=$NEXUS_WORKER_WINDOW). A worker cannot waive" >&2
            echo "  its own required skeptic. Leave the skeptic-pending marker in place for the" >&2
            echo "  operator to resolve (spawn the skeptic, or waive from the orchestrator session)." >&2
            return 1
        fi
        ( cmd_log_action monitor --event skeptic-decision \
            "${winx[@]}" \
            --extra "decision=waived" \
            --extra "reason=$f_waive" \
            --extra "issue=$issue" ) 2>/dev/null || true
        rm -f "$pending_dir/${sw_safe}" 2>/dev/null || true
        printf '\n=== SKEPTIC: WAIVED (operator override) ===\n'
        printf 'reason: %s\n' "$f_waive"
        printf 'CONSEQUENCE: the required skeptic was waived by operator override;\n'
        printf 'the pending marker is cleared, so this window can retire normally.\n'
        printf '(recorded; proceeding without a skeptic pass)\n'
        return 0
    fi

    # Resolve the effective decision from spawn mode + worker decision.
    local effective=""
    case "$mode" in
        deny)
            if [[ "$f_decision" == "require" ]]; then
                effective=required-escalated   # responsible upgrade
            else
                effective=denied-spawn
            fi
            ;;
        require)
            if [[ "$f_decision" == "deny" ]]; then
                echo "ng wrap-up: this worker was spawned with --skeptic require; a skeptic is" >&2
                echo "  mandatory and you cannot waive it with --skeptic-decision deny. Proceed:" >&2
                echo "  leave the skeptic-pending marker in place and the orchestrator will spawn" >&2
                echo "  the skeptic. (Only an operator, from the orchestrator session, may release" >&2
                echo "  a requirement set in error.)" >&2
                return 1
            fi
            effective=required
            ;;
        auto|*)
            case "$f_decision" in
                require) effective=required ;;
                deny)    effective=denied-auto ;;
                "")      effective=undecided ;;
                *) echo "ng wrap-up: --skeptic-decision must be require|deny, got '$f_decision'" >&2; return 1 ;;
            esac
            # Auto decisions must carry a rationale (the responsible
            # choice must be articulated and recorded).
            if [[ "$effective" == "required" || "$effective" == "denied-auto" ]] && [[ -z "$f_rationale" ]]; then
                echo "ng wrap-up: an auto-mode skeptic decision requires --skeptic-rationale <text>" >&2
                echo "  (record WHY a skeptic is/ isn't warranted — see the heuristic below)." >&2
                _skeptic_print_heuristic >&2
                return 1
            fi
            ;;
    esac

    local next=$((depth + 1))
    case "$effective" in
        required|required-escalated)
            # Open a NEW skeptic round: archive the previous round's terminal
            # sentinels BEFORE writing the pending marker. A completed round
            # leaves $STATE_DIR/skeptic/<task>/DONE (and its .answered.md
            # verdicts) behind; left in place, the worker's very next
            # `skeptic-channel.sh await` returns exit 10 instantly and it
            # retires believing it was validated when no skeptic ever
            # spawned — the gate fails OPEN exactly on the re-validation
            # rounds, which exist because something was already found wrong
            # (issue #469). `reset` ARCHIVES the stale pair into
            # <channel>/.stale-archive-<ts>/ rather than bare-`rm`-ing only
            # the DONE (your-org/nexus-code#511): the forensic trail survives
            # and stale verdicts do not pollute the new round. await
            # independently refuses a DONE older than the marker; this is the
            # fail-fast half of that pair.
            [[ -n "$source_window" ]] \
                && "$_script_dir/skeptic-channel.sh" reset "$source_window" >/dev/null 2>&1 || true
            [[ -n "$sw_safe" ]] && printf '%s' "$next" > "$pending_dir/${sw_safe}" 2>/dev/null || true
            ( cmd_log_action monitor --event skeptic-request \
                --extra "target-window=$source_window" \
                --extra "depth=$next" \
                --extra "mode=$mode" \
                --extra "decision=$effective" \
                --extra "issue=$issue" ) 2>/dev/null || true
            printf '\n=== SKEPTIC REQUIRED (skills/nexus.skeptic) ===\n'
            if [[ "$effective" == "required-escalated" ]]; then
                printf 'Spawn mode was `deny`, but you escalated to require — recorded.\n'
            else
                printf 'This task requires an independent skeptic validation pass.\n'
            fi
            [[ -n "$f_rationale" ]] && printf 'rationale: %s\n' "$f_rationale"
            printf 'CONSEQUENCE: a skeptic MUST validate this result; this window cannot\n'
            printf 'retire until a skeptic returns a verdict (retire-preflight.sh enforces\n'
            printf 'the skeptic-pending marker — see skills/nexus.window-cleanup).\n'
            printf 'A skeptic-pending marker is set; the task is NOT complete until a\n'
            printf 'skeptic returns a verdict. The orchestrator should spawn:\n\n'
            _skeptic_spawn_cmd "$source_window" "$next"
            printf '\nWhile the skeptic reviews, DO NOT go idle — enter the await loop\n'
            printf 'so its requests reach you (and so the watcher sees you as\n'
            printf 'parked-awaiting-skeptic, not idle):\n'
            printf '    monitor/skeptic-channel.sh await %s\n' "$source_window"
            printf '  exit 0  → it acked open request(s) (now `.ack.md`): read each,\n'
            printf '            answer with `skeptic-channel.sh answer %s <req> ...`\n' "$source_window"
            printf '            (renames →`.answered.md`), then RE-ENTER await.\n'
            printf '  exit 4  → timed out with nothing pending: RE-ENTER await.\n'
            printf '  exit 10 → DONE sentinel: the skeptic closed the channel; stop\n'
            printf '            looping and proceed to retire.\n'
            ;;
        denied-spawn)
            ( cmd_log_action monitor --event skeptic-decision \
                "${winx[@]}" \
                --extra "decision=denied" \
                --extra "reason=spawn-deny" \
                --extra "issue=$issue" ) 2>/dev/null || true
            rm -f "$pending_dir/${sw_safe}" 2>/dev/null || true
            printf '\n=== SKEPTIC: DENIED AT SPAWN ===\n'
            printf 'No skeptic pass (trivial / low-impact work, disabled at spawn). Recorded.\n'
            printf 'CONSEQUENCE: skeptic was waived at spawn; proceeding without one\n'
            printf '(recorded). No pending marker, so this window can retire normally.\n'
            ;;
        denied-auto)
            ( cmd_log_action monitor --event skeptic-decision \
                "${winx[@]}" \
                --extra "decision=denied" \
                --extra "reason=auto-worker-choice" \
                --extra "rationale=$f_rationale" \
                --extra "issue=$issue" ) 2>/dev/null || true
            rm -f "$pending_dir/${sw_safe}" 2>/dev/null || true
            printf '\n=== SKEPTIC: NOT WARRANTED (worker decision, auto mode) ===\n'
            printf 'rationale: %s\n' "$f_rationale"
            printf 'CONSEQUENCE: you judged no skeptic warranted; no pending marker is set,\n'
            printf 'so this window can retire normally (the decision + rationale are recorded).\n'
            printf '(recorded; proceeding without a skeptic pass)\n'
            ;;
        undecided)
            ( cmd_log_action monitor --event skeptic-decision \
                "${winx[@]}" \
                --extra "decision=auto-undecided" \
                --extra "issue=$issue" ) 2>/dev/null || true
            printf '\n=== SKEPTIC DECISION REQUIRED (auto mode) ===\n'
            printf 'CONSEQUENCE: you must record a skeptic decision + rationale now; if\n'
            printf 'you choose require, the retire gate applies (this window cannot retire\n'
            printf 'until a skeptic returns a verdict).\n'
            printf 'This worker was spawned in `auto` skeptic mode: YOU must make the\n'
            printf 'responsible call on whether your result warrants an independent\n'
            printf 'skeptic pass, and record it. Re-run wrap-up with ONE of:\n'
            printf '    --skeptic-decision require --skeptic-rationale "<why>"\n'
            printf '    --skeptic-decision deny    --skeptic-rationale "<why>"\n\n'
            _skeptic_print_heuristic
            local enforce
            enforce=$("$_cfg" monitor.skeptic.enforce_auto_decision true 2>/dev/null || echo true)
            [[ -n "${MONITOR_SKEPTIC_ENFORCE_AUTO_DECISION:-}" ]] && enforce="$MONITOR_SKEPTIC_ENFORCE_AUTO_DECISION"
            case "$enforce" in
                1|true|yes|on)
                    printf '\n(monitor.skeptic.enforce_auto_decision is on — wrap-up will not\n'
                    printf 'complete until you record a decision.)\n'
                    return 1
                    ;;
                *)
                    printf '\n(Advisory for now: recorded as auto-undecided. Make the call.)\n'
                    ;;
            esac
            ;;
    esac
    return 0
}

# `ng wrap-up <issue> <report-path> [--trigger-comment <id>]
#                                  [--repo OWNER/REPO]
#                                  [--trigger-repo OWNER/REPO]
#                                  [--retain <reason>|--no-retain]`
#
# The universal end-of-task hand-off, folded into one verb:
#   1. upload the report to the asset repo (via upload-asset.sh)
#   2. post a templated comment on <issue> with the asset URL
#      (post-once idempotent: a re-run does not duplicate the link
#      comment for this issue+report+repo — it RE-POINTS the prior
#      comment's asset URL at the fresh upload via the CAS edit
#      path, since step 1 mints a new blob every run; #524 defect 2)
#   3. rocket-react the trigger comment if --trigger-comment is set
#   4. append a wrap-up entry to the action log
#   5. append a window-retain entry (auto by default; --no-retain
#      opts out; --retain <reason> overrides the default tag)
#
# Exit code 0 iff all attempted steps succeed. On partial success the
# verb still attempts every reachable step (the rocket and log-action
# don't depend on the upload), then emits a structured stderr report
# naming which steps ok/failed so the caller can retry the failed ones.
#
# `--repo` governs the issue-thread repo (steps 2 + log target).
# `--trigger-repo` (if omitted, defaults to `--repo`) governs where
# the rocket-react posts in step 3 — needed when the trigger comment
# lives on a different repo than the issue thread (e.g. PR-#4
# dogfood: worker on a `nexus-code` clone wraps up against
# `your-nexus#1` with the trigger comment on `nexus-code#4`).
# The asset repo is always taken from config (github.asset_repo) by
# upload-asset.sh.
#
# Retain-by-default (step 5): a successful wrap-up auto-logs a
# `window-retain` event for the source tmux window so the watcher's
# idle-worker probe suppresses the wrapped row into a footer for the
# `monitor.retain_ttl_seconds` window (default 24 h). The auto-tag is
# `wrap-up-<YYYY-MM-DD>`. Pass `--retain <reason>` for a custom tag,
# or `--no-retain` to close-immediately (short-lived helper that's
# truly done; context-pressure wrap-ups where the worker won't be
# resumed). The retain is logged only when the verb runs inside the
# worker's tmux pane (source_window resolved from $TMUX_PANE);
# off-tmux invocations silently skip step 5 since there's no window
# to retain.
cmd_wrap_up() {
    _help_check "$@"
    local issue="${1:-}" report_path="${2:-}"
    [[ -n "$issue" && -n "$report_path" ]] \
        || die "usage: ng wrap-up <issue> <report-path> [--trigger-comment <id>] [--repo <owner/name>] [--trigger-repo <owner/name>]"
    shift 2 || true
    local trigger_comment="" repo_arg="" trigger_repo_arg="" body_file="" no_comment=0 allow_stub=0
    local retain_reason="" no_retain=0
    # Skeptic-protocol flags (skills/nexus.skeptic). All optional and
    # backward-compatible: a wrap-up with none of these falls back to
    # the worker's spawn-stamped mode (provenance record) or `auto`.
    local sk_decision="" sk_rationale="" sk_waive=""
    local sk_role=0 sk_verdict="" sk_target="" sk_depth="" sk_findings="" sk_orig=""
    while (( $# > 0 )); do
        case "$1" in
            --trigger-comment)  trigger_comment="${2:-}";   shift 2 ;;
            --repo)             repo_arg="${2:-}";          shift 2 ;;
            --trigger-repo)     trigger_repo_arg="${2:-}";  shift 2 ;;
            --comment-body-file) body_file="${2:-}";        shift 2 ;;
            --no-comment)       no_comment=1;               shift   ;;
            --allow-stub)       allow_stub=1;               shift   ;;
            --retain)           retain_reason="${2:-}";     shift 2 ;;
            --no-retain)        no_retain=1;                shift   ;;
            --skeptic-decision)  sk_decision="${2:-}";      shift 2 ;;
            --skeptic-rationale) sk_rationale="${2:-}";     shift 2 ;;
            --skeptic-waive)     sk_waive="${2:-}";         shift 2 ;;
            --skeptic-role)      sk_role=1;                 shift   ;;
            --skeptic-verdict)   sk_verdict="${2:-}";       shift 2 ;;
            --skeptic-target)    sk_target="${2:-}";        shift 2 ;;
            --skeptic-depth)     sk_depth="${2:-}";         shift 2 ;;
            --skeptic-findings)  sk_findings="${2:-}";      shift 2 ;;
            --skeptic-orig)      sk_orig="${2:-}";          shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    if (( no_retain == 1 )) && [[ -n "$retain_reason" ]]; then
        die "wrap-up: --no-retain and --retain are mutually exclusive"
    fi
    [[ -f "$report_path" ]] || die "wrap-up: report not found: $report_path"
    # --no-comment and --comment-body-file are mutually exclusive: one
    # asks to skip step 2 entirely, the other supplies a custom body
    # for it. Trying both is a config error, not a "do the safer of
    # the two" — fail loud.
    if (( no_comment == 1 )) && [[ -n "$body_file" ]]; then
        die "wrap-up: --no-comment and --comment-body-file are mutually exclusive"
    fi
    if [[ -n "$body_file" && ! -f "$body_file" ]]; then
        die "wrap-up: --comment-body-file not found: $body_file"
    fi

    local target trigger_target basename
    target=$(_resolve_repo write "$repo_arg") || exit $?
    # Rocket-react target. Defaults to `target` (back-compat: when
    # the trigger lives in the same repo as the issue thread, the
    # caller doesn't need to pass --trigger-repo). An explicit value
    # goes through _resolve_repo write so the strict-mode validation
    # applies to it too — same leak-prevention as the issue target.
    if [[ -n "$trigger_repo_arg" ]]; then
        trigger_target=$(_resolve_repo write "$trigger_repo_arg") || exit $?
    else
        trigger_target="$target"
    fi
    basename=$(basename -- "$report_path")

    # Per-step outcomes. ok | failed | skipped.
    local upload_st=failed comment_st=skipped rocket_st=skipped log_st=failed
    local asset_url="" comment_url="" failure_detail=""

    # Temp file for per-step stderr capture. RETURN trap cleans it up.
    local err_buf
    err_buf=$(mktemp)
    trap "rm -f '$err_buf'" RETURN

    # Step 0: pre-flight report-check. Refuse to ship a stub asset
    # URL into the issue thread — fix the report first. --allow-stub
    # forwards --allow-todo so the worker can wrap an intentional
    # in-progress checkpoint (rare; the verb's defaults are strict).
    : > "$err_buf"
    local -a check_args=("$report_path")
    (( allow_stub == 1 )) && check_args+=(--allow-todo)
    if ! ( cmd_report_check "${check_args[@]}" ) >/dev/null 2>"$err_buf"; then
        {
            printf 'ng wrap-up: report-check failed — fix the report before wrapping up.\n'
            printf 'Pass --allow-stub to override for an intentional checkpoint.\n'
            cat "$err_buf"
        } >&2
        return 1
    fi

    # Source tmux window. Captured so the watcher's idle classifier can
    # match wrap-up events ↔ windows directly instead of via the
    # report-basename heuristic (issue #109). Empty when wrap-up is
    # invoked outside tmux (orchestrator-side direct call). Shares
    # `_report_tmux_window` with `report-init` so both surfaces target by
    # $TMUX_PANE — without -t, display-message returns the active window
    # of the session, NOT the calling pane's window. Resolved HERE (before
    # the GitHub hand-off) so the skeptic gate can run first.
    local source_window
    source_window=$(_report_tmux_window)

    # Step 0b (skeptic protocol, skills/nexus.skeptic): run the skeptic
    # decision/enforcement BEFORE the external GitHub hand-off. A wrap-up
    # that the skeptic step REFUSES (an undecided `auto` worker under
    # enforce, a `require` worker trying to `--skeptic-decision deny`, a
    # worker-context waive, a malformed skeptic-role verdict) must NOT
    # have already announced "done" on the issue thread or rocketed the
    # trigger — and crucially must NOT double-post on the worker's retry.
    # Running it first makes the gate honest with the protocol's own claim
    # ("not complete until a skeptic returns"): on refusal we return early,
    # before any upload/comment/rocket/log. On the require/auto-require
    # path it sets the pending marker and prints the await-loop guidance,
    # then the hand-off proceeds normally (the report IS what the skeptic
    # reads; posting it is correct, and the retire gate still blocks the
    # window until a verdict lands).
    _wrapup_skeptic_step \
        "$issue" "$source_window" "$target" \
        "$sk_role" "$sk_decision" "$sk_rationale" "$sk_waive" \
        "$sk_verdict" "$sk_target" "$sk_depth" "$sk_findings" "$sk_orig" \
        || return $?

    # Step 1: upload the report. Stdout = URL; stderr = progress + errors.
    if asset_url=$("$_script_dir/upload-asset.sh" "$report_path" --issue "$issue" 2>"$err_buf"); then
        # Trim trailing newline (`$()` already strips it, but be explicit).
        asset_url="${asset_url%$'\n'}"
        if [[ -n "$asset_url" ]]; then
            upload_st=ok
        else
            upload_st=failed
            failure_detail+=$'  upload: upload-asset.sh exited 0 but no URL on stdout\n'
        fi
    else
        upload_st=failed
        failure_detail+="  upload: upload-asset.sh failed: $(tr '\n' ' ' < "$err_buf")"$'\n'
    fi

    # Step 2: post the comment. Three modes:
    #   - --no-comment: skipped (worker plans to post via `ng reply`).
    #   - --comment-body-file <path>: caller supplies prose; the verb
    #     substitutes {{REPORT_URL}} with the asset URL, or appends a
    #     "Full report: <URL>" footer when no token is present.
    #   - default: templated body from the report's H1 + Summary.
    # Always skipped if upload failed — without an asset URL the
    # comment body would be a dead link.
    if (( no_comment == 1 )); then
        comment_st=skipped
    elif [[ "$upload_st" == ok ]]; then
        local body
        if [[ -n "$body_file" ]]; then
            body=$(<"$body_file")
            if [[ "$body" == *"{{REPORT_URL}}"* ]]; then
                body="${body//\{\{REPORT_URL\}\}/$asset_url}"
            else
                # No token → append a footer so the link is always
                # present regardless of what the worker wrote.
                body="${body}"$'\n\nFull report: '"$asset_url"
            fi
        else
            local title summary
            title=$(_wrapup_report_title "$report_path")
            summary=$(_wrapup_report_summary "$report_path")
            if [[ -z "$title" ]]; then
                body=$(printf '## %s\n\nReport: %s\n' "$basename" "$asset_url")
            elif [[ -n "$summary" ]]; then
                body=$(printf '## %s\n\n%s\n\nFull report: %s\n' "$title" "$summary" "$asset_url")
            else
                body=$(printf '## %s\n\nFull report: %s\n' "$title" "$asset_url")
            fi
        fi
        : > "$err_buf"
        # Post-once idempotency (B15 / your-org/your-nexus#236): if a
        # prior wrap-up for this (issue, report, repo) already posted the
        # link comment, don't double-post on a retry. But step 1 just
        # re-uploaded the report to a NEW blob, so reusing the prior
        # comment AS-IS would pin the thread to the STALE upload while
        # printing success (#524 defect 2). Re-point the prior comment's
        # asset link(s) at the new blob via the CAS edit path; when the
        # comment is gone or no longer references this report, post the
        # canonical link comment fresh (a duplicate beats a stale link).
        local prior_comment_url
        prior_comment_url=$(_wrapup_prior_comment_url "$issue" "$basename" "$target")
        if [[ -n "$prior_comment_url" ]]; then
            local repoint_rc=0
            comment_url=$(_wrapup_repoint_link_comment \
                "$target" "$prior_comment_url" "$basename" "$asset_url" \
                2>"$err_buf") || repoint_rc=$?
            if (( repoint_rc == 0 )); then
                comment_st=updated
            elif (( repoint_rc == 2 )); then
                : > "$err_buf"
                if comment_url=$(_post_body "/repos/$target/issues/$issue/comments" "$body" 2>"$err_buf"); then
                    comment_st=ok
                else
                    comment_st=failed
                    failure_detail+="  comment: POST /repos/$target/issues/$issue/comments failed: $(tr '\n' ' ' < "$err_buf")"$'\n'
                    comment_url=""
                fi
            else
                comment_st=failed
                failure_detail+="  comment: re-point of prior link comment $prior_comment_url failed: $(tr '\n' ' ' < "$err_buf")"$'\n'
                comment_url=""
            fi
        elif comment_url=$(_post_body "/repos/$target/issues/$issue/comments" "$body" 2>"$err_buf"); then
            comment_st=ok
        else
            comment_st=failed
            failure_detail+="  comment: POST /repos/$target/issues/$issue/comments failed: $(tr '\n' ' ' < "$err_buf")"$'\n'
            comment_url=""
        fi
    fi

    # Step 3: rocket the trigger comment, if one was supplied. Posts to
    # $trigger_target (defaults to $target; --trigger-repo overrides).
    if [[ -n "$trigger_comment" && "$trigger_comment" != "0" ]]; then
        : > "$err_buf"
        if api -X POST "/repos/$trigger_target/issues/comments/$trigger_comment/reactions" \
               -f content=rocket >/dev/null 2>"$err_buf"; then
            rocket_st=ok
            _mark_processed comment "$trigger_comment"
            # 🚀 = done → record the STOP marker so the re-emit registry
            # evicts this mention (your-org/nexus-code#360) rather than
            # demoting it to the 👀 slow-nudge tier.
            _mark_processed rocket "$trigger_comment"
        else
            rocket_st=failed
            failure_detail+="  rocket: POST /repos/$trigger_target/issues/comments/$trigger_comment/reactions failed: $(tr '\n' ' ' < "$err_buf")"$'\n'
        fi
    fi

    # ($source_window was resolved before the skeptic gate, above.)

    # Step 4: log the action. Always attempted — useful even on partial
    # success so the orchestrator can audit which wrap-up step blocked.
    local -a log_args=(
        monitor
        --event wrap-up
        --extra "issue=$issue"
        --extra "report=$basename"
    )
    [[ -n "$asset_url" ]]        && log_args+=( --extra "asset-url=$asset_url" )
    [[ -n "$comment_url" ]]      && log_args+=( --extra "comment-url=$comment_url" )
    [[ -n "$trigger_comment" ]]  && log_args+=( --extra "trigger-comment=$trigger_comment" )
    [[ -n "$source_window" ]]    && log_args+=( --extra "window=$source_window" )
    log_args+=( --extra "repo=$target" )
    # Record trigger-repo only when it differs from repo — keeps
    # legacy entries compact (and parseable by jq selectors that
    # don't expect the field) while still surfacing cross-repo
    # wrap-ups for audit.
    [[ "$trigger_target" != "$target" ]] \
        && log_args+=( --extra "trigger-repo=$trigger_target" )
    log_args+=( --extra "upload=$upload_st" )
    log_args+=( --extra "comment=$comment_st" )
    log_args+=( --extra "rocket=$rocket_st" )
    if ( cmd_log_action "${log_args[@]}" ) 2>/dev/null; then
        log_st=ok
    else
        log_st=failed
        failure_detail+=$'  log-action: append to action-log.jsonl failed\n'
    fi

    # Step 5: auto-retain the source tmux window so the watcher's idle-worker
    # probe suppresses it into the retained-footer for retain_ttl_seconds
    # (default 24 h, config monitor.retain_ttl_seconds). Skipped when:
    #   - --no-retain was passed (close-immediately opt-out), OR
    #   - no source_window (verb ran outside the worker's tmux pane —
    #     orchestrator-side direct call, test harness, etc.).
    # Retention failure does NOT flip exit code: the wrap-up itself
    # already succeeded; failing to log a retain is auditability noise,
    # not a hand-off blocker. Stderr still names the step.
    local retain_st=skipped
    if (( no_retain == 0 )) && [[ -n "$source_window" ]]; then
        local effective_retain_reason="$retain_reason"
        if [[ -z "$effective_retain_reason" ]]; then
            effective_retain_reason="wrap-up-$(date -u +%Y-%m-%d)"
        fi
        local -a retain_args=(
            monitor
            --event window-retain
            --extra "window=$source_window"
            --extra "reason=$effective_retain_reason"
            --extra "issue=$issue"
        )
        if ( cmd_log_action "${retain_args[@]}" ) 2>/dev/null; then
            retain_st=ok
        else
            retain_st=failed
            failure_detail+=$'  retain: append window-retain to action-log.jsonl failed\n'
        fi
    fi

    # Summary line per step (stdout — machine-readable, predictable order).
    if [[ "$upload_st" == ok ]]; then
        printf 'uploaded: %s\n' "$asset_url"
    else
        printf 'uploaded: FAILED\n'
    fi
    if [[ "$comment_st" == ok ]]; then
        printf 'posted comment: %s\n' "$comment_url"
    elif [[ "$comment_st" == updated ]]; then
        printf 'posted comment: UPDATED %s (post-once: link re-pointed to the new upload)\n' "$comment_url"
    elif [[ "$comment_st" == skipped ]]; then
        printf 'posted comment: SKIPPED (upload failed)\n'
    else
        printf 'posted comment: FAILED\n'
    fi
    if [[ -n "$trigger_comment" && "$trigger_comment" != "0" ]]; then
        if [[ "$rocket_st" == ok ]]; then
            printf 'rocketed comment %s\n' "$trigger_comment"
        else
            printf 'rocketed comment %s: FAILED\n' "$trigger_comment"
        fi
    fi
    if [[ "$log_st" == ok ]]; then
        printf 'logged action: wrap-up issue=%s report=%s\n' "$issue" "$basename"
    else
        printf 'logged action: FAILED\n'
    fi
    if [[ "$retain_st" == ok ]]; then
        printf 'retained window: %s (reason=%s; ttl=monitor.retain_ttl_seconds)\n' \
            "$source_window" "${retain_reason:-wrap-up-$(date -u +%Y-%m-%d)}"
    elif [[ "$retain_st" == failed ]]; then
        printf 'retained window: FAILED\n'
    fi

    # Aggregate: failures (not skips) on the hand-off steps flip exit.
    # Step 5 (retain) is auditability — its failure surfaces on stderr
    # but does not flip exit on its own. A failed retain leaves the
    # worker visible to the next idle-worker emit, which is the safe
    # degradation: the orchestrator will see and triage the row.
    if [[ "$upload_st" == failed || "$comment_st" == failed \
          || "$rocket_st" == failed || "$log_st" == failed ]]; then
        {
            printf 'ng wrap-up: partial failure — retry the failed steps:\n'
            printf '%s' "$failure_detail"
        } >&2
        return 1
    fi
    if [[ "$retain_st" == failed ]]; then
        {
            printf 'ng wrap-up: retain logging failed (wrap-up itself succeeded):\n'
            printf '%s' "$failure_detail"
        } >&2
    fi

    # (The skeptic protocol step ran as Step 0b, BEFORE the GitHub
    # hand-off — see the rationale there. By here the hand-off has
    # already succeeded, so nothing skeptic-related remains.)

    # Step 7 (informational): interactive-wrap clarification (the #205
    # state-machine follow-up). When the source window carries a live
    # operator-engagement mark, this wrap-up does NOT release the
    # window — interactive sessions stay engaged by default, because
    # the operator may have follow-up inquiries. Tell the agent how to
    # signal the finished state explicitly. A machine-driven (non-
    # engaged) wrap-up prints nothing here and keeps today's behavior.
    if [[ -n "$source_window" ]] && _wrapup_window_engaged "$source_window"; then
        printf '%s\n' \
            '' \
            'NOTE: operator-engaged (interactive) session detected — clarify your finished state:' \
            '  - expecting follow-up user inquiries (the DEFAULT): do nothing further.' \
            '    The window stays engaged; idle cleanup and retire-eligibility remain' \
            '    suppressed while the operator is active (the mark self-expires on its' \
            '    own once the pane goes static past the change TTL).' \
            '  - FINISHED with this interactive session: run' \
            '        ng engaged-done' \
            '    to release the window for the typical wrapped-window cleanup.'
    fi
    return 0
}

# Does `window` carry a live operator-engagement mark? Lightweight
# ng-side mirror of the watcher's `_openg_marked` validity core (row
# seeded + pane-content change within the decay TTL + no newer
# `engaged-done`), reading the same state files the watcher writes:
#   - $STATE_DIR/operator-engaged.tsv   (row: since/last/…)
#   - $STATE_DIR/pane-change/<window>   (hash \t last_change_epoch)
#   - $STATE_DIR/action-log.jsonl       (engaged-done events)
# Used only to decide whether the interactive-wrap clarification
# prints — over-printing is harmless, so the spawn-lifecycle guard the
# watcher applies is deliberately omitted here.
_wrapup_window_engaged() {
    local window="$1"
    [[ -n "$window" ]] || return 1
    local row since last
    row=$(awk -F'\t' -v w="$window" '$1 == w { printf "%s\t%s", $2, $3; exit }' \
        "$STATE_DIR/operator-engaged.tsv" 2>/dev/null)
    [[ -n "$row" ]] || return 1
    IFS=$'\t' read -r since last <<<"$row"
    [[ "$since" =~ ^[0-9]+$ && "$last" =~ ^[0-9]+$ ]] || return 1
    (( since > 0 && last > 0 )) || return 1
    # Self-expiry mirror: mark holds only while the pane changed
    # within the decay TTL.
    local change_epoch ttl now
    change_epoch=$(awk -F'\t' 'NR == 1 { print $2; exit }' \
        "$STATE_DIR/pane-change/$window" 2>/dev/null)
    [[ "$change_epoch" =~ ^[0-9]+$ ]] || return 1
    ttl="${MONITOR_OPERATOR_ENGAGED_CHANGE_TTL_SECONDS:-}"
    if [[ ! "$ttl" =~ ^[0-9]+$ ]]; then
        ttl=$("$_cfg" monitor.operator_engaged_change_ttl_seconds 600 2>/dev/null) || ttl=600
        [[ "$ttl" =~ ^[0-9]+$ ]] || ttl=600
    fi
    now=$(date +%s)
    (( change_epoch > 0 && now - change_epoch <= ttl )) || return 1
    # Finished-signal mirror: a newer engaged-done already released it.
    local done_ts done_epoch
    done_ts=$(grep '"event":"engaged-done"' "$STATE_DIR/action-log.jsonl" 2>/dev/null \
        | tac \
        | jq -r --arg w "$window" 'select(.window == $w) | .ts' 2>/dev/null \
        | head -1)
    if [[ -n "$done_ts" ]]; then
        done_epoch=$(date -d "$done_ts" +%s 2>/dev/null) || done_epoch=""
        if [[ "$done_epoch" =~ ^[0-9]+$ ]] && (( done_epoch > since )); then
            return 1
        fi
    fi
    return 0
}

# `ng engaged-done [--window <name>]`
#
# The interactive session's explicit FINISHED-signal (the #205
# state-machine follow-up). A wrap-up from an operator-engaged window
# does NOT release the window — the engagement mark survives the
# hand-off so the operator's follow-up inquiries keep flowing without
# the watcher nagging or retiring the window. When the agent is
# genuinely done (no follow-up expected), this verb appends the
# `engaged-done` event the watcher's `_openg_marked` treats as an
# invalidation: the mark dies, and the window drops back to the
# typical wrapped-window cleanup path (retain footer → retire
# eligibility), exactly like a never-engaged worker that wrapped.
# A LATER operator prompt re-seeds a fresh engagement episode — the
# release is never a lock-out.
#
# Window resolution mirrors wrap-up's: the calling pane's tmux window
# via $TMUX_PANE; pass --window when invoking from outside the pane.
cmd_engaged_done() {
    _help_check "$@"
    local window_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --window) window_arg="${2:-}"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    local window="$window_arg"
    [[ -n "$window" ]] || window=$(_report_tmux_window)
    [[ -n "$window" ]] \
        || die "engaged-done: no tmux window resolvable — run inside the worker's pane or pass --window <name>"
    ( cmd_log_action monitor --event engaged-done --extra "window=$window" ) \
        || die "engaged-done: action-log append failed"
    printf 'engaged-done: %s released for normal cleanup (engagement mark invalidated; typical wrapped-window retire path applies; a new operator prompt re-engages)\n' \
        "$window"
}

# Fetch a github.com/user-attachments/{assets,files}/... URL via the
# user's PAT and write the bytes to disk. Bridges the bot's blind spot
# on user-pasted images: those URLs are scoped to user-OAuth credentials
# only; the App installation token returns 404 silently. See probe A in
# reports/nexus_2026-04-30_235529_hosted-survey.md.
#
# Two stages:
#   1. GET the user-attachments URL with `Authorization: Bearer <user-PAT>`
#      → expect 302 to a 5-min signed S3 URL (response body is empty).
#   2. GET the S3 URL → bytes (no auth; the signature is in the URL).
#
# Stage 1 deliberately uses `curl` with the user's `gh auth token`, NOT
# the bot's `api()` helper — the App credentials silently 404 here.
#
# Exit codes:
#   0  success
#   1  user input error (not a user-attachments URL, missing arg, unknown flag)
#   2  auth failure (gh auth token empty, or PAT rejected at stage 1)
#   3  fetch failure (stage 1 missing Location, stage 2 non-200, network)
#   4  --image-only set and content-type is not image/*
cmd_fetch_asset() {
    _help_check "$@"
    local url="" out="" image_only=0
    while (( $# > 0 )); do
        case "$1" in
            --out)        out="${2:-}"; shift 2 ;;
            --image-only) image_only=1; shift   ;;
            -*)
                echo "ng fetch-asset: unknown flag: $1" >&2; exit 1 ;;
            *)
                if [[ -z "$url" ]]; then
                    url="$1"; shift
                else
                    echo "ng fetch-asset: unexpected positional: $1" >&2; exit 1
                fi
                ;;
        esac
    done
    [[ -n "$url" ]] || {
        echo "ng fetch-asset: usage: ng fetch-asset <user-attachments URL> [--out PATH] [--image-only]" >&2
        exit 1
    }
    [[ "$url" =~ ^https://github\.com/user-attachments/(assets|files)/ ]] || {
        echo "ng fetch-asset: not a github.com/user-attachments/{assets,files}/... URL: $url" >&2
        exit 1
    }

    local asset_id
    asset_id=$(awk -F/ '{ sub(/\?.*/,""); print $NF }' <<<"$url")
    [[ -n "$asset_id" ]] || { echo "ng fetch-asset: could not extract asset id from URL" >&2; exit 1; }

    # User PAT, NOT bot installation token. We deliberately read it
    # via `gh auth token` instead of forwarding $GH_TOKEN — bot tokens
    # 404 on this domain, and that's the entire reason this verb exists.
    #
    # locals-env.sh scopes GH_CONFIG_DIR to a credential-free dir (fail-closed
    # identity), so name the operator's config dir explicitly rather than
    # relying on gh-shim.sh being on PATH — this verb must keep working even
    # when the PATH-front wrapper is not reached.
    local user_pat opcfg=""
    if [[ -n "${NEXUS_OPERATOR_GH_CONFIG_DIR:-}" ]]; then
        opcfg="$NEXUS_OPERATOR_GH_CONFIG_DIR"
    elif [[ -n "${NEXUS_GH_CONFIG_SCOPED:-}" ]]; then
        opcfg="${XDG_CONFIG_HOME:-${HOME:-}/.config}/gh"
    fi
    if [[ -n "$opcfg" ]]; then
        user_pat=$(GH_CONFIG_DIR="$opcfg" gh auth token 2>/dev/null) || true
    else
        user_pat=$(gh auth token 2>/dev/null) || true
    fi
    [[ -n "$user_pat" ]] || {
        echo "ng fetch-asset: gh auth token returned empty; user PAT required (run: gh auth login)" >&2
        exit 2
    }

    local h1 h2
    h1=$(mktemp); h2=$(mktemp)
    trap "rm -f '$h1' '$h2'" RETURN

    local s1_status
    s1_status=$(curl -sS -o /dev/null -D "$h1" -w '%{http_code}' \
        -H "Authorization: Bearer $user_pat" \
        -H "Accept: application/octet-stream" \
        "$url") || { echo "ng fetch-asset: stage 1 curl failed (network?)" >&2; exit 3; }

    case "$s1_status" in
        302|303) ;;
        401|403)
            echo "ng fetch-asset: stage 1 returned $s1_status — user PAT rejected (token expired or insufficient scopes)" >&2
            exit 2 ;;
        404)
            cat >&2 <<'EOF'
ng fetch-asset: user-attachments URL not accessible to bot or user PAT (GitHub requires browser-session auth for this surface).

Workaround: ask the user to place the file locally under work/<project>/
and reference it by absolute path, or post the issue/comment number it's
attached to so the file can be downloaded via the issue's REST timeline
surface (e.g. gh api repos/<owner>/<repo>/issues/<N>/timeline for inline
images attached to issue or comment bodies). Stop attempting fetches
through this verb and route the gap to the user.
EOF
            exit 3 ;;
        *)
            echo "ng fetch-asset: stage 1 returned unexpected status $s1_status" >&2
            exit 3 ;;
    esac

    local location
    location=$(awk 'BEGIN{IGNORECASE=1} /^[Ll]ocation:/ { sub(/^[Ll]ocation: */,""); sub(/\r$/,""); print; exit }' "$h1")
    [[ -n "$location" ]] || { echo "ng fetch-asset: stage 1 redirect missing Location header" >&2; exit 3; }

    if [[ -z "$out" ]]; then
        # Default path: monitor/.state/assets/<asset-id><ext>. Extension
        # comes from the S3 URL basename (canonical) or the
        # response-content-type query param GitHub sets on the signed URL.
        local s3_basename ext=""
        s3_basename=$(awk -F/ '{ sub(/\?.*/,""); print $NF }' <<<"$location")
        if [[ "$s3_basename" == *.* ]]; then
            ext=".${s3_basename##*.}"
        elif [[ "$location" =~ response-content-type=([^&]+) ]]; then
            local ct="${BASH_REMATCH[1]}"
            ct="${ct//%2F//}"; ct="${ct//%2f//}"
            case "$ct" in
                image/png)            ext=".png"  ;;
                image/jpeg|image/jpg) ext=".jpg"  ;;
                image/gif)            ext=".gif"  ;;
                image/webp)           ext=".webp" ;;
                image/svg+xml)        ext=".svg"  ;;
                application/pdf)      ext=".pdf"  ;;
                *)                    ext=".bin"  ;;
            esac
        else
            ext=".bin"
        fi
        mkdir -p "$STATE_DIR/assets"
        out="$STATE_DIR/assets/${asset_id}${ext}"
    else
        local out_dir
        out_dir=$(dirname -- "$out")
        mkdir -p "$out_dir"
    fi

    # Stage 2: signed S3 URL, no auth. -f makes 4xx/5xx fail-fast so
    # we don't leave a 0-byte / error-body file on disk.
    local s2_status
    s2_status=$(curl -sS -f -o "$out" -D "$h2" -w '%{http_code}' "$location") || {
        echo "ng fetch-asset: stage 2 curl failed (S3 signed URL expired or denied; status=$s2_status)" >&2
        rm -f "$out"
        exit 3
    }
    [[ "$s2_status" == "200" ]] || {
        echo "ng fetch-asset: stage 2 returned $s2_status (expected 200)" >&2
        rm -f "$out"
        exit 3
    }

    local content_type byte_count
    content_type=$(awk 'BEGIN{IGNORECASE=1} /^[Cc]ontent-[Tt]ype:/ { sub(/^[Cc]ontent-[Tt]ype: */,""); sub(/\r$/,""); print; exit }' "$h2")
    [[ -n "$content_type" ]] || content_type="application/octet-stream"
    byte_count=$(stat -c %s "$out" 2>/dev/null || wc -c < "$out")

    if (( image_only == 1 )) && [[ ! "$content_type" =~ ^image/ ]]; then
        echo "ng fetch-asset: --image-only set but content-type is $content_type" >&2
        rm -f "$out"
        exit 4
    fi

    printf 'path=%s\ncontent_type=%s\nbytes=%s\n' "$out" "$content_type" "$byte_count"
}

cmd_issue() {
    _help_check_first "$@"
    local first="${1:-}"; shift || true
    [[ -n "$first" ]] || die "usage: ng issue <n> | ng issue create ... | ng issue comment <n> ... | ng issue close <n> ..."
    case "$first" in
        create)  cmd_issue_create  "$@" ;;
        comment) cmd_issue_comment "$@" ;;
        close)   cmd_close         "$@" ;;  # delegate; keeps one code path for close
        view)    cmd_issue_view    "$@" ;;
        *[!0-9]*|"") die "ng issue: not a number and not a known subcommand: $first" ;;
        *)       cmd_issue_view "$first" "$@" ;;  # numeric -> view
    esac
}

# `ng issue <n>` -> "#<n> state=OPEN title=..." (one-liner; default
# stays terse so dashboards keep scripting against it). Flags expand:
#   --with-body      : append the issue body
#   --with-comments  : append all comments (chronological, with author)
#   --repo OWNER/NAME: target a different repo than $REPO
cmd_issue_view() {
    _help_check "$@"
    local n="${1:-}"; shift || true
    [[ -n "$n" ]] || die "usage: ng issue <n> [--repo <owner/name>] [--with-body] [--with-comments]"
    local repo_arg="" want_body=0 want_comments=0
    while (( $# > 0 )); do
        case "$1" in
            --repo)          repo_arg="${2:-}"; shift 2 ;;
            --with-body)     want_body=1;       shift ;;
            --with-comments) want_comments=1;   shift ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    local target meta out
    target=$(_resolve_repo read "$repo_arg") || exit $?
    meta=$(api "/repos/$target/issues/$n" 2>/dev/null) \
        || die "issue $n: fetch failed"
    out=$(jq -r 'select(.number) | "#\(.number) state=\(.state | ascii_upcase) title=\(.title)"' <<<"$meta")
    [[ -n "$out" ]] || die "issue $n: fetch failed"
    printf '%s\n' "$out"
    if (( want_body == 1 )); then
        local body
        body=$(jq -r '.body // ""' <<<"$meta")
        printf '\n--- body ---\n%s\n' "$body"
    fi
    if (( want_comments == 1 )); then
        printf '\n--- comments ---\n'
        api --paginate "/repos/$target/issues/$n/comments?per_page=100" 2>/dev/null \
            | jq -r '.[] | "\n[\(.created_at)] \(.user.login):\n\(.body)"'
    fi
}

# Open a new issue under the bot account. Body is required (from
# --body-file or stdin). Labels may be repeated.
cmd_issue_create() {
    _help_check "$@"
    local title="" body_file="" repo_arg=""
    local -a labels=()
    while (( $# > 0 )); do
        case "$1" in
            --title)     title="${2:-}";     shift 2 ;;
            --body-file) body_file="${2:-}"; shift 2 ;;
            --label)     labels+=("${2:-}"); shift 2 ;;
            --repo)      repo_arg="${2:-}";  shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    [[ -n "$title" ]] || die "ng issue create: --title is required"
    local body target
    body=$(_read_body "$body_file")
    [[ -n "$body" ]] || die "ng issue create: empty body"
    target=$(_resolve_repo write "$repo_arg") || exit $?
    # Build the POST payload with jq so label escaping stays honest.
    # An empty array goes to jq as zero args (not `[""]`) — which
    # matters because GitHub rejects `labels: [""]`.
    local payload
    if (( ${#labels[@]} > 0 )); then
        payload=$(jq -n --arg t "$title" --arg b "$body" \
            --argjson ls "$(printf '%s\n' "${labels[@]}" | jq -R . | jq -s .)" \
            '{title:$t, body:$b, labels:$ls}')
    else
        payload=$(jq -n --arg t "$title" --arg b "$body" '{title:$t, body:$b}')
    fi
    local url
    url=$(printf '%s' "$payload" \
          | api -X POST "/repos/$target/issues" --input - \
          | jq -r '.html_url // empty')
    [[ -n "$url" ]] || die "issue create failed"
    printf '%s\n' "$url"
}

# Post a comment. Equivalent to `ng reply` but lives under the `issue`
# namespace for discoverability. Body from --body-file or stdin.
cmd_issue_comment() {
    _help_check "$@"
    local n="${1:-}"; shift || true
    [[ -n "$n" ]] || die "usage: ng issue comment <n> [--repo <owner/name>] [--body-file <path>]"
    local body_file="" repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --body-file) body_file="${2:-}"; shift 2 ;;
            --repo)      repo_arg="${2:-}";  shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    local target
    target=$(_resolve_repo write "$repo_arg") || exit $?
    _post_body "/repos/$target/issues/$n/comments" "$(_read_body "$body_file")"
}

# ---- pull requests ----

# Dispatch: `ng pr create|edit|merge|view ...`
cmd_pr() {
    _help_check_first "$@"
    local sub="${1:-}"; shift || true
    case "$sub" in
        create) cmd_pr_create "$@" ;;
        edit)   cmd_pr_edit   "$@" ;;
        merge)  cmd_pr_merge  "$@" ;;
        view)   cmd_pr_view   "$@" ;;
        *)      die "usage: ng pr create|edit|merge|view ..." ;;
    esac
}

# Open a PR. Body is required (from --body-file or stdin). Branch must
# already be pushed to origin; this is pure API, it doesn't push for you.
#
# Reviewer behavior: bot-opened PRs default to --reviewer
# $github.user_login, so each PR auto-requests review from the human
# operator. GitHub mutes notifications for actions taken by the
# recipient's account, so without this the dashboard surface goes
# cold for any repo missing CODEOWNERS. Belt-and-suspenders with
# `.github/CODEOWNERS` for repos that have it; the only gap is repos
# where the requested login isn't a collaborator (then the
# requested_reviewers POST 422s — we warn, not fatal).
# Opt-out with --no-reviewer; override with --reviewer <login>.
cmd_pr_create() {
    _help_check "$@"
    local head="" base="main" title="" body_file="" repo_arg=""
    # Sentinel distinguishes "not passed" from "passed empty" — empty
    # means --no-reviewer (caller intends to skip), unset means default.
    local reviewer="__DEFAULT__"
    while (( $# > 0 )); do
        case "$1" in
            --head)        head="${2:-}";      shift 2 ;;
            --base)        base="${2:-}";      shift 2 ;;
            --title)       title="${2:-}";     shift 2 ;;
            --body-file)   body_file="${2:-}"; shift 2 ;;
            --repo)        repo_arg="${2:-}";  shift 2 ;;
            --reviewer)    reviewer="${2:-}";  shift 2 ;;
            --no-reviewer) reviewer="";        shift ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    [[ -n "$head"  ]] || die "ng pr create: --head is required"
    [[ -n "$title" ]] || die "ng pr create: --title is required"
    local body target
    body=$(_read_body "$body_file")
    [[ -n "$body" ]] || die "ng pr create: empty body"
    target=$(_resolve_repo write "$repo_arg") || exit $?
    # When PRing into a non-nexus repo, run the bot-install preflight
    # so a missing install fails with a clear remediation instead of
    # GitHub's "Resource not accessible by integration" GraphQL error.
    if [[ "$target" != "$REPO" ]]; then
        _preflight_repo "$target" || die "preflight failed for $target — install the bot before retrying"
    fi
    [[ "$reviewer" == "__DEFAULT__" ]] && reviewer="$USER_LOGIN"
    local response url number
    response=$(jq -n --arg t "$title" --arg b "$body" --arg h "$head" --arg base "$base" \
            '{title:$t, body:$b, head:$h, base:$base}' \
          | api -X POST "/repos/$target/pulls" --input -)
    url=$(jq -r '.html_url // empty'  <<<"$response")
    number=$(jq -r '.number // empty' <<<"$response")
    [[ -n "$url" ]] || die "pr create failed"
    # Auto-request review via separate endpoint (the pulls POST doesn't
    # accept `reviewers`). Bot identity != reviewer, so self-review
    # rejection isn't a concern. Failure here is warned, not fatal: a
    # missing collaborator (e.g. CODEOWNERS-only flow) shouldn't kill
    # an otherwise-successful PR open.
    if [[ -n "$reviewer" && -n "$number" ]]; then
        if ! jq -n --arg u "$reviewer" '{reviewers:[$u]}' \
             | api -X POST "/repos/$target/pulls/$number/requested_reviewers" --input - >/dev/null; then
            echo "ng: warning: failed to request review from @$reviewer on $target#$number" >&2
        fi
    fi
    printf '%s\n' "$url"
}

# Patch title and/or body on an existing PR. Either flag alone is fine.
cmd_pr_edit() {
    _help_check "$@"
    local n="${1:-}"; shift || true
    [[ -n "$n" ]] || die "usage: ng pr edit <n> [--repo <owner/name>] [--title <t>] [--body-file <path>]"
    local title="" body_file="" have_body=0 repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --title)     title="${2:-}";     shift 2 ;;
            --body-file) body_file="${2:-}"; have_body=1; shift 2 ;;
            --repo)      repo_arg="${2:-}";  shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    [[ -n "$title" || "$have_body" == 1 ]] || die "ng pr edit: pass --title and/or --body-file"
    local payload='{}' target
    target=$(_resolve_repo write "$repo_arg") || exit $?
    [[ -n "$title" ]]    && payload=$(jq -c --arg t "$title" '. + {title:$t}' <<<"$payload")
    if (( have_body == 1 )); then
        local body
        body=$(_read_body "$body_file")
        [[ -n "$body" ]] || die "ng pr edit: empty body"
        payload=$(jq -c --arg b "$body" '. + {body:$b}' <<<"$payload")
    fi
    local url
    url=$(printf '%s' "$payload" \
          | api -X PATCH "/repos/$target/pulls/$n" --input - \
          | jq -r '.html_url // empty')
    [[ -n "$url" ]] || die "pr edit failed"
    printf '%s\n' "$url"
}

# Merge a PR via the REST API. Prints the merge commit SHA. Optional
# --delete-branch removes the head ref after a successful merge.
cmd_pr_merge() {
    _help_check "$@"
    local n="${1:-}"; shift || true
    [[ -n "$n" ]] || die "usage: ng pr merge <n> [--repo <owner/name>] [--squash|--merge|--rebase] [--delete-branch]"
    local method="squash" delete_branch=0 repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --squash) method="squash"; shift ;;
            --merge)  method="merge";  shift ;;
            --rebase) method="rebase"; shift ;;
            --delete-branch) delete_branch=1; shift ;;
            --repo)   repo_arg="${2:-}"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    local head_ref sha target
    target=$(_resolve_repo write "$repo_arg") || exit $?
    head_ref=$(api "/repos/$target/pulls/$n" 2>/dev/null | jq -r '.head.ref // empty')
    sha=$(jq -n --arg m "$method" '{merge_method:$m}' \
          | api -X PUT "/repos/$target/pulls/$n/merge" --input - \
          | jq -r '.sha // empty')
    [[ -n "$sha" ]] || die "pr merge failed"
    printf '%s\n' "$sha"
    if (( delete_branch == 1 )); then
        [[ -n "$head_ref" ]] || { echo "ng: could not resolve head ref; skipping delete" >&2; return 0; }
        api -X DELETE "/repos/$target/git/refs/heads/$head_ref" >/dev/null \
            || echo "ng: failed to delete branch $head_ref (already gone?)" >&2
    fi
}

# Read-only summary: #N state=OPEN author=login title=..., plus head->base.
# `--json [field,...]` switches to scriptable JSON (#236 B4): bare
# `--json` prints the full REST pull object; `--json number,state,title`
# selects those fields. Field names are GitHub REST pull-object keys
# (number, state, title, draft, merged, mergeable, …); dotted paths like
# `head.ref` resolve too.
cmd_pr_view() {
    _help_check "$@"
    local n="${1:-}"; shift || true
    [[ -n "$n" ]] || die "usage: ng pr view <n> [--repo <owner/name>] [--json [field,...]]"
    local repo_arg="" want_json=0 json_fields=""
    while (( $# > 0 )); do
        case "$1" in
            --repo) repo_arg="${2:-}"; shift 2 ;;
            --json)
                want_json=1
                # An optional following token that isn't another flag is
                # the comma-separated field selector.
                if [[ -n "${2:-}" && "$2" != --* ]]; then
                    json_fields="$2"; shift 2
                else
                    shift
                fi
                ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    local target raw
    target=$(_resolve_repo read "$repo_arg") || exit $?
    raw=$(api "/repos/$target/pulls/$n" 2>/dev/null)
    [[ -n "$raw" ]] && jq -e '.number' <<<"$raw" >/dev/null 2>&1 \
        || die "pr $n: fetch failed"
    if (( want_json )); then
        if [[ -n "$json_fields" ]]; then
            local filter='{}' f
            local IFS=','
            for f in $json_fields; do
                f="${f// /}"
                [[ -n "$f" ]] || continue
                [[ "$f" =~ ^[A-Za-z0-9_.]+$ ]] \
                    || die "pr view --json: invalid field name: $f"
                filter="$filter + {\"$f\": (.$f? // null)}"
            done
            jq -S "$filter" <<<"$raw"
        else
            jq -S '.' <<<"$raw"
        fi
        return 0
    fi
    jq -r 'select(.number) | "#\(.number) state=\(.state | ascii_upcase) author=\(.user.login) \(.head.ref)->\(.base.ref) title=\(.title)"' <<<"$raw"
}

# ---- read-only repo / comment helpers ----

# `ng preflight <owner/repo>` — is the bot's installation able to write
# to this repo? Cross-repo PR/issue verbs would otherwise surface a
# confusing "Resource not accessible by integration" GraphQL error;
# this turns that into one explicit yes/no line front-loaded.
#
# Beyond the yes/no, preflight surfaces the installation's
# `repository_selection` (all|selected) and — when the repo is missing —
# a concrete management URL plus the bot name, so the operator lands on
# the page that adds the repo instead of hunting through GitHub's
# settings UI (U5, your-org/your-nexus#236). One /installation/
# repositories call drives all of it.
#
# Exit 0: yes. Exit 1: no (with remediation hint).
cmd_preflight() {
    _help_check "$@"
    local target="${1:-}"
    [[ -n "$target" ]] || die "usage: ng preflight <owner/repo>"
    [[ "$target" == */* ]] || die "preflight: target must be OWNER/NAME (got: $target)"

    # One paginated fetch surfaces BOTH the membership test and
    # repository_selection — same slurp shape as _preflight_repo, so the
    # two stay in sync. errexit is off (set -uo pipefail, no -e); the
    # `|| x=...` guards convert jq's -e "result was false/null" exit and
    # any empty-payload jq error into a safe default rather than aborting.
    local payload installed selection
    payload=$(api --paginate "/installation/repositories?per_page=100" 2>/dev/null)
    installed=$(printf '%s' "$payload" | jq -es --arg t "$target" \
        '[.[].repositories[]?.full_name] | any(. == $t)' 2>/dev/null) || installed=false
    selection=$(printf '%s' "$payload" | jq -rs \
        '[.[].repository_selection] | map(select(. != null)) | first // "unknown"' \
        2>/dev/null) || selection=unknown

    if [[ "$installed" == "true" ]]; then
        printf 'bot installed: yes (%s) — repository_selection=%s\n' "$target" "$selection"
        return 0
    fi

    local bot_name owner install_id url owner_match
    bot_name=$("$_cfg" github.bot_git_name "the nexus bot")
    bot_name="${bot_name%\[bot\]}"
    owner="${target%%/*}"
    install_id=$("$_cfg" github.bot_installation_id 2>/dev/null) || install_id=""

    # Pin the installation id in the URL only when we can confirm the
    # bot's installation actually lives under $owner (it can see at least
    # one repo owned by $owner). A stale id under the wrong org 404s, so
    # otherwise fall back to the org-level installations list page.
    owner_match=$(printf '%s' "$payload" | jq -es --arg o "$owner" \
        'any(.[].repositories[]?; .owner.login == $o)' 2>/dev/null) || owner_match=false
    if [[ -n "$install_id" && "$owner_match" == "true" ]]; then
        url="https://github.com/organizations/$owner/settings/installations/$install_id"
    else
        url="https://github.com/organizations/$owner/settings/installations"
    fi

    printf 'bot installed: NO (%s) — repository_selection=%s\n' "$target" "$selection"
    printf '  ask org admin for %s to add %s to %s'\''s installation:\n' \
        "$owner" "$target" "$bot_name"
    printf '    %s\n' "$url"
    return 1
}

# `ng show <comment-id>` — read-only fetch of a comment by ID. Bypasses
# the `ng process` eligibility filter (which only surfaces
# user-authored comments) so agents can quote prior bot deliverables in
# replies. The security boundary is in the *processing* path, not the
# read path.
#
# `--meta` additionally emits the CAS snapshot header for
# `ng comment-edit --expect-updated-at` (the safe read half of the
# read-modify-write loop, #524 defect 1):
#   id=<cid>
#   updated_at=<ts>
#   body<<EOF
#   <body>
#   EOF
cmd_show() {
    _help_check "$@"
    local cid="${1:-}"; shift || true
    [[ -n "$cid" ]] || die "usage: ng show <comment-id> [--repo <owner/name>] [--meta]"
    local repo_arg="" with_meta=0
    while (( $# > 0 )); do
        case "$1" in
            --repo) repo_arg="${2:-}"; shift 2 ;;
            --meta) with_meta=1;       shift   ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    local target meta body
    target=$(_resolve_repo read "$repo_arg") || exit $?
    meta=$(api "/repos/$target/issues/comments/$cid" 2>/dev/null) \
        || die "comment $cid: fetch failed"
    body=$(jq -r '.body // empty' <<<"$meta")
    [[ -n "$body" ]] || die "comment $cid: fetch failed (or empty body)"
    if (( with_meta == 1 )); then
        local updated
        updated=$(jq -r '.updated_at // empty' <<<"$meta")
        [[ -n "$updated" ]] || die "comment $cid: malformed metadata (no updated_at)"
        printf 'id=%s\nupdated_at=%s\nbody<<EOF\n%s\nEOF\n' "$cid" "$updated" "$body"
    else
        printf '%s\n' "$body"
    fi
}

# ---- dashboard ----

# Resolve the overview issue number. Three layers of robustness, in
# priority order, against the labelled-issue index's eventual
# consistency (~60% empty-result rate observed in
# `reports/nexus_2026-04-27_113127_ng-overview-flakiness.md`):
#
#   1. `github.overview_issue_number` in config/nexus.yml — if set,
#      skip the lookup entirely. Cheapest, most reliable.
#   2. Per-process cache at $STATE_DIR/overview-number — populated on
#      first successful lookup; valid for the life of this state dir.
#   3. Live API call with up to 3 attempts (1s + 2s backoff) when the
#      label index returns `[]` transiently.
#
# Cache busts on first lookup mismatch (e.g. relabelled issue) — a
# stale cache that resolves to a non-overview issue dies on the
# eventual PATCH, not silently.
_overview_number() {
    local cache="$STATE_DIR/overview-number"
    local pinned
    pinned=$("$_cfg" github.overview_issue_number "" 2>/dev/null || true)
    if [[ -n "$pinned" && "$pinned" =~ ^[0-9]+$ ]]; then
        printf '%s' "$pinned"
        return 0
    fi
    if [[ -f "$cache" ]]; then
        local cached
        cached=$(cat "$cache" 2>/dev/null)
        if [[ "$cached" =~ ^[0-9]+$ ]]; then
            printf '%s' "$cached"
            return 0
        fi
    fi
    local n="" attempt=1 backoff=1
    while (( attempt <= 3 )); do
        n=$(api "/repos/$REPO/issues?labels=nexus:overview&state=open&per_page=5" 2>/dev/null \
            | jq -r '.[0].number // empty')
        [[ -n "$n" ]] && break
        sleep "$backoff"
        backoff=$(( backoff * 2 ))
        (( attempt++ ))
    done
    [[ -n "$n" ]] || die "no open issue with label nexus:overview (3 attempts; pin via github.overview_issue_number to skip lookup)"
    mkdir -p "$STATE_DIR"
    printf '%s' "$n" > "$cache"
    printf '%s' "$n"
}

# Extract the dashboard middle (everything between markers, exclusive).
_extract_middle() {
    awk -v s="$DASH_START" -v e="$DASH_END" '
        $0 ~ s { in_block = 1; next }
        $0 ~ e { in_block = 0 }
        in_block { print }
    '
}

# Splice: print prefix + START line + new middle (from $1 file) + END line + suffix.
_splice_body() {
    awk -v s="$DASH_START" -v e="$DASH_END" -v nf="$1" '
        function emit_new(    line) { while ((getline line < nf) > 0) print line; close(nf) }
        $0 ~ s { print; emit_new(); in_block = 1; next }
        $0 ~ e { in_block = 0; print; next }
        !in_block { print }
    '
}

# Resolve the overview issue number WITHOUT an API round-trip — for
# rendering (identity block, scaffold pointer) where the live number
# isn't load-bearing. Config pin first, else the conventional `1`.
# (`_overview_number` remains the authoritative, API-backed resolver
# used on the write path.)
_overview_number_cheap() {
    local pinned
    pinned=$("$_cfg" github.overview_issue_number "" 2>/dev/null || true)
    if [[ -n "$pinned" && "$pinned" =~ ^[0-9]+$ ]]; then
        printf '%s' "$pinned"
    else
        printf '1'
    fi
}

# ---- dashboard schema (scaffold + validate) ----

# Render the canonical dashboard skeleton to stdout. Every section in
# DASH_REQUIRED_SECTIONS appears with a one-line hint describing what it
# holds and whether it is operator-narrated or auto-populated. The
# operator pipes this into `ng dashboard put` (or fills it in first).
# Identity is intentionally a POINTER, not a copy — the canonical record
# lives in the `ng nexus-identity` block elsewhere in the same issue body.
_dashboard_template() {
    cat <<'TEMPLATE_EOF'
## Identity
_See the auto-generated **Nexus Identity** block above (run `ng nexus-identity`). Working directory, host, repos, watcher paths live there — not here._

## Infra
_Operator-narrated. Watcher / orchestrator / CC-pin health at a glance. e.g. `watcher ✅ live (pid 1234) · orchestrator ✅ · CC pin 1.x.y`._

## Services
_Auto-populatable from `monitor/services.registry` (name + healthcheck). One row per supervised service with its health. Narrate exceptions._

## In-flight
_Active worker windows: `window` · topic · state · branch/PR. Mirrors `tmux list-windows` + per-window heartbeats. Avoids spawn-name collisions._

## Awaiting operator
_Threads/decisions blocked on the operator: issue link · one-line ask. Empty is good news — keep it short._

## Recent landings
_Last few merged PRs / completed tasks: `#PR` · one-line summary · date. Trim to the most recent handful._
TEMPLATE_EOF
}

# Report which required sections are MISSING from the body in file $1.
# Prints one missing heading per line to stdout; empty output == all
# present. Pure text check (grep -Fx on each canonical heading) — no
# network, so both `dashboard validate` and the put-time warn reuse it.
_dashboard_missing_sections() {
    local file="$1" section
    for section in "${DASH_REQUIRED_SECTIONS[@]}"; do
        grep -qFx "$section" "$file" || printf '%s\n' "$section"
    done
}

# `ng dashboard scaffold` — print the canonical skeleton.
cmd_dashboard_scaffold() {
    _help_check "$@"
    (( $# == 0 )) || die "usage: ng dashboard scaffold (no args)"
    _dashboard_template
}

# `ng dashboard validate [--body-file <path>]` — check a candidate
# dashboard body (file or stdin) against DASH_REQUIRED_SECTIONS.
# Exit 0 = all required headings present; exit 1 = one or more missing
# (listed on stderr). This is the STRICT gate for CI / pre-commit use;
# the `dashboard put` path runs the same check in WARN-only mode so the
# operator is never blocked from pushing in a hurry.
cmd_dashboard_validate() {
    _help_check "$@"
    local body_file=""
    while (( $# > 0 )); do
        case "$1" in --body-file) body_file="${2:-}"; shift 2 ;; *) die "unknown flag: $1" ;; esac
    done
    local tmp; tmp=$(mktemp)
    trap "rm -f '$tmp'" RETURN
    _read_body "$body_file" > "$tmp"
    [[ -s "$tmp" ]] || die "empty dashboard body"
    local missing; missing=$(_dashboard_missing_sections "$tmp")
    if [[ -z "$missing" ]]; then
        printf 'dashboard validate: OK (all %d required sections present)\n' "${#DASH_REQUIRED_SECTIONS[@]}"
        return 0
    fi
    {
        printf 'ng dashboard validate: missing required section(s):\n'
        while IFS= read -r _s; do printf '  - %s\n' "$_s"; done <<<"$missing"
        printf 'scaffold the full skeleton with: ng dashboard scaffold\n'
    } >&2
    return 1
}

cmd_dashboard_get() {
    _help_check "$@"
    local num body
    num=$(_overview_number)
    body=$(api "/repos/$REPO/issues/$num" 2>/dev/null | jq -r '.body // empty')
    [[ -n "$body" ]] || die "overview #$num has empty body"
    case "$body" in *"$DASH_START"*"$DASH_END"*) ;; *) die "overview #$num: dashboard markers missing" ;; esac
    mkdir -p "$STATE_DIR"
    printf '%s' "$body" | _extract_middle | tee "$DASH_CACHE"
}

cmd_dashboard_put() {
    _help_check "$@"
    local body_file=""
    while (( $# > 0 )); do
        case "$1" in --body-file) body_file="${2:-}"; shift 2 ;; *) die "unknown flag: $1" ;; esac
    done
    local tmp_new tmp_full tmp_merged
    tmp_new=$(mktemp); tmp_full=$(mktemp); tmp_merged=$(mktemp)
    # Double-quoted trap expands paths at trap-set time, so cleanup
    # still works after the local vars go out of scope on RETURN
    # (set -u otherwise complains about unbound variables).
    trap "rm -f '$tmp_new' '$tmp_full' '$tmp_merged'" RETURN
    _read_body "$body_file" > "$tmp_new"
    [[ -s "$tmp_new" ]] || die "empty dashboard body"

    # Schema check in WARN-only mode: surface drift from the canonical
    # section set, but never block the push — the operator still needs to
    # update the dashboard in a hurry. `ng dashboard validate` is the
    # strict gate for anyone who wants a hard failure.
    local _missing; _missing=$(_dashboard_missing_sections "$tmp_new")
    if [[ -n "$_missing" ]]; then
        {
            printf 'ng dashboard put: WARNING — body is missing required section(s):\n'
            while IFS= read -r _s; do printf '  - %s\n' "$_s"; done <<<"$_missing"
            printf '  (pushing anyway; scaffold with `ng dashboard scaffold`)\n'
        } >&2
    fi

    local num
    num=$(_overview_number)
    api "/repos/$REPO/issues/$num" 2>/dev/null | jq -r '.body // empty' > "$tmp_full"
    [[ -s "$tmp_full" ]] || die "overview #$num: empty body"
    grep -qF -- "$DASH_START" "$tmp_full" && grep -qF -- "$DASH_END" "$tmp_full" \
        || die "overview #$num: dashboard markers missing"

    _splice_body "$tmp_new" < "$tmp_full" > "$tmp_merged"

    local url
    url=$(jq -Rs '{body: .}' < "$tmp_merged" \
          | api -X PATCH "/repos/$REPO/issues/$num" --input - \
          | jq -r '.html_url // empty')
    [[ -n "$url" ]] || die "dashboard PATCH failed"
    mkdir -p "$STATE_DIR"
    cp "$tmp_new" "$DASH_CACHE"
    # Touch the freshness timestamp the watcher reads in its emit footer.
    # Single source of truth for "when did we last write the dashboard".
    date -Is > "$STATE_DIR/dashboard-updated.ts"
    printf '%s\n' "$url"
}

cmd_dashboard() {
    _help_check_first "$@"
    local sub="${1:-}"; shift || true
    case "$sub" in
        get)      cmd_dashboard_get      "$@" ;;
        put)      cmd_dashboard_put      "$@" ;;
        scaffold) cmd_dashboard_scaffold "$@" ;;
        validate) cmd_dashboard_validate "$@" ;;
        *)   die "usage: ng dashboard get|put|scaffold|validate [--body-file <path>]" ;;
    esac
}

# ---- watcher (persistent monitor/watcher/main.sh) ----

# Listing and dumping archived diffs is intentionally NOT a subcommand.
# The archive is just a directory of sortable filenames, and the
# agent-bootstrap snippet does:
#     find monitor/.state/diffs -newer monitor/.state/last-ack.txt \
#         -type f | sort | xargs -r cat
# No CLI call saves enough to justify the surface area.

# Append one line to the action log (monitor/.state/action-log.jsonl).
# Format: {ts, agent, event, note, extra?} — intentionally tiny so the
# cost of writing to it is near-zero and agents don't dread it.
#
# Usage:
#   ng log-action <agent> --event <name> [--note <text>] [--extra k=v]...
#
# The `extra` flag may be repeated to attach arbitrary key=value pairs.
# Values are preserved as strings; structured JSON should go in --extra
# using quoted JSON values if needed.
cmd_log_action() {
    _help_check "$@"
    local agent="${1:-}"; shift || true
    [[ -n "$agent" ]] || die "usage: ng log-action <agent> --event <name> [--note <t>] [--extra k=v]..."
    local event="" note=""
    local -a extras=()
    while (( $# > 0 )); do
        case "$1" in
            --event) event="${2:-}"; shift 2 ;;
            --note)  note="${2:-}";  shift 2 ;;
            --extra) extras+=("${2:-}"); shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    [[ -n "$event" ]] || die "log-action: --event is required"
    mkdir -p "$STATE_DIR"
    local log_file="$STATE_DIR/action-log.jsonl"
    # Build the JSON incrementally with jq to keep escaping honest.
    local json
    json=$(jq -cn \
        --arg ts "$(date -Is)" \
        --arg agent "$agent" \
        --arg event "$event" \
        --arg note "$note" \
        '{ts:$ts, agent:$agent, event:$event} + (if $note != "" then {note:$note} else {} end)')
    # Fold any --extra k=v flags into the object.
    local kv k v
    for kv in "${extras[@]}"; do
        k="${kv%%=*}"; v="${kv#*=}"
        [[ -n "$k" ]] || continue
        json=$(jq -c --arg k "$k" --arg v "$v" '. + {($k): $v}' <<<"$json")
    done
    printf '%s\n' "$json" >> "$log_file"
}

# Manual emit-suppression — the orchestrator's backup lever for when the
# reactions/dedup filters fail to exclude a comment that's re-surfacing
# every poll cycle. Appends a `comment:<id>` line to
# `monitor/.state/emit-suppression.lines`; `compose_emit`'s
# `_filter_suppression` stage drops any matching `id=<N>` line from the
# assembled eligible-comments stream on the next compose tick.
#
# The file is append-only; entries persist across watcher restarts.
# Operator clears them out by editing/truncating the file directly.
# Logs a `monitor` action-log event so the meta-review can see when /
# why the backup channel was used.
cmd_suppress_emit() {
    _help_check "$@"
    local cid="" repo_arg="" reason=""
    while (( $# > 0 )); do
        case "$1" in
            --repo)   repo_arg="${2:-}"; shift 2 ;;
            --reason) reason="${2:-}";   shift 2 ;;
            --*)      die "unknown flag: $1" ;;
            *)
                if [[ -z "$cid" ]]; then cid="$1"
                else die "unexpected extra positional: $1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$cid" ]] || die "usage: ng suppress-emit <comment-id> [--repo <owner/name>] [--reason <short>]"
    # Comment ids are numeric integers in GitHub's database. Reject
    # anything that isn't to keep the suppression file format strict —
    # the compose-layer filter parses `id=<N>` tokens and a non-numeric
    # entry would never match a line shape anyway.
    [[ "$cid" =~ ^[0-9]+$ ]] || die "suppress-emit: comment-id must be numeric, got: $cid"
    mkdir -p "$STATE_DIR"
    local suppress_file="$STATE_DIR/emit-suppression.lines"
    local entry="comment:${cid}"
    [[ -f "$suppress_file" ]] || : > "$suppress_file"
    if grep -qxF "$entry" "$suppress_file"; then
        printf 'already suppressed: %s\n' "$entry"
        return 0
    fi
    printf '%s\n' "$entry" >> "$suppress_file"
    local -a log_args=(monitor --event emit-suppress --extra "entry=$entry")
    [[ -n "$repo_arg" ]] && log_args+=(--extra "repo=$repo_arg")
    [[ -n "$reason"   ]] && log_args+=(--note "$reason")
    cmd_log_action "${log_args[@]}" 2>/dev/null || true
    printf 'suppressed: %s\n' "$entry"
}

# Quick status: is the watcher alive, who's the target, how old is the
# heartbeat. Prints to stdout in a human-friendly key=value block.
#
# Exit code buckets come from `_watcher_alive` in
# `monitor/watcher/_lib.sh` — the same helper bootstrap.sh uses, so
# `ng watcher-status` and bootstrap can't drift (issue #14):
#
#   0  fresh + pid alive (headless watcher: pid identity + heartbeat)
#   1  stale: heartbeat age within [2x+slack, 5x interval]
#   2  very stale, OR pid dead/recycled
#   3  no heartbeat file
cmd_watcher_status() {
    _help_check "$@"
    # `--scheduler` — append a per-task last-fire summary read from
    # monitor/.state/watcher-scheduler.jsonl. The cron-supervisor uses
    # this to verify task health: presence of compose_emit,
    # snapshot_local, deliveries_poll, github_poll, etc. as discrete
    # tasks. Missing JSONL ⇒ `scheduler: telemetry absent` (watcher
    # never started or the file was rotated/cleaned).
    local want_scheduler=0
    while (( $# > 0 )); do
        case "$1" in
            --scheduler) want_scheduler=1; shift ;;
            *) die "ng watcher-status: unknown flag: $1" ;;
        esac
    done
    local hb="$STATE_DIR/watcher-heartbeat"
    local lock="$STATE_DIR/watcher.lock"
    local target_file="$STATE_DIR/watcher-target"
    local interval
    interval=$("$_script_dir/../config/load.sh" monitor.interval_seconds 60)
    # shellcheck source=watcher/_lib.sh
    source "$_script_dir/watcher/_lib.sh"
    _watcher_alive "$STATE_DIR" "$interval"
    local status_code=$?
    if [[ ! -f "$hb" ]]; then
        echo "heartbeat: missing"
    else
        local age iso pid target
        age=$(_watcher_heartbeat_age "$hb")
        iso=$(date -Is -r "$hb" 2>/dev/null || echo unknown)
        pid=$(_watcher_heartbeat_field "$hb" pid)
        target=$(_watcher_heartbeat_field "$hb" target)
        echo "heartbeat: $iso (age=${age}s)"
        if [[ -n "$pid" ]]; then
            if kill -0 "$pid" 2>/dev/null; then
                echo "pid: $pid (alive)"
            else
                echo "pid: $pid (DEAD)"
            fi
        else
            echo "pid: unknown"
        fi
        echo "target: ${target:-$(cat "$target_file" 2>/dev/null || echo unknown)}"
    fi
    if [[ -f "$lock" ]]; then
        local lock_pid lock_started
        lock_pid=$(_watcher_lock_field "$lock" pid)
        lock_started=$(_watcher_lock_field "$lock" started_at)
        echo "lock: pid=${lock_pid:-?} started=${lock_started:-?}"
    else
        echo "lock: absent"
    fi
    # State-dir-scoped singleton (flock) — the cross-sandbox / cross-host
    # guard the pid lock above can't provide. Held = a cockpit owns this
    # NEXUS_ROOT (normally the running watcher); the assessment flags a
    # stale lock when its recorded host rebooted / differs. Full inspect:
    # `monitor/watcher/launcher.sh --instance-status`.
    local ilock="$STATE_DIR/nexus-instance.lock" iholder
    if iholder=$(_nexus_instance_lock_live "$ilock"); then
        echo "instance-lock: held (assessment=$(_nexus_instance_lock_assess "$iholder") host=$(_nexus_instance_lock_field "$iholder" host) pid=$(_nexus_instance_lock_field "$iholder" pid) started=$(_nexus_instance_lock_field "$iholder" started_at))"
    elif [[ -e "$ilock" ]]; then
        echo "instance-lock: free (stale metadata present; reclaimed on next start)"
    else
        echo "instance-lock: absent"
    fi
    # The watcher runs headless (no tmux window) since the
    # services-model migration. A window named 'watcher' is a legacy
    # leftover worth surfacing — the launcher sweeps it on next spawn.
    if command -v tmux >/dev/null 2>&1; then
        local wins
        wins=$(tmux list-windows -F '#{window_name}' 2>/dev/null | grep -cxF watcher || true)
        if [[ "$wins" == "1" ]]; then
            echo "hosting: legacy tmux window 'watcher' present (headless expected)"
        else
            echo "hosting: headless"
        fi
    fi
    # Archive count for a quick sanity check.
    local diff_dir="$STATE_DIR/diffs" count=0
    if [[ -d "$diff_dir" ]]; then
        count=$(find "$diff_dir" -maxdepth 1 -type f -name '*.md' 2>/dev/null | wc -l)
    fi
    echo "archived_diffs: $count"

    # Per-task scheduler summary (issue #172). Opt-in: cron-supervisor
    # and ad-hoc operator probes pass `--scheduler` to verify v2
    # migration completeness. Each line is one task with its most
    # recent `phase`, `rc`, `elapsed_ms`, and the ISO `ts` of that fire.
    if (( want_scheduler == 1 )); then
        local sched_log="$STATE_DIR/watcher-scheduler.jsonl"
        if [[ -f "$sched_log" ]]; then
            echo "scheduler: telemetry $sched_log"
            # awk keyed on `"task":"<name>"` — keeps the last occurrence
            # per task with its rc + elapsed + phase + ts. Stable order
            # by task name for diffability.
            awk '
                {
                    if (match($0, /"task":"[^"]+"/)) {
                        t = substr($0, RSTART+8, RLENGTH-9)
                    } else { t = "" }
                    if (match($0, /"rc":[0-9]+/))         rc = substr($0, RSTART+5, RLENGTH-5); else rc = ""
                    if (match($0, /"elapsed_ms":[0-9]+/)) ms = substr($0, RSTART+13, RLENGTH-13); else ms = ""
                    if (match($0, /"phase":"[^"]+"/))     ph = substr($0, RSTART+9, RLENGTH-10); else ph = ""
                    if (match($0, /"ts":"[^"]+"/))        ts = substr($0, RSTART+6, RLENGTH-7); else ts = ""
                    if (t != "") { rc_by[t]=rc; ms_by[t]=ms; ph_by[t]=ph; ts_by[t]=ts }
                }
                END {
                    n = 0
                    for (t in ts_by) { keys[n++] = t }
                    # bubble-sort small set (≤30)
                    for (i = 0; i < n; i++)
                        for (j = i+1; j < n; j++)
                            if (keys[j] < keys[i]) { tmp = keys[i]; keys[i] = keys[j]; keys[j] = tmp }
                    for (i = 0; i < n; i++) {
                        t = keys[i]
                        printf "  %-22s phase=%-11s rc=%-3s elapsed_ms=%-6s last_fire=%s\n", \
                            t, ph_by[t], rc_by[t], ms_by[t], ts_by[t]
                    }
                }
            ' "$sched_log"
        else
            echo "scheduler: telemetry absent"
        fi
    fi
    return "$status_code"
}

# Print an App-level JWT (no installation-token exchange). Thin shim
# over `mint-token.sh --jwt-only`. Used by callers that need to hit
# /app/* endpoints — most importantly /app/hook/deliveries, the App's
# own webhook delivery log (auth: JWT, not installation token).
cmd_mint_jwt() {
    _help_check "$@"
    (( $# == 0 )) || die "ng mint-jwt: takes no arguments"
    local jwt
    jwt=$("$_script_dir/mint-token.sh" --jwt-only) \
        || die "mint-token.sh --jwt-only failed; bot identity cannot be obtained. See stderr above."
    [[ -n "$jwt" ]] || die \
        "mint-token.sh --jwt-only returned empty; check config/nexus.yml github.bot_* keys and pem path."
    printf '%s\n' "$jwt"
}

# `ng respawn <window | session-id>` — the canonical "bring a
# wrapped/closed worker's session back" verb. Thin wrapper over
# `monitor/spawn-worker.sh --resume`: all the resolution (session-id
# from report frontmatter / window-close events / project-dir jsonl,
# workdir from pane / events / spawn-prompt cache) and all the spawn
# parity (NEXUS_ROOT + NEXUS_WORKER_WINDOW exports, worker-settings
# hooks, window options, lifecycle anchors) live there; this verb just
# routes so the operator surface matches the other window-lifecycle
# verbs (spawn-decision, wrap-up-check).
cmd_respawn() {
    _help_check "$@"
    local target="${1:-}"; shift || true
    [[ -n "$target" && "$target" != --* ]] \
        || die "usage: ng respawn <window | session-id> [--window N] [--workdir P] [--replace] [--dry-run]"
    local -a args=( --resume "$target" )
    while (( $# > 0 )); do
        case "$1" in
            --window)   [[ -n "${2:-}" ]] || die "respawn: --window needs a value";  args+=( -n "$2" ); shift 2 ;;
            --workdir)  [[ -n "${2:-}" ]] || die "respawn: --workdir needs a value"; args+=( -c "$2" ); shift 2 ;;
            --replace)  args+=( --replace ); shift ;;
            --dry-run)  args+=( --dry-run ); shift ;;
            --nudge)    args+=( --nudge ); shift ;;
            --no-nudge) args+=( --no-nudge ); shift ;;
            *) die "respawn: unknown flag: $1" ;;
        esac
    done
    exec "$_script_dir/spawn-worker.sh" "${args[@]}"
}

# `ng spawn-decision <window>` — advisory helper that classifies a
# retained worker window as continue-vs-spawn material per the policy
# in `skills/nexus.window-cleanup` (Continue-vs-spawn section).
# Issue #72 D5.
#
# Inputs:
#   <window>          — tmux window name to evaluate
#   --topic <slug>    — optional. The topic of the new task. When omitted,
#                        the helper assumes topic-match (caller already
#                        decided the routing applies to this window).
#
# Output (stdout, key=value, machine-parseable):
#   decision=<continue|spawn|ambiguous> reason=<short>
#   pane_state=<state> retain_age_s=<n|none> spawn_age_s=<n|none>
#
# Exit codes:
#   0  decision rendered (regardless of which class)
#   1  window unknown to tmux / classifier couldn't run
cmd_spawn_decision() {
    _help_check "$@"
    local window="${1:-}"
    [[ -n "$window" ]] || die "usage: ng spawn-decision <window> [--topic <slug>]"
    shift || true
    local topic=""
    while (( $# > 0 )); do
        case "$1" in
            --topic) topic="${2:-}"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    command -v tmux >/dev/null 2>&1 \
        || { echo "decision=ambiguous reason=no-tmux"; return 1; }
    local windows_csv
    windows_csv=$(tmux list-windows -F '#{window_name}' 2>/dev/null)
    if ! grep -qxF "$window" <<<"$windows_csv"; then
        echo "decision=spawn reason=window-absent pane_state=absent retain_age_s=none spawn_age_s=none"
        return 0
    fi
    # Pane state.
    local pane_state="unknown"
    if [[ -x "$_script_dir/pane-state.sh" ]]; then
        local line
        line=$("$_script_dir/pane-state.sh" --all 2>/dev/null \
                 | awk -v w="$window" -F'[ =]' '
                     {for(i=1;i<=NF;i+=2) kv[$i]=$(i+1)}
                     kv["name"]==w {print kv["state"]; exit}
                  ')
        [[ -n "$line" ]] && pane_state="$line"
    fi
    # Lifecycle anchors (issue #72): spawn ts + last retain ts.
    local log_file="$STATE_DIR/action-log.jsonl"
    local now spawn_age_s retain_age_s
    now=$(date +%s)
    spawn_age_s="none"
    retain_age_s="none"
    if [[ -f "$log_file" ]] && command -v jq >/dev/null 2>&1; then
        local spawn_ts retain_ts
        spawn_ts=$(grep '"event":"spawn"' "$log_file" 2>/dev/null \
                     | tac \
                     | jq -r --arg w "$window" 'select(.window==$w) | .ts' 2>/dev/null \
                     | head -1)
        retain_ts=$(grep '"event":"window-retain"' "$log_file" 2>/dev/null \
                     | tac \
                     | jq -r --arg w "$window" 'select(.window==$w) | .ts' 2>/dev/null \
                     | head -1)
        if [[ -n "$spawn_ts" ]]; then
            local spawn_epoch
            spawn_epoch=$(date -d "$spawn_ts" +%s 2>/dev/null || echo "")
            [[ "$spawn_epoch" =~ ^[0-9]+$ ]] && spawn_age_s=$(( now - spawn_epoch ))
        fi
        if [[ -n "$retain_ts" ]]; then
            local retain_epoch
            retain_epoch=$(date -d "$retain_ts" +%s 2>/dev/null || echo "")
            [[ "$retain_epoch" =~ ^[0-9]+$ ]] && retain_age_s=$(( now - retain_epoch ))
        fi
    fi
    # Decision policy mirrors skills/nexus.window-cleanup Continue-vs-spawn.
    local retain_ttl
    retain_ttl=$("$_script_dir/../config/load.sh" monitor.retain_ttl_seconds 86400 2>/dev/null || echo 86400)
    local decision="continue" reason="default-continue"
    case "$pane_state" in
        busy|user-typing)
            decision="ambiguous"
            reason="pane-mid-flight-queue-as-paste-buffer-followup" ;;
        blocked)
            decision="spawn"
            reason="pane-blocked-fresh-spawn-after-triage" ;;
        absent)
            decision="spawn"
            reason="pane-absent-fresh-spawn" ;;
        idle|autosuggest-only|empty)
            if [[ "$retain_age_s" == "none" ]]; then
                decision="spawn"
                reason="no-retain-on-record"
            elif (( retain_age_s > retain_ttl )); then
                decision="spawn"
                reason="retain-ttl-expired"
            else
                decision="continue"
                reason="retained-and-idle"
            fi ;;
        *)
            decision="ambiguous"
            reason="pane-state-unknown" ;;
    esac
    printf 'decision=%s reason=%s pane_state=%s retain_age_s=%s spawn_age_s=%s\n' \
        "$decision" "$reason" "$pane_state" "$retain_age_s" "$spawn_age_s"
    return 0
}

# `ng wrap-up-check <window>` — verify a worker has completed all
# wrap-up obligations before the orchestrator closes its window.
# Issue #72 D5. Independent of `ng wrap-up`'s pre-flight (which
# fires before the worker has uploaded anything); this verifies the
# post-conditions:
#
#   1. action-log carries a `wrap-up` event for the window (current
#      lifecycle — i.e. ts > most-recent spawn ts).
#   2. The cited report exists on disk and passes `ng report-check`.
#   3. A trigger-comment was rocketed, OR the worker explicitly
#      opted out via `--no-trigger` at wrap-up time (verifier passes
#      either way).
#
# Output (stdout):
#   status=<ok|incomplete> wrap_up=<present|missing>
#   report_check=<ok|fail|missing> rocket=<ok|skipped|missing>
#
# Exit codes:
#   0  status=ok — safe to close
#   1  status=incomplete — at least one obligation missing
cmd_wrap_up_check() {
    _help_check "$@"
    local window="${1:-}"
    [[ -n "$window" ]] || die "usage: ng wrap-up-check <window>"
    local log_file="$STATE_DIR/action-log.jsonl"
    local wrap_up_st="missing" report_check_st="missing" rocket_st="skipped"
    local entry_report=""
    if [[ -f "$log_file" ]] && command -v jq >/dev/null 2>&1; then
        # Most-recent spawn ts (lifecycle anchor; pre-spawn entries
        # don't count).
        local spawn_ts spawn_epoch=0
        spawn_ts=$(grep '"event":"spawn"' "$log_file" 2>/dev/null \
                     | tac \
                     | jq -r --arg w "$window" 'select(.window==$w) | .ts' 2>/dev/null \
                     | head -1)
        if [[ -n "$spawn_ts" ]]; then
            spawn_epoch=$(date -d "$spawn_ts" +%s 2>/dev/null || echo 0)
        fi
        # Walk wrap-up events newest-first; take the first whose ts >
        # spawn ts (or any when spawn anchor is missing).
        local entry_ts entry_epoch entry_window entry_rocket
        while IFS=$'\t' read -r entry_window entry_ts entry_report entry_rocket; do
            [[ -n "$entry_report" ]] || continue
            if [[ "$entry_window" != "$window" ]]; then continue; fi
            if (( spawn_epoch > 0 )) && [[ -n "$entry_ts" && "$entry_ts" != "_NULL_" ]]; then
                entry_epoch=$(date -d "$entry_ts" +%s 2>/dev/null || echo 0)
                if [[ "$entry_epoch" =~ ^[0-9]+$ ]] \
                   && (( entry_epoch < spawn_epoch )); then
                    continue
                fi
            fi
            wrap_up_st="present"
            # Rocket status field was added by `ng wrap-up` step 3
            # (ok | failed | skipped). Treat skipped/ok as
            # acceptable; failed flips to missing.
            case "$entry_rocket" in
                ok|skipped|"") rocket_st="ok" ;;
                failed)        rocket_st="missing" ;;
                *)             rocket_st="ok" ;;
            esac
            break
        done < <(grep '"event":"wrap-up"' "$log_file" \
                    | tac \
                    | jq -r '[(.window // ""), (.ts // "_NULL_"), (.report // ""), (.rocket // "")] | @tsv' 2>/dev/null)
    fi
    # Report-check (only when we found a basename to check).
    if [[ -n "$entry_report" ]]; then
        local report_path=""
        if [[ -n "${NEXUS_ROOT:-}" && -f "$NEXUS_ROOT/reports/$entry_report" ]]; then
            report_path="$NEXUS_ROOT/reports/$entry_report"
        elif [[ -f "reports/$entry_report" ]]; then
            report_path="reports/$entry_report"
        fi
        if [[ -n "$report_path" ]]; then
            if cmd_report_check "$report_path" >/dev/null 2>&1; then
                report_check_st="ok"
            else
                report_check_st="fail"
            fi
        else
            report_check_st="missing"
        fi
    fi
    local status="incomplete"
    if [[ "$wrap_up_st" == "present" \
          && "$report_check_st" == "ok" \
          && "$rocket_st" != "missing" ]]; then
        status="ok"
    fi
    printf 'status=%s wrap_up=%s report_check=%s rocket=%s\n' \
        "$status" "$wrap_up_st" "$report_check_st" "$rocket_st"
    [[ "$status" == "ok" ]]
}

# `ng interactive-sessions [--limit N] [--days D] [--upsert-overview] [--dry-run]`
#
# Enumerate recently paused/closed interactive windows from their
# provenance records (monitor/.state/windows/<window>.json, written by
# spawn-worker.sh --kind interactive) and render a markdown section that
# the operator (or a fresh orchestrator) can use to identify and resume
# paused sessions.
#
# The section is bounded by HTML-comment delimiters and idempotently
# upserted into the overview issue body on --upsert-overview, so
# repeated runs replace the block in-place (no drift, no duplication).
# The bot identity (REST PATCH) is used for the GitHub write.
#
# --limit N     include at most N sessions (default 20)
# --days D      only include sessions active within the last D days (default 30)
# --upsert-overview  PATCH the block into the overview issue body
# --dry-run     print the rendered block; skip the GitHub PATCH
#
# Exit codes:
#   0  success (rendered; patched if --upsert-overview and not --dry-run)
#   1  error (write failed)
cmd_interactive_sessions() {
    _help_check "$@"
    local limit=20 days=30 upsert=0 dry_run=0 repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --limit)           limit="${2:-}";    shift 2 ;;
            --days)            days="${2:-}";     shift 2 ;;
            --upsert-overview) upsert=1;          shift   ;;
            --dry-run)         dry_run=1;         shift   ;;
            --repo)            repo_arg="${2:-}"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    [[ "$limit" =~ ^[0-9]+$ && "$limit" -gt 0 ]] || die "interactive-sessions: --limit must be a positive integer"
    [[ "$days"  =~ ^[0-9]+$ && "$days"  -gt 0 ]] || die "interactive-sessions: --days must be a positive integer"

    # Resolve the nexus root: env override, then script-relative.
    local nexus_root="${NEXUS_ROOT:-}"
    [[ -n "$nexus_root" ]] || nexus_root=$(cd "$_script_dir/.." && pwd)
    local windows_dir="$nexus_root/monitor/.state/windows"
    local action_log="$STATE_DIR/action-log.jsonl"

    local cutoff_epoch
    cutoff_epoch=$(date -d "-${days} days" +%s 2>/dev/null || date -v -"${days}"d +%s 2>/dev/null || echo 0)

    # Collect interactive-kind provenance records.
    # Each record: window, session_id, kind, workdir, topic, spawned_at.
    # We also consult window-close action-log events to identify closed windows.
    local -a sessions=()
    local -a elided_names=()
    local total_found=0

    if [[ -d "$windows_dir" ]] && command -v jq >/dev/null 2>&1; then
        # Build a set of closed windows from the action log (newest close first).
        declare -A closed_at
        if [[ -f "$action_log" ]]; then
            while IFS=$'\t' read -r cwin cts; do
                [[ -n "$cwin" && -n "$cts" ]] || continue
                closed_at["$cwin"]="$cts"
            done < <(grep '"event":"window-close"' "$action_log" 2>/dev/null \
                | tac \
                | jq -r '[(.window // ""), (.ts // "")] | @tsv' 2>/dev/null \
                | awk -F'\t' '!seen[$1]++')
        fi

        # Walk provenance files, newest-spawned first (sort by spawned_at field).
        local f win topic session_id workdir spawned_at spawned_epoch kind status resume_cmd
        while IFS= read -r f; do
            [[ -f "$f" ]] || continue
            kind=$(jq -r '.kind // "task"' "$f" 2>/dev/null)
            [[ "$kind" == "interactive" ]] || continue
            win=$(jq -r '.window // ""' "$f" 2>/dev/null)
            [[ -n "$win" ]] || continue
            topic=$(jq -r '.topic // ""' "$f" 2>/dev/null)
            [[ -n "$topic" ]] || topic="$win"
            session_id=$(jq -r '.session_id // ""' "$f" 2>/dev/null)
            workdir=$(jq -r '.workdir // ""' "$f" 2>/dev/null)
            spawned_at=$(jq -r '.spawned_at // ""' "$f" 2>/dev/null)
            spawned_epoch=0
            if [[ -n "$spawned_at" ]]; then
                spawned_epoch=$(date -d "$spawned_at" +%s 2>/dev/null || echo 0)
            fi

            # Status: open (window still in tmux), closed, or unknown.
            if [[ -n "${closed_at[$win]:-}" ]]; then
                status="closed (${closed_at[$win]%%T*})"
            elif command -v tmux >/dev/null 2>&1 \
                 && tmux list-windows -F '#W' 2>/dev/null | grep -Fxq -- "$win"; then
                status="open"
            else
                status="paused"
            fi

            # Cutoff: skip sessions with no activity sign within --days.
            # Use heartbeat mtime or spawned_at as activity proxy.
            local hb_ref="$nexus_root/monitor/.state/heartbeat/$win.json"
            local activity_epoch="$spawned_epoch"
            if [[ -f "$hb_ref" ]]; then
                local hb_mtime
                hb_mtime=$(stat -c '%Y' "$hb_ref" 2>/dev/null || echo 0)
                [[ "$hb_mtime" =~ ^[0-9]+$ ]] && (( hb_mtime > activity_epoch )) && activity_epoch="$hb_mtime"
            fi
            (( activity_epoch >= cutoff_epoch )) || { elided_names+=("$win"); continue; }

            total_found=$(( total_found + 1 ))
            if (( total_found > limit )); then
                elided_names+=("$win")
                continue
            fi

            resume_cmd="monitor/spawn-worker.sh --resume $win"
            sessions+=("${win}|${topic}|${status}|${spawned_at%%T*}|${resume_cmd}")
        done < <(
            # Sort provenance files by spawned_at field descending (newest first).
            for f2 in "$windows_dir"/*.json; do
                [[ -f "$f2" ]] || continue
                local sa; sa=$(jq -r '.spawned_at // "0000"' "$f2" 2>/dev/null || echo "0000")
                printf '%s\t%s\n' "$sa" "$f2"
            done | sort -rk1,1 | awk -F'\t' '{print $2}'
        )
    fi

    # Render the markdown section.
    local elided_count=${#elided_names[@]}
    local elided_note=""
    if (( elided_count > 0 )); then
        elided_note="_Showing ${#sessions[@]} of $(( ${#sessions[@]} + elided_count )) interactive sessions (last ${days} days). ${elided_count} elided: $(printf '%s, ' "${elided_names[@]}" | sed 's/, $//')._"
    else
        elided_note="_Showing ${#sessions[@]} interactive sessions (last ${days} days)._"
    fi

    local block
    block=$(cat <<'MARKDOWN_EOF'
<!-- interactive-sessions:start -->
## Resumable Interactive Sessions

The orchestrator can resume any session below by running the listed command (or equivalently `monitor/ng respawn <window-name>`). Sessions are spawned with `--kind interactive` and are auto-retired after extended inactivity.

MARKDOWN_EOF
)
    if (( ${#sessions[@]} == 0 )); then
        block+=$'\n| Window | Topic | Status | Spawned | Resume Command |\n'
        block+=$'|--------|-------|--------|---------|----------------|\n'
        block+=$'| — | no interactive sessions recorded | — | — | — |\n'
    else
        block+=$'\n| Window | Topic | Status | Spawned | Resume Command |\n'
        block+=$'|--------|-------|--------|---------|----------------|\n'
        local entry
        for entry in "${sessions[@]}"; do
            IFS='|' read -r e_win e_topic e_status e_date e_cmd <<<"$entry"
            block+="| \`${e_win}\` | ${e_topic} | ${e_status} | ${e_date} | \`${e_cmd}\` |"$'\n'
        done
    fi
    block+=$'\n'"${elided_note}"$'\n'
    block+=$'<!-- interactive-sessions:end -->'

    printf '%s\n' "$block"

    # Upsert into overview issue body when --upsert-overview.
    if (( upsert == 1 )) && (( dry_run == 0 )); then
        local target; target=$(_resolve_repo write "$repo_arg") || exit $?
        local overview_number
        overview_number=$("$_cfg" github.overview_issue 1 2>/dev/null || echo 1)
        [[ "$overview_number" =~ ^[0-9]+$ ]] || overview_number=1

        # Fetch current body.
        local current_body
        current_body=$(api "/repos/$target/issues/$overview_number" 2>/dev/null \
            | jq -r '.body // ""') \
            || die "interactive-sessions: failed to fetch overview issue body"

        # Idempotent upsert: replace existing delimited block, or append.
        local start_marker='<!-- interactive-sessions:start -->'
        local end_marker='<!-- interactive-sessions:end -->'
        local new_body
        if printf '%s' "$current_body" | grep -qF "$start_marker"; then
            # Replace the existing block.
            new_body=$(printf '%s' "$current_body" \
                | awk -v block="$block" \
                    'BEGIN { in_block=0 }
                     /<!--[[:space:]]*interactive-sessions:start[[:space:]]*-->/ { in_block=1; print block; next }
                     in_block && /<!--[[:space:]]*interactive-sessions:end[[:space:]]*-->/ { in_block=0; next }
                     in_block { next }
                     { print }')
        else
            # Append the block.
            new_body="${current_body}"$'\n\n'"${block}"
        fi

        jq -n --arg body "$new_body" '{body: $body}' \
            | api -X PATCH "/repos/$target/issues/$overview_number" --input - >/dev/null \
            || die "interactive-sessions: PATCH overview issue failed"
        printf 'upserted interactive-sessions block into %s #%s\n' "$target" "$overview_number" >&2
    elif (( dry_run == 1 )); then
        printf '(dry-run: block above NOT patched into overview issue)\n' >&2
    fi
}

# ---- service-incident generator (service-health-watch) ----
#
# Assemble a structured incident report for a registered service FROM
# THE RECORDED STATE — the per-service incident files the watcher's
# service_health task writes under monitor/.state/service-health/
# (<name>.state current-incident record + <name>.events append-only
# history) plus the service logfile. Machine facts (down→restored
# timestamps, the failing healthcheck, every restart attempt + outcome)
# are filled FROM the state so the human-written prose can't drift from
# what actually happened. The root-cause / how-to-undo sections are
# templated placeholders the dispatched fix-worker fills in.
#
# Emits markdown to stdout (the operator pipes it to `ng issue create
# --body-file -` or saves it). The required sections — Failure report /
# Immediate response / Root-cause fix (with how-to-undo) / References /
# Worker report — match skills/nexus.service-recovery and the operator's
# spec verbatim.
_sh_incident_field() {
    # awk key=value reader over a state file (mirrors _version_field).
    local file="$1" key="$2"
    [[ -f "$file" ]] || return 1
    awk -F= -v k="$key" '$1==k { sub(/^[^=]*=/, ""); print; exit }' "$file"
}

cmd_service_incident() {
    _help_check "$@"
    local svc="${1:-}"
    [[ -n "$svc" ]] || die "usage: ng service-incident <svc> [--state-dir <path>]"
    shift
    local state_dir_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --state-dir) state_dir_arg="${2:-}"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    local sh_dir="${state_dir_arg:-$STATE_DIR/service-health}"
    local sf="$sh_dir/${svc}.state"
    local ef="$sh_dir/${svc}.events"
    if [[ ! -f "$sf" && ! -f "$ef" ]]; then
        die "service-incident: no recorded state for '$svc' under $sh_dir (no ${svc}.state or ${svc}.events). Is the name a registry service that has had an incident?"
    fi

    local status policy first_iso recovered_iso recovered_via attempts health logfile workdir note last_check_iso grace_seconds
    status=$(_sh_incident_field "$sf" status 2>/dev/null || echo unknown)
    policy=$(_sh_incident_field "$sf" policy 2>/dev/null || echo "auto-restart")
    first_iso=$(_sh_incident_field "$sf" first_unhealthy_iso 2>/dev/null || echo unknown)
    recovered_iso=$(_sh_incident_field "$sf" recovered_at_iso 2>/dev/null || echo "—")
    recovered_via=$(_sh_incident_field "$sf" recovered_via 2>/dev/null || echo "")
    attempts=$(_sh_incident_field "$sf" restart_attempts 2>/dev/null || echo 0)
    health=$(_sh_incident_field "$sf" health_cmd 2>/dev/null || echo unknown)
    logfile=$(_sh_incident_field "$sf" logfile 2>/dev/null || echo "")
    workdir=$(_sh_incident_field "$sf" workdir 2>/dev/null || echo "")
    note=$(_sh_incident_field "$sf" note 2>/dev/null || echo "")
    last_check_iso=$(_sh_incident_field "$sf" last_check_iso 2>/dev/null || echo "")
    grace_seconds=$(_sh_incident_field "$sf" grace_seconds 2>/dev/null || echo "")

    # Human-readable current-state line + restart outcome derived from the
    # machine record — never invented.
    local restart_outcome
    case "$status" in
        recovered)
            if [[ "$recovered_via" == self-healed* ]]; then
                restart_outcome="RECOVERED — ${recovered_via}; restored ~${recovered_iso} (watcher did not restart)."
            else
                restart_outcome="RECOVERED — auto-restart held after ${attempts} attempt(s); restored ~${recovered_iso}."
            fi ;;
        flapping)  restart_outcome="NOT RECOVERED (flapping) — ${attempts} auto-restart attempt(s) did not hold; escalated to the orchestrator." ;;
        recovering) restart_outcome="IN PROGRESS — ${attempts} auto-restart attempt(s) issued; awaiting verification at last check ${last_check_iso}." ;;
        emit-only) restart_outcome="NOT RECOVERED (emit-only policy) — watcher did NOT auto-restart by policy; escalated to the orchestrator for a decision." ;;
        grace)     restart_outcome="IN GRACE — unhealthy, within the ${grace_seconds:-?}s self-heal grace window; watcher has NOT acted yet (deferring to the supervisor)." ;;
        down)      restart_outcome="DOWN — auto-restart underway (${attempts} attempt(s))." ;;
        *)         restart_outcome="status='${status}', ${attempts} restart attempt(s)." ;;
    esac

    local workdir_note=""
    [[ -n "$workdir" ]] && workdir_note=" (workdir \`$workdir\`)"

    # Plain-language status + the single clearest next action, keyed off the
    # same machine status. An operator who only knows biology + basic compute
    # reads THIS, not the restart-attempt internals above.
    local plain_status plain_action
    case "$status" in
        recovered)
            plain_status="already came back on its own"
            plain_action="**Nothing is required of you** — it recovered automatically. This issue is just a record; you can close it once you've read it." ;;
        recovering)
            plain_status="is restarting automatically right now"
            plain_action="**Give it a minute,** then check whether it's working again. If it does not come back, restart the workspace using the steps below." ;;
        grace)
            plain_status="had a brief hiccup and is being given a moment to recover on its own"
            plain_action="**Usually nothing** — wait a moment and it should recover. If it does not, restart the workspace using the steps below." ;;
        down)
            plain_status="went down and an automatic restart is already underway"
            plain_action="**Give it a minute.** If it does not come back, restart the workspace using the steps below." ;;
        flapping)
            plain_status="is **still down** — the automatic restarts did not hold"
            plain_action="**Restart the workspace** using the steps below." ;;
        emit-only)
            plain_status="is **down**, and it is deliberately set to NOT restart itself (a human decides)"
            plain_action="**Restart the workspace** using the steps below (the workspace's automated agent may also handle it for you)." ;;
        *)
            plain_status="changed state (\`$status\`)"
            plain_action="If \`$svc\` is not working, restart the workspace using the steps below." ;;
    esac

    # The recovery runbook needs the nexus root for the copy-paste restart
    # command (same derivation as cmd_nexus_identity / cmd_report_init).
    local nexus_root="${NEXUS_ROOT:-}"
    [[ -n "$nexus_root" ]] || nexus_root=$(cd "$_script_dir/.." && pwd)

    printf '# Service incident: `%s`\n\n' "$svc"

    # ---- Operator-friendly opening (issue: many operators are biologists
    # with only basic compute knowledge) -------------------------------------
    # Lead with a plain-language TL;DR + a copy-pasteable recovery runbook
    # BEFORE any machine facts. The detach / `watcher --continue` procedure
    # mirrors the EROFS-incident body in monitor/watcher/_lib.sh
    # (_nexus_incident_issue_body) verbatim, so the operator meets the SAME
    # recovery steps everywhere a workspace restart is the fix.
    printf '> **In plain terms (no compute expertise needed):** a background service in your workspace — **`%s`**%s — %s.\n' "$svc" "$workdir_note" "$plain_status"
    printf '>\n'
    printf '> **What this means for you:** _(see **User-facing impact** below — typically a website, app, or tool that was unreachable during the outage window.)_\n'
    printf '>\n'
    printf '> **What you should do:** %s\n\n' "$plain_action"

    printf '### If `%s` is still down: restart the workspace\n\n' "$svc"
    printf 'Most outages fix themselves (the monitor auto-restarts services) or are handled for you by the workspace agent. Do the following **only if `%s` is still not working.**\n\n' "$svc"
    printf '**If you are in the agent sandbox** (the simplest, surest fix — it cleanly restarts the whole workspace):\n\n'
    printf '1. **Find the workspace terminal.** Look at the bottom status bar. If it reads **`[sandbox]`**, you are in the right (inner) window.\n'
    printf '2. **Close that inner sandbox window:** press and hold **`Ctrl`**, tap **`a`**, let go — then tap **`d`**.\n'
    printf '   - That detaches and closes the inner (nested) sandbox tmux.\n'
    printf '   - ⚠️ Do **NOT** use **`Ctrl`+`b`** then **`d`** — that is the *outer/meta* terminal and will not fix anything.\n'
    printf '3. **Restart the workspace.** You are now back at the outer shell. Paste this one line and press **Enter**:\n'
    printf '   ```\n'
    printf '   cd %s && agent-sandbox tmux new-session ./watcher --continue\n' "$nexus_root"
    printf '   ```\n'
    printf '   (`--continue` resumes your previous session where it left off.)\n\n'
    printf 'That brings the whole workspace — including `%s` — back up on its own within about a minute.\n\n' "$svc"
    printf '**If you are NOT in the agent sandbox,** restart just this one service from the nexus root instead:\n\n'
    printf '```\nmonitor/svc.sh restart %s\n```\n\n' "$svc"

    printf -- '---\n\n'
    printf '_Auto-generated by `monitor/ng service-incident %s` from the watcher incident record (%s). The machine facts below are verbatim; fill the **Root-cause fix** + placeholders before filing._\n\n' "$svc" "$sf"

    printf '## Failure report\n\n'
    printf -- '- **Service:** `%s`%s\n' "$svc" "$workdir_note"
    printf -- '- **First unhealthy:** %s\n' "$first_iso"
    printf -- '- **Restored:** %s\n' "$recovered_iso"
    printf -- '- **Failing healthcheck:** `%s`\n' "$health"
    printf -- '- **Current status:** %s\n' "$status"
    printf -- '- **Restart policy:** `%s` %s\n' "$policy" \
        "$([[ "$policy" == "emit-only" ]] && echo '(watcher never auto-restarts this service — emit + orchestrator judgment)' || echo '(grace → minimal-downtime auto-restart → emit)')"
    printf -- '- **User-facing impact:** _(fill in: downtime window, endpoints affected — derive the window from First-unhealthy → Restored above)_\n'
    [[ -n "$note" ]] && printf -- '- **Watcher note:** %s\n' "$note"
    printf '\n'

    printf '## Immediate response\n\n'
    printf -- '- **Auto-restart (watcher):** %s\n' "$restart_outcome"
    if [[ "$policy" == "emit-only" ]]; then
        printf -- '- This service is `emit-only`: the watcher deliberately does NOT auto-restart it. After the self-heal grace window the watcher escalated to the orchestrator instead of restarting.\n'
    else
        printf -- '- The watcher first gives the service a self-heal grace window (its `*-supervised.sh` wrapper), then — only if still unhealthy — restarts via `monitor/svc.sh restart %s` (minimal downtime; stops a wedged supervisor process group, then relaunches via `recover_service`).\n' "$svc"
    fi
    printf -- '- **Manual restart (if any):** _(fill in: did the orchestrator run `monitor/svc.sh restart %s` itself? outcome?)_\n\n' "$svc"

    printf '## Root-cause fix\n\n'
    printf '_(fill in — the dispatched fix-worker completes this. Reversible + non-degrading; do NOT falsify the service to pass the healthcheck.)_\n\n'
    printf -- '- **What was changed:** _(file/commit)_\n'
    printf -- '- **Where:** _(path · commit SHA)_\n'
    printf -- '- **How to undo:** _(explicit revert — e.g. `git revert <sha>` — stated plainly so any operator can reverse it)_\n'
    printf -- '- **Why it will not reoccur:** _(fill in)_\n\n'

    printf '## References\n\n'
    printf -- '- **Incident state file:** `%s`\n' "$sf"
    printf -- '- **Incident event history:** `%s`\n' "$ef"
    [[ -n "$logfile" ]] && printf -- '- **Service logfile:** `%s`\n' "$logfile"
    printf -- '- **Related issues / PRs / commits:** _(fill in)_\n\n'

    # Embed the machine-recorded event timeline verbatim — the spine of
    # the report, immune to prose drift.
    if [[ -f "$ef" ]]; then
        printf '### Recorded event timeline (verbatim)\n\n```\n'
        awk -F'\t' '{ printf "%s  %-22s %s\n", $1, $2, $3 }' "$ef"
        printf '```\n\n'
    fi
    if [[ -n "$logfile" && -f "$logfile" ]]; then
        printf '### Logfile tail (last 40 lines)\n\n```\n'
        tail -n 40 "$logfile" 2>/dev/null
        printf '```\n\n'
    fi

    printf '## Worker report\n\n'
    printf '_(link the dispatched fix-worker'\''s `reports/` file here once it wraps up.)_\n'
}

# `ng nexus-identity [--upsert-overview] [--dry-run] [--repo OWNER/NAME]`
#
# Render a compact, stable **Nexus identity** block — the working
# directory front and centre — and idempotently upsert it into the
# overview issue body between HTML-comment delimiters (same pattern as
# `ng interactive-sessions`). The point is auto-generation: every field
# is DERIVED from the environment/config this nexus already has, so a
# second operator running the same code gets their own correct block
# with zero edits, and repeated runs replace the block in place (no
# drift, no duplication).
#
# Derived fields (nothing hardcodes `operator`):
#   - Working directory   $NEXUS_ROOT (env), else script-relative root.
#   - Host                `hostname` of the cockpit/watcher host.
#   - Asset + issue repo  github.repo ($REPO) + overview issue number.
#   - Implementation clone the nexus root's git origin remote + branch.
#   - Watcher pidfile/log <root>/monitor/.state/watcher.{pid,log}.
#
# --upsert-overview  PATCH the block into the overview issue body.
# --dry-run          print the rendered block; skip the GitHub PATCH.
# --repo OWNER/NAME  override the target repo for the upsert.
#
# Exit codes: 0 success; 1 error (write failed).
cmd_nexus_identity() {
    _help_check "$@"
    local upsert=0 dry_run=0 repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --upsert-overview) upsert=1;          shift   ;;
            --dry-run)         dry_run=1;         shift   ;;
            --repo)            repo_arg="${2:-}"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    # Resolve the nexus root: env override, then script-relative.
    local nexus_root="${NEXUS_ROOT:-}"
    [[ -n "$nexus_root" ]] || nexus_root=$(cd "$_script_dir/.." && pwd)

    local host; host=$(hostname 2>/dev/null || echo "(unknown host)")

    # Implementation-clone provenance: the nexus root IS the canonical
    # nexus-code checkout. Read its origin remote + current branch; fall
    # back gracefully when the root isn't a git checkout (e.g. tests).
    local clone_remote clone_branch
    clone_remote=$(git -C "$nexus_root" remote get-url origin 2>/dev/null || echo "(no git origin)")
    clone_branch=$(git -C "$nexus_root" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "(detached)")

    local overview_num; overview_num=$(_overview_number_cheap)
    local watcher_pid="$nexus_root/monitor/.state/watcher.pid"
    local watcher_log="$nexus_root/monitor/.state/watcher.log"

    # Render the block. Working directory is the prominent headline; the
    # rest is a compact key/value table. Identity, not status.
    local block
    block="${IDENTITY_START}"$'\n'
    block+=$'## Nexus Identity\n\n'
    block+="**Working directory:** \`${nexus_root}\`"$'\n\n'
    block+=$'| Field | Value |\n'
    block+=$'|-------|-------|\n'
    block+="| Host | \`${host}\` |"$'\n'
    block+="| Asset + issue repo | \`${REPO}\` (overview: \`#${overview_num}\`) |"$'\n'
    block+="| Implementation clone | \`${clone_remote}\` · branch \`${clone_branch}\` |"$'\n'
    block+="| Watcher pidfile | \`${watcher_pid}\` |"$'\n'
    block+="| Watcher log | \`${watcher_log}\` |"$'\n'
    block+=$'\n'
    block+="_Orient / resume: cockpit \`monitor/svc.sh\` (in the \`services\` window) · live dashboard is the section below in this issue · reports under \`${nexus_root}/reports/\`. This block is auto-generated by \`ng nexus-identity\` — do not edit by hand._"$'\n'
    block+="${IDENTITY_END}"

    printf '%s\n' "$block"

    # Upsert into the overview issue body when --upsert-overview.
    if (( upsert == 1 )) && (( dry_run == 0 )); then
        local target; target=$(_resolve_repo write "$repo_arg") || exit $?
        local overview_number; overview_number=$(_overview_number)

        local current_body
        current_body=$(api "/repos/$target/issues/$overview_number" 2>/dev/null \
            | jq -r '.body // ""') \
            || die "nexus-identity: failed to fetch overview issue body"

        # Idempotent upsert: replace the existing delimited block, or append.
        local new_body
        if printf '%s' "$current_body" | grep -qF "$IDENTITY_START"; then
            new_body=$(printf '%s' "$current_body" \
                | awk -v block="$block" \
                    'BEGIN { in_block=0 }
                     /<!--[[:space:]]*nexus-identity:start[[:space:]]*-->/ { in_block=1; print block; next }
                     in_block && /<!--[[:space:]]*nexus-identity:end[[:space:]]*-->/ { in_block=0; next }
                     in_block { next }
                     { print }')
        else
            new_body="${current_body}"$'\n\n'"${block}"
        fi

        jq -n --arg body "$new_body" '{body: $body}' \
            | api -X PATCH "/repos/$target/issues/$overview_number" --input - >/dev/null \
            || die "nexus-identity: PATCH overview issue failed"
        printf 'upserted nexus-identity block into %s #%s\n' "$target" "$overview_number" >&2
    elif (( dry_run == 1 )); then
        printf '(dry-run: block above NOT patched into overview issue)\n' >&2
    fi
}

# ---- dispatch ----

# `ng skeptic <subcommand> ...` — thin delegator to
# monitor/skeptic-channel.sh (the worker↔skeptic comms channel + nudge).
# Gives the skeptic protocol a discoverable home on the `ng` surface:
#   ng skeptic ask          <task> <slug> ...  (skeptic writes a request)
#   ng skeptic await        <task>             (WORKER blocks for *.open.md,
#                                               acks → .ack.md, exits 0;
#                                               DONE → exit 10; timeout → 4)
#   ng skeptic answer       <task> <req> ...   (worker replies, → .answered.md)
#   ng skeptic await-answer <task> <req> ...   (skeptic blocks for the answer)
#   ng skeptic reconcile    <task> ...         (skeptic ensures all acked)
#   ng skeptic close        <task>             (skeptic drops DONE sentinel)
#   ng skeptic nudge        <window> ...       (wake an idle worker)
#   ng skeptic poll|status|list|init|dir <task>
# Run `ng skeptic --help` for the full surface + exit-code contract.
cmd_skeptic() {
    local chan="$_script_dir/skeptic-channel.sh"
    [[ -x "$chan" ]] || die "skeptic: $chan not found or not executable"
    "$chan" "$@"
}

# `ng request <subcommand> ...` — thin delegator to
# monitor/request-channel.sh (the watcher-mediated request inbox + the
# bidirectional request/reply protocol; agent-channel RFC Part B/D). The
# worker→orchestrator escalation channel, symmetric with `ng skeptic`:
#   PRODUCER/CLIENT:
#     ng request file  --origin <w> --kind <k> [--reply required] --slug <s> …
#                                              (writes .new.md; PRINTS the stable id)
#     ng request await <id> [--timeout S]      (block until .replied/.done; print reply)
#     ng request fetch <id> progress|results   (no-publish branch; path-confined pull)
#     ng request list [--state …] | show <id> | reqfile <id> | dir
#   ORCHESTRATOR:
#     ng request ack   <id>                    (.claimed → .done; bare ack —
#                                               refused on a reply:required id, use reply)
#     ng request reply <id> [--worker w] [--dir p] [--issue o/r#N] …  (.claimed → .replied)
#     ng request fail  <id> --reason "<why>"
# Run `ng request --help` for the full surface + exit-code contract.
cmd_request() {
    local chan="$_script_dir/request-channel.sh"
    [[ -x "$chan" ]] || die "request: $chan not found or not executable"
    "$chan" "$@"
}

# `ng remote <subcommand> …` — out-of-band secret provisioning for the
# confined remote SSH endpoint (agent-channel RFC Part A §4.9): host-key
# generation, one-time enrollment tokens, key enrollment, revoke, list, and
# the pre-write secret grep guard. NO subcommand here EVER touches GitHub;
# secrets travel out-of-band only (stdout / 0600 op-only file).
#     ng remote gen-host-key                       (print host fingerprint)
#     ng remote issue-token --principal P [--ttl S](mint a one-time token)
#     ng remote enroll --pubkey F --token T        (consume token → authorize a key)
#     ng remote enroll-invite --principal P [--ttl S]  (ROOTLESS self-enroll:
#                                                   mint token + per-window enroll
#                                                   key; client pipes <token>\n<pub>)
#     ng remote prune-enroll                       (drop expired/consumed enroll lines)
#     ng remote revoke --principal P               (remove a client's key)
#     ng remote list                               (enrolled principals)
#     ng remote carrier-authline --pubkey F|- [--port P]  (off-host forward-only carrier line)
#     ng remote guard [FILE]                       (pre-write secret scan; exit 3 if matched)
# Run `ng remote --help` for the full surface.
cmd_remote() {
    local chan="$_script_dir/remote-enroll.sh"
    [[ -x "$chan" ]] || die "remote: $chan not found or not executable"
    "$chan" "$@"
}

# ---- pure pass-through facades ----
#
# Each verb below is a thin discoverability front door over a standalone
# monitor/*.sh script — the exact `ng skeptic` shape. `_facade` `exec`s the
# script so stdout, stderr, and the exit code pass through UNCHANGED; the
# gate/logic and its dedicated test-*.sh unit stay single-source in the
# script (facade-over-scripts, not migrate — see docs/ng-interface-proposal.md).
#
# Deliberately NO `_help_check` here: `ng <verb> --help` must forward to the
# underlying script's own usage, not ng's. Adding logic to these is a smell —
# fix the script instead.
_facade() {
    local script="$1"; shift
    local path="$_script_dir/$script"
    [[ -x "$path" ]] || die "${script%.sh}: $path not found or not executable"
    exec "$path" "$@"
}
# orchestrator: synchronous go/no-go gate before tmux kill-window
cmd_retire_preflight() { _facade retire-preflight.sh "$@"; }
# orchestrator: classify a worker pane (idle|busy|user-typing|…)
cmd_pane_state()       { _facade pane-state.sh       "$@"; }
# worker: pre-flight that a deliverable path is writable before compute
cmd_write_probe()      { _facade write-probe.sh      "$@"; }
# maintenance: roll pre-buffer reports into monthly reports/YYYY-MM/ dirs
cmd_reports_roll()     { _facade reports-roll.sh     "$@"; }
# worker: self-declare an async external wait (slurm/CI/long curl)
cmd_declare_wait()     { _facade declare-wait.sh     "$@"; }
# worker: mark an async launch deliberately fire-and-forget
cmd_declare_no_wait()  { _facade declare-no-wait.sh  "$@"; }
# orchestrator: canonical follow-up paste into a worker window
cmd_paste_followup()   { _facade paste-followup.sh   "$@"; }
# any worker: literature discovery (S2 + ASTA), library add, setup status
cmd_lit()              { _facade lit.sh              "$@"; }
# both: print a GitHub App installation token (the $(…) idiom; symmetry
# with `ng mint-jwt`, which is mint-token.sh --jwt-only)
cmd_token()            { _facade mint-token.sh       "$@"; }
# worker: print the user PAT for private-repo reads
cmd_user_pat()         { _facade user-pat.sh         "$@"; }

# Categorized index of every dispatchable verb. This is the single
# "what can ng do" surface — the cure for the `unknown subcommand`
# papercut where there was no place listing the full set. Printed by
# `ng --help`, `ng -h`, `ng help`, and `ng verbs`. Run `ng <verb> --help`
# for per-verb usage.
_verb_index() {
    cat <<'EOF'

ng verbs — complete index (run `ng <verb> --help` for usage)

GitHub writes & reads:
  process <comment-id>           eyes + fetch comment body
  process-issue <n>              eyes + fetch issue body
  react <comment-id> <emoji>     react to a comment
  react-issue <n> <emoji>        react to an issue
  reply <issue>                  post a comment (body from stdin/--body-file)
  comment <issue>                alias of reply
  comment-edit <comment-id>      CAS edit of an existing comment (exit 4 on
                                 concurrent change; snapshot via show --meta)
  close <issue>                  comment + close
  show <comment-id>              print a comment body (read-only; --meta adds
                                 the updated_at CAS snapshot)
  suppress-emit <comment-id>     mute a watcher emit for a comment
  upload <path>                  push file to asset repo, print pinned URL
  preflight <owner/repo>         is the bot installed on this repo?
  issue <n>|create|comment|close|view   issue read/write sub-verbs
  pr create|edit|merge|view             pull-request sub-verbs
  dashboard get|put|scaffold|validate   overview dashboard ops
  nexus-identity                 render/upsert the overview identity block

Task lifecycle & reports:
  wrap-up <issue> <report>       one-shot end-of-task hand-off
  wrap-up-check <window>         verify a window wrapped up cleanly
  report-init <slug>             write a frontmatter'd report skeleton
  report-check <path>            validate a report's required sections
  reports-roll [--dry-run]       archive pre-buffer reports into reports/YYYY-MM/
  log-action <agent> --event …   append an action-log event
  fetch-asset <url>              fetch a user-attachments asset locally

Window & worker ops:
  respawn <window|session-id>    respawn a worker window
  spawn-decision <window>        spawn/skeptic decision read
  engaged-done                   mark an engaged worker done
  pane-state <window-index>      classify a worker pane
  paste-followup <window>        canonical follow-up paste into a window
  retire-preflight <window>      synchronous go/no-go gate before kill
  skeptic <sub> …                worker↔skeptic comms channel + nudge
  request <sub> …                worker→orchestrator request inbox (file/await/fetch/ack/reply)
  remote <sub> …                 confined remote SSH endpoint secrets (gen-host-key/issue-token/enroll/enroll-invite/prune-enroll/revoke/list/carrier-authline/guard)

State queries & infra:
  watcher-status                 watcher liveness / scheduler state
  service-incident <svc>         open an operator incident issue
  interactive-sessions           interactive-session digest
  mint-jwt                       print a bot JWT (mint-token.sh --jwt-only)
  token                          print a bot installation token
  user-pat                       print the user PAT for private reads
  write-probe <path>             pre-flight a deliverable path is writable
  declare-wait <kind> <id> <desc>   self-declare an async external wait
  declare-no-wait <kind> <id>    mark an async launch fire-and-forget

Literature research:
  lit search "<q>" [--source s2|asta|both] [--limit N]  content-relevance discovery
  lit add <DOI|S2-id>            fetch metadata + add to the reference library
  lit status                     keys / library / setup readiness
  lit setup                      key-acquisition + setup references
EOF
}

# Print the leading comment block (line 2 → first blank line). Replaces
# the previous hardcoded `sed -n '2,Np'` whose N drifted out of sync
# every time the header was edited.
_print_help() { awk '/^$/{exit} NR>1' "$0"; }

main() {
    local sub="${1:-}"; shift || true
    case "$sub" in
        process)        cmd_process       "$@" ;;
        process-issue)  cmd_process_issue "$@" ;;
        react)          cmd_react         "$@" ;;
        react-issue)    cmd_react_issue   "$@" ;;
        reply)          cmd_reply         "$@" ;;
        comment)        cmd_comment       "$@" ;;
        comment-edit)   cmd_comment_edit  "$@" ;;
        close)          cmd_close         "$@" ;;
        issue)          cmd_issue         "$@" ;;
        pr)             cmd_pr            "$@" ;;
        preflight)      cmd_preflight     "$@" ;;
        show)           cmd_show          "$@" ;;
        upload)         cmd_upload        "$@" ;;
        wrap-up)        cmd_wrap_up       "$@" ;;
        report-init)    cmd_report_init   "$@" ;;
        report-check)   cmd_report_check  "$@" ;;
        reports-roll)   cmd_reports_roll  "$@" ;;
        fetch-asset)    cmd_fetch_asset   "$@" ;;
        dashboard)      cmd_dashboard     "$@" ;;
        watcher-status) cmd_watcher_status "$@" ;;
        log-action)     cmd_log_action     "$@" ;;
        service-incident) cmd_service_incident "$@" ;;
        suppress-emit)  cmd_suppress_emit  "$@" ;;
        mint-jwt)       cmd_mint_jwt       "$@" ;;
        respawn)        cmd_respawn        "$@" ;;
        spawn-decision) cmd_spawn_decision "$@" ;;
        wrap-up-check)         cmd_wrap_up_check         "$@" ;;
        engaged-done)          cmd_engaged_done          "$@" ;;
        interactive-sessions)  cmd_interactive_sessions  "$@" ;;
        nexus-identity)        cmd_nexus_identity        "$@" ;;
        skeptic)               cmd_skeptic               "$@" ;;
        request)               cmd_request               "$@" ;;
        remote)                cmd_remote                "$@" ;;
        retire-preflight)      cmd_retire_preflight      "$@" ;;
        pane-state)            cmd_pane_state            "$@" ;;
        write-probe)           cmd_write_probe           "$@" ;;
        declare-wait)          cmd_declare_wait          "$@" ;;
        declare-no-wait)       cmd_declare_no_wait       "$@" ;;
        paste-followup)        cmd_paste_followup        "$@" ;;
        token)                 cmd_token                 "$@" ;;
        user-pat)              cmd_user_pat              "$@" ;;
        lit)                   cmd_lit                   "$@" ;;
        help|verbs) _print_help; _verb_index; exit 0 ;;
        -h|--help) _print_help; _verb_index; exit 0 ;;
        "")        _print_help >&2;   exit 1 ;;
        *)         die "unknown subcommand: $sub (see ng --help)" ;;
    esac
}

# Run main only when executed directly. Sourcing (e.g. from the unit
# suite, to exercise internal helpers like _wrapup_skeptic_step against
# temp state) defines the functions without dispatching.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
