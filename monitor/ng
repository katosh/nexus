#!/usr/bin/env bash
# Nexus monitor GitHub helper. Wraps the common monitor ops in tight
# subcommands so the agent doesn't shell out to gh + jq for every step.
#
# Usage examples:
#   ng process 4272693242                  # eyes + fetch body in one shot (comment)
#   ng react   4272693242 rocket           # react + confirmation print (comment)
#   ng process-issue 55                    # eyes + fetch body in one shot (issue itself)
#   ng react-issue   55 rocket             # react on the issue itself
#   ng react   4272693242 eyes --repo OWNER/NAME    # cross-repo react (process/react/react-issue/process-issue all take --repo)
#   ng show    4272693242                  # print comment body (read-only)
#   ng show    4272693242 --meta           # + id/updated_at header (CAS snapshot
#                                          #   for comment-edit --expect-updated-at)
#   echo "done" | ng reply 7               # post a reply (body from stdin)
#   ng comment-edit 4272693242 --body-file new.md --expect-updated-at <ts>
#                # compare-and-swap edit of an existing comment: refuses
#                # (exit 4) when the comment changed since your `ng show
#                # --meta` read, instead of silently clobbering the
#                # concurrent edit (#524). --force = deliberate
#                # last-writer-wins (loud stderr warning). Prefer
#                # `ng reply` (append) on contended threads.
#   ng reply 7 --repo owner/name --body-file b.md   # cross-repo reply
#   echo "ack" | ng comment 7              # alias of `ng reply` (issue/PR comment)
#   ng close   12 --comment "shipped"      # comment + close, prints CLOSED
#   ng dashboard get                       # current dashboard middle
#   ng dashboard put --body-file new.md    # splice + PATCH; prints issue URL
#   ng dashboard scaffold                  # print the canonical section skeleton
#   ng dashboard validate --body-file d.md # check required sections present
#   ng nexus-identity --dry-run            # render the identity block (no write)
#   ng issue 1                             # one-line: #1 state=OPEN title=Nexus
#   ng issue 1 --with-body --with-comments # full body + chronological comments
#   ng issue create --title t --body-file b.md [--label l]...   # print URL
#   ng issue comment 7 --body-file b.md    # like `ng reply 7 --body-file b.md`
#   ng pr create --head b [--base main] --title t --body-file b.md   # print URL
#                # auto-requests review from $github.user_login;
#                # opt-out via --no-reviewer, override via --reviewer <login>
#   ng pr edit   12 [--title t] [--body-file b.md]                   # print URL
#   ng pr merge  12 [--squash|--merge|--rebase] [--delete-branch]    # print sha
#   ng pr view   12                        # #12 state=OPEN author=login title=...
#   ng pr view   12 --json number,state,title   # scriptable JSON (bare --json = full object)
#   ng preflight your-org/foo              # is the bot installed on this repo?
#   ng upload fig.png [--issue N]          # asset-repo upload, prints SHA-pinned URL
#   ng wrap-up <issue> <report> [--trigger-comment <id>] [--repo OWNER/REPO]
#                                [--trigger-repo OWNER/REPO]
#                                [--comment-body-file <path> | --no-comment]
#                                [--allow-stub]
#                                [--skeptic-decision require|deny --skeptic-rationale "<why>"]
#                                [--skeptic-waive "<reason>"]
#                                [--skeptic-role --skeptic-target <window>
#                                 --skeptic-verdict credible|check|suspect|refuted
#                                 --skeptic-depth N --skeptic-findings N
#                                 --skeptic-orig <original-worker-window>]
#                # one-shot end-of-task: upload report + post link
#                # comment + rocket trigger comment + log action.
#                # --repo controls the issue-thread (comment) target.
#                # --trigger-repo (defaults to --repo) controls the
#                # rocket-react target — pass when the trigger
#                # comment lives on a different repo than the issue.
#                # --comment-body-file lets you supply a bespoke
#                # comment body ({{REPORT_URL}} expanded; else footer
#                # appended). --no-comment skips step 2 entirely.
#                # --allow-stub forwards --allow-todo to the
#                # pre-flight report-check (intentional checkpoint).
#                # SKEPTIC PROTOCOL (skills/nexus.skeptic): wrap-up reads
#                # the worker's spawn-stamped skeptic mode and acts —
#                # require enforces, auto presents the responsible-default
#                # choice (record via --skeptic-decision + --skeptic-
#                # rationale), deny skips. --skeptic-role marks a
#                # skeptic's own wrap-up (logs its --skeptic-verdict and
#                # applies bounded recursion). --skeptic-waive is the
#                # operator override of a required skeptic.
#   ng skeptic <ask|await|answer|await-answer|reconcile|close|poll|
#               status|list|nudge|init|dir> ...
#                # worker↔skeptic comms channel + nudge (delegates to
#                # monitor/skeptic-channel.sh). Worker-run `await` blocks
#                # for *.open.md, acks (→.ack.md), exits; `answer`
#                # renames →.answered.md; skeptic `reconcile`+`close`
#                # drive the wrap. The rename is the signal at every
#                # step. See nexus.skeptic.
#   ng report-init <slug> [--project N] [--issue N] [--comment-id ID] [--reports-dir P]
#                # writes a frontmatter'd report skeleton at the
#                # canonical path; captures session-id + tmux window
#                # automatically; prints the path.
#   ng report-check <path> [--allow-todo]
#                # validates a report against the schema in
#                # nexus.report (frontmatter + sections + min chars
#                # + no placeholders). exit 0/1/2.
#   ng fetch-asset <user-attachments URL> [--out PATH] [--image-only]
#                # download a github.com/user-attachments/... asset via
#                # the user's PAT (the bot's installation token returns
#                # 404 — these URLs require user-OAuth). Prints path,
#                # content-type, byte count. Default --out is
#                # monitor/.state/assets/<asset-id>.<ext>.
#   ng watcher-status [--scheduler]        # heartbeat + (optional) per-task v2 telemetry
#   ng log-action monitor --event process --note "..."   # append to action log
#   ng service-incident <svc>              # assemble a service incident report
#                # from the watcher's recorded state (service-health-watch),
#                # to stdout — pipe to `ng issue create --body-file -`.
#   ng suppress-emit <comment-id> [--repo OWNER/REPO] [--reason "<short>"]
#                # operator-side manual emit-suppression. Appends
#                # `comment:<id>` to monitor/.state/emit-suppression.lines;
#                # compose_emit's _filter_suppression stage drops any
#                # `id=<N>` line in the suppression file from the
#                # eligible-comments stream on the next tick. Backup
#                # lever for when the reactions filter fails to exclude
#                # a comment that's re-surfacing every cycle.
#   ng mint-jwt                            # print App-level JWT (for /app/hook/* etc)
#   ng respawn <window | session-id> [--window N] [--workdir P]
#                            [--replace] [--nudge|--no-nudge] [--dry-run]
#                # resume a wrapped/closed worker's Claude Code session
#                # in a tmux window with full spawn parity (env exports,
#                # worker-settings hooks, window options, lifecycle
#                # anchors). Thin wrapper over
#                # `monitor/spawn-worker.sh --resume` — session-id and
#                # workdir auto-resolve from report frontmatter /
#                # action-log / ~/.claude/projects; pass a UUID (with
#                # --window) to override. Workers whose last heartbeat
#                # was mid-turn (busy) get a continuation prompt
#                # automatically — claude --resume alone does NOT
#                # restart an interrupted turn. NEVER hand-roll
#                # `tmux new-window … claude --resume` — that loses the
#                # NEXUS_ROOT/NEXUS_WORKER_WINDOW exports and every
#                # worker hook breaks.
#   ng spawn-decision <window> [--topic <slug>]
#                # advisory continue-vs-spawn classifier for a retained
#                # worker. Inspects pane-state + most-recent spawn /
#                # window-retain action-log entries + retain TTL and
#                # emits `decision=<continue|spawn|ambiguous> reason=...`.
#                # Mirrors the policy in skills/nexus.window-cleanup
#                # Continue-vs-spawn. Always exit 0; orchestrator
#                # decides what to do with the advice.
#   ng wrap-up-check <window>
#                # verify worker wrap-up obligations BEFORE closing.
#                # Checks: action-log has a current-lifecycle wrap-up
#                # event, the cited report exists and passes
#                # report-check, rocket status is ok/skipped. Exit 0
#                # when status=ok (safe to close); exit 1 when
#                # incomplete (caller should NOT close yet).
#   ng engaged-done [--window <name>]
#                # interactive session's explicit FINISHED-signal. A
#                # wrap-up from an operator-engaged window keeps the
#                # window engaged by default (follow-up inquiries
#                # expected); this verb invalidates the engagement
#                # mark so the window follows the typical wrapped-
#                # window cleanup. A new operator prompt re-engages.
#   ng interactive-sessions [--limit N] [--days D] [--upsert-overview] [--dry-run]
#                # list recently paused/closed interactive windows with
#                # their resume commands, and optionally idempotently
#                # upsert a registry block into the overview issue body
#                # (your-org/your-nexus #1) between HTML-comment
#                # delimiters. --dry-run prints the rendered block
#                # without patching GitHub. Uses the bot identity
#                # (REST PATCH /repos/.../issues/1).
#   ng nexus-identity [--upsert-overview] [--dry-run] [--repo <o/n>]
#                # render the auto-generated Nexus identity block
#                # (working directory headline + host/repos/watcher
#                # paths, all DERIVED — generic across operators) and
#                # idempotently upsert it into the overview issue body
#                # between <!-- nexus-identity:start/end --> markers.
#                # --dry-run renders without patching GitHub.
#   # ── pass-through facades over standalone monitor/*.sh (exec; stdout/
#   #    stderr/exit unchanged — the script keeps its logic + test-*.sh unit):
#   ng retire-preflight <window>           # synchronous go/no-go gate pre-kill
#   ng pane-state <window-index>           # classify a worker pane
#   ng write-probe <path>                  # pre-flight a deliverable path
#   ng declare-wait <kind> <id> <desc>     # self-declare an async wait
#   ng declare-no-wait <kind> <id>         # mark an async launch fire-and-forget
#   ng paste-followup <window> ...         # canonical follow-up paste
#   ng token                               # print bot installation token ($(…))
#   ng user-pat                            # print user PAT for private reads
#   ng help | ng verbs                     # complete categorized verb index
#   ng <verb> --help                       # per-verb usage block (also -h)
#
# Most pr/issue/show verbs accept --repo OWNER/NAME to target a non-nexus
# repo. Unset, the cwd-derive default depends on whether the verb writes
# or reads:
#   - READ verbs (issue view, pr view, show) prefer the cwd's
#     `git remote get-url origin` if it's a github.com URL (one-line
#     stderr warning when different from $REPO), else fall back to $REPO.
#   - WRITE verbs (reply, comment-edit, wrap-up, issue create, issue comment, pr
#     create, pr edit, pr merge, upload) prefer $REPO from config. If
#     the cwd has a github origin that DIFFERS from $REPO, the verb
#     refuses to write (structured error asking for explicit --repo)
#     rather than silently misroute — closes #108 / the soon-to-be-
#     public nexus-code leak risk.
#
# Auth: every write uses an installation token from monitor/mint-token.sh —
# not the user's `gh` token — so user-authored notifications (issue creates,
# PR opens, comments, reviews) actually trigger GitHub's notification system
# for @operator. The ONLY GitHub interaction that should still use the user's
# identity is `git commit` / `git push` (authorship on the commit graph).
# Identity (repo, user_login) comes from config/nexus.yml via config/load.sh.

set -uo pipefail

# Dereference symlinks before resolving the script dir. `ng` is invoked
# BY NAME through the `locals/bin/ng -> ../../monitor/ng` shim that
# link-nexus-tools.sh provisions (and that the worker floor tells every
# worker to use). Without `readlink -f`, BASH_SOURCE[0] is the shim path,
# `_script_dir` resolves to `locals/bin`, and `$_script_dir/../config/load.sh`
# points at the nonexistent `locals/config/load.sh` — so config loading
# silently fails and every config-derived value falls back to a built-in
# default (your-org/nexus-code#522). Matches the idiom already used by
# entry.sh:93, install-claude-local.sh:67, link-nexus-tools.sh:41.
_script_dir=$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)
_cfg="$_script_dir/../config/load.sh"

REPO="$("$_cfg" github.repo)"
USER_LOGIN="$("$_cfg" github.user_login)"

# Resolve the canonical `monitor/.state/` for this nexus operator.
# Precedence (most-specific first):
#   1. $NEXUS_STATE_DIR     env override — direct path; test escape hatch.
#   2. $NEXUS_ROOT          env — `<root>/monitor/.state`. Set by the
#                          watcher and `monitor/watcher/launcher.sh`
#                          so any `ng` invocation under the watcher's
#                          process tree picks the right dir.
#   3. config nexus.root    operator-pinned root from config/nexus.yml —
#                          the long-lived source of truth. Keeps worker
#                          wrap-ups landing in the primary clone's log
#                          where the watcher's idle classifier reads
#                          them, regardless of which `ng` binary
#                          (worktree, fresh clone) the worker invoked.
#   4. $_script_dir/.state  script-relative fallback. Preserves
#                          back-compat for fresh installs that haven't
#                          set NEXUS_ROOT/nexus.root yet; in normal
#                          operator setups the config-key path wins.
_resolve_state_dir() {
    if [[ -n "${NEXUS_STATE_DIR:-}" ]]; then
        printf '%s' "$NEXUS_STATE_DIR"
        return 0
    fi
    if [[ -n "${NEXUS_ROOT:-}" ]]; then
        printf '%s/monitor/.state' "$NEXUS_ROOT"
        return 0
    fi
    local cfg_root
    cfg_root=$("$_cfg" nexus.root 2>/dev/null) || cfg_root=""
    if [[ -n "$cfg_root" ]]; then
        printf '%s/monitor/.state' "$cfg_root"
        return 0
    fi
    printf '%s/.state' "$_script_dir"
}
STATE_DIR="$(_resolve_state_dir)"
DASH_CACHE="$STATE_DIR/dashboard.md"
# Append-only list of comment- and issue-ids we've eyed from this
# toolchain. Read by monitor/watcher/main.sh's snapshot_github to
# suppress comments / issues for the 1-2 cycles between POST
# /reactions and GH-side propagation, which would otherwise re-surface
# them as still-eligible. Entries are prefixed by kind so the same
# file holds both comment ids and issue numbers without collision:
#   comment:<databaseId>     for issue / PR / PR-review comments
#   issue:<issue-number>     for the issue itself (the `issue_new=` line)
PROCESSED_CACHE="$STATE_DIR/processed-comments.txt"
DASH_START='<!-- NEXUS_DASHBOARD_START -->'
DASH_END='<!-- NEXUS_DASHBOARD_END -->'
# Delimiters for the auto-generated nexus-identity block (cmd_nexus_identity).
# Like the dashboard markers, the block is upserted idempotently into the
# overview issue body so it can never drift — same delimiters every run.
IDENTITY_START='<!-- nexus-identity:start -->'
IDENTITY_END='<!-- nexus-identity:end -->'
# Canonical dashboard section schema — the single source of truth for both
# the `ng dashboard scaffold` skeleton and the `ng dashboard validate` (and
# put-time warn) checker. Adding/renaming a section here propagates to every
# operator's dashboard when they pull nexus-code; nothing else hardcodes the
# heading set. Keep these as exact `## ` H2 headings (matched with grep -Fx).
DASH_REQUIRED_SECTIONS=(
    "## Identity"
    "## Infra"
    "## Services"
    "## In-flight"
    "## Awaiting operator"
    "## Recent landings"
)

die() { echo "ng: $*" >&2; exit 1; }

# Per-verb usage strings keyed by the calling function name. Lifted
# from each cmd_*'s existing `die "usage: ..."` line so the help
# block stays in sync with the argument parser without duplicating
# prose. Add new verbs alongside the cmd_* definition.
_usage_for() {
    case "${1:-}" in
        cmd_process)        echo "usage: ng process <comment-id> [--repo <owner/name>]" ;;
        cmd_process_issue)  echo "usage: ng process-issue <issue-number> [--repo <owner/name>]" ;;
        cmd_react)          echo "usage: ng react <comment-id> <eyes|rocket> [--repo <owner/name>]" ;;
        cmd_react_issue)    echo "usage: ng react-issue <issue-number> <eyes|rocket> [--repo <owner/name>]" ;;
        cmd_reply)          echo "usage: ng reply <issue> [--repo <owner/name>] [--body-file <path>]" ;;
        cmd_comment)        echo "usage: ng comment <issue> [--repo <owner/name>] [--body-file <path>]   # alias of ng reply" ;;
        cmd_close)          echo "usage: ng close <issue> [--comment <text>]" ;;
        cmd_show)           echo "usage: ng show <comment-id> [--repo <owner/name>] [--meta]" ;;
        cmd_comment_edit)   echo "usage: ng comment-edit <comment-id> (--expect-updated-at <ts> | --force) [--repo <owner/name>] [--body-file <path>]   # CAS: exit 4 on concurrent edit; get <ts> from \`ng show <id> --meta\`" ;;
        cmd_upload)         echo "usage: ng upload <local-path> [--issue N] [--repo-path <path>] [--shape pin|latest] [--message <msg>]" ;;
        cmd_wrap_up)        echo "usage: ng wrap-up <issue> <report-path> [--trigger-comment <id>] [--repo <owner/name>] [--trigger-repo <owner/name>] [--comment-body-file <path>|--no-comment] [--allow-stub] [--retain <reason>|--no-retain]" ;;
        cmd_report_init)    echo "usage: ng report-init <slug> [--project <name>] [--issue <#>] [--comment-id <id>] [--reports-dir <path>]" ;;
        cmd_report_check)   echo "usage: ng report-check <path> [--allow-todo]" ;;
        cmd_fetch_asset)    echo "usage: ng fetch-asset <user-attachments URL> [--out PATH] [--image-only]" ;;
        cmd_issue)          echo "usage: ng issue <n> | ng issue create ... | ng issue comment <n> ... | ng issue close <n> ... | ng issue view <n> ..." ;;
        cmd_issue_view)     echo "usage: ng issue <n> [--repo <owner/name>] [--with-body] [--with-comments]" ;;
        cmd_issue_create)   echo "usage: ng issue create --title <t> [--body-file <path>] [--repo <owner/name>] [--label <l>]..." ;;
        cmd_issue_comment)  echo "usage: ng issue comment <n> [--repo <owner/name>] [--body-file <path>]" ;;
        cmd_pr)             echo "usage: ng pr create|edit|merge|view ..." ;;
        cmd_pr_create)      echo "usage: ng pr create --head <branch> --title <t> [--body-file <path>] [--base main] [--repo <owner/name>] [--reviewer <login>|--no-reviewer]" ;;
        cmd_pr_edit)        echo "usage: ng pr edit <n> [--repo <owner/name>] [--title <t>] [--body-file <path>]" ;;
        cmd_pr_merge)       echo "usage: ng pr merge <n> [--repo <owner/name>] [--squash|--merge|--rebase] [--delete-branch]" ;;
        cmd_pr_view)        echo "usage: ng pr view <n> [--repo <owner/name>] [--json [field,...]]" ;;
        cmd_preflight)      echo "usage: ng preflight <owner/repo>" ;;
        cmd_dashboard)      echo "usage: ng dashboard get|put|scaffold|validate [--body-file <path>]" ;;
        cmd_dashboard_get)  echo "usage: ng dashboard get" ;;
        cmd_dashboard_put)  echo "usage: ng dashboard put [--body-file <path>]" ;;
        cmd_dashboard_scaffold) echo "usage: ng dashboard scaffold" ;;
        cmd_dashboard_validate) echo "usage: ng dashboard validate [--body-file <path>]" ;;
        cmd_log_action)     echo "usage: ng log-action <agent> --event <name> [--note <t>] [--extra k=v]..." ;;
        cmd_service_incident) echo "usage: ng service-incident <svc> [--state-dir <path>]" ;;
        cmd_suppress_emit)  echo "usage: ng suppress-emit <comment-id> [--repo <owner/name>] [--reason <short>]" ;;
        cmd_watcher_status) echo "usage: ng watcher-status [--scheduler]" ;;
        cmd_mint_jwt)       echo "usage: ng mint-jwt" ;;
        cmd_respawn)        echo "usage: ng respawn <window | session-id> [--window N] [--workdir P] [--replace] [--nudge|--no-nudge] [--dry-run]" ;;
        cmd_spawn_decision) echo "usage: ng spawn-decision <window> [--topic <slug>]" ;;
        cmd_wrap_up_check)  echo "usage: ng wrap-up-check <window>" ;;
        cmd_engaged_done)          echo "usage: ng engaged-done [--window <name>]" ;;
        cmd_interactive_sessions)  echo "usage: ng interactive-sessions [--limit N] [--days D] [--upsert-overview] [--dry-run]" ;;
        cmd_nexus_identity)        echo "usage: ng nexus-identity [--upsert-overview] [--dry-run] [--repo <owner/name>]" ;;
        *)                  return 1 ;;
    esac
}

# `--help` / `-h` short-circuit for leaf cmd_* functions. Called as
# the first line of every verb. If any arg is `--help` or `-h`, print
# the verb's usage block via _usage_for and exit 0 — no parsing, no
# side effects, no positional shifts. Closes the regression where
# `ng report-init --help` treated --help as the slug and wrote a
# `--help.md` skeleton file.
_help_check() {
    local a
    for a in "$@"; do
        case "$a" in
            --help|-h)
                _usage_for "${FUNCNAME[1]:-}" || _print_help
                exit 0
                ;;
        esac
    done
}

# `--help` / `-h` short-circuit for dispatcher cmd_* (cmd_issue,
# cmd_pr, cmd_dashboard). Fires only when help is the FIRST arg so
# that `ng <dispatcher> <subverb> --help` falls through to the
# subverb's own _help_check rather than swallowing it here.
_help_check_first() {
    case "${1:-}" in
        --help|-h)
            _usage_for "${FUNCNAME[1]:-}" || _print_help
            exit 0
            ;;
    esac
}

# Append a prefixed entry (kind:id) to the processed-comments cache
# if not already present. Called after a successful eyes/rocket
# reaction POST; the watcher uses the file to exclude comments /
# issues whose reaction hasn't propagated server-side yet.
#   _mark_processed comment 4272693242   # any bot reaction (eyes OR rocket)
#   _mark_processed issue   55           # ditto, on an issue body
#   _mark_processed rocket  4272693242   # the bot 🚀 specifically — the
#                                        # two-tier re-emit STOP signal
#                                        # (your-org/nexus-code#360). Written
#                                        # IN ADDITION to `comment:<id>` so the
#                                        # re-emit registry can tell a 🚀 (done
#                                        # → stop) from a bare 👀 (acked → slow
#                                        # 6h nudge) without a live API call.
_mark_processed() {
    local kind="$1" id="$2"
    [[ -n "$kind" && -n "$id" ]] || return 0
    case "$kind" in comment|issue|rocket) ;; *) return 0 ;; esac
    local entry="${kind}:${id}"
    mkdir -p "$STATE_DIR"
    [[ -f "$PROCESSED_CACHE" ]] || : > "$PROCESSED_CACHE"
    grep -qxF "$entry" "$PROCESSED_CACHE" || printf '%s\n' "$entry" >> "$PROCESSED_CACHE"
}

# Cache the bot token for the life of this process.
_token=""
token() {
    [[ -n "$_token" ]] || {
        # Surface mint-token.sh's stderr (key path, mint failures) so the
        # operator can fix the underlying problem instead of guessing.
        _token=$("$_script_dir/mint-token.sh") \
            || die "mint-token.sh failed; bot identity cannot be obtained. See stderr above."
        # Refuse to fall through to ambient gh auth on empty token.
        # Empty $GH_TOKEN is treated as "no override" by gh and silently
        # falls back to the user's cached auth, which would post as
        # @operator — defeating the bot/user identity boundary.
        [[ -n "$_token" ]] || die \
            "mint-token.sh returned empty; bot identity cannot be obtained. Check config/nexus.yml github.bot_* keys and pem path."
    }
    printf '%s' "$_token"
}

# gh api with the bot token bound. All API I/O flows through here.
# NEVER bind an empty GH_TOKEN — `gh` would silently fall back to the
# user's cached auth. token() dies loudly if minting fails.
api() { GH_TOKEN=$(token) gh api "$@"; }

# Resolve the target repo for --repo-aware verbs. Two modes:
#
# write (default — every verb that mutates GitHub state):
#   reply, comment-edit, wrap-up, issue create, issue comment, pr create, pr edit,
#   pr merge, upload, dashboard put. Precedence:
#     1. explicit --repo
#     2. $REPO from config
#     3. cwd's git origin ONLY when it matches $REPO exactly
#   A cwd github-origin that differs from $REPO with no --repo is a
#   STRUCTURED ERROR — the verb refuses to write to either side and
#   asks for an explicit --repo. Closes the worker-in-nexus-code-
#   clone-silently-misrouting-to-your-nexus footgun (#108) and is
#   the orchestrator-side half of the leak-risk fix for the soon-
#   to-be-public `nexus-code` repo.
#
# read (read-only verbs — issue view, pr view, show):
#   Preserves the ergonomic cwd-derive default so cd'ing into a
#   project and running `ng issue view 12` Just Works without --repo.
#   Precedence:
#     1. explicit --repo
#     2. cwd's git origin if it parses as github.com (warn once on
#        stderr if it differs from $REPO)
#     3. $REPO from config
#
# Usage: _resolve_repo <mode> <explicit-repo-arg>
#   - mode ∈ {read, write}
#   - explicit-repo-arg may be empty (then the precedence rules apply)
# The bot token is still minted from the nexus config regardless.
_resolve_repo() {
    local mode="${1:-write}"; shift || true
    local explicit="${1:-}"
    if [[ -n "$explicit" ]]; then
        printf '%s' "$explicit"
        return 0
    fi
    local origin cwd_repo=""
    origin=$(git remote get-url origin 2>/dev/null || true)
    # Strip optional .git suffix; capture owner/name.
    if [[ "$origin" =~ github\.com[:/]([^/]+)/([^/]+)$ ]]; then
        cwd_repo="${BASH_REMATCH[1]}/${BASH_REMATCH[2]%.git}"
    fi
    case "$mode" in
        read)
            if [[ -n "$cwd_repo" && "$cwd_repo" != "${REPO:-}" ]]; then
                echo "ng: targeting cwd origin $cwd_repo (override with --repo, or run from nexus root for $REPO)" >&2
                printf '%s' "$cwd_repo"
                return 0
            fi
            [[ -n "${REPO:-}" ]] || die "no --repo, no \$REPO, and cwd has no github origin"
            printf '%s' "$REPO"
            ;;
        write)
            if [[ -n "$cwd_repo" && -n "${REPO:-}" && "$cwd_repo" != "$REPO" ]]; then
                die "this verb writes to $REPO; cwd is $cwd_repo; pass --repo explicitly to override (write verbs no longer cwd-derive silently — issue #108)"
            fi
            [[ -n "${REPO:-}" ]] || die "no --repo, no \$REPO, and cwd has no github origin"
            printf '%s' "$REPO"
            ;;
        *)
            die "_resolve_repo: unknown mode '$mode' (read|write)"
            ;;
    esac
}

# Check whether the bot's GitHub App installation includes the given
# OWNER/NAME repo. Returns 0 if installed, 1 if not, 2 on API error.
# Silent (no stdout) — callers print whatever message they want.
#
# /installation/repositories paginates as a stream of
# `{total_count, repositories:[...]}` objects under `gh --paginate`.
# Slurp them into one array, flatten, then membership-test full_name.
_preflight_repo() {
    local target="${1:-}"
    [[ -n "$target" ]] || return 2
    api --paginate "/installation/repositories?per_page=100" 2>/dev/null \
        | jq -es --arg t "$target" \
            '[.[].repositories[]?.full_name] | any(. == $t)' \
            >/dev/null
}

# Read body from --body-file path (in $1) or stdin (if $1 empty).
_read_body() {
    if [[ -n "$1" ]]; then
        [[ -f "$1" ]] || die "body file not found: $1"
        cat -- "$1"
    else
        cat
    fi
}

# Post {body: "..."} to <endpoint> ($1) with content from $2; print html_url.
# Lets `gh api`'s stderr (HTTP status, error message body) leak through
# so a 4xx surfaces concretely instead of a bare "POST … failed".
_post_body() {
    local endpoint="$1" body="$2" url
    [[ -n "$body" ]] || die "empty body"
    url=$(jq -n --arg b "$body" '{body: $b}' \
          | api -X POST "$endpoint" --input - \
          | jq -r '.html_url // empty')
    [[ -n "$url" ]] || die "POST $endpoint failed"
    printf '%s\n' "$url"
}

# ---- CAS comment edit (#524 defect 1) -----------------------------------
#
# Every nexus agent posts as the SAME bot identity, so a concurrent
# agent overwriting a comment edit is unattributable by construction —
# GraphQL userContentEdits shows one author for every revision. A plain
# `PATCH /repos/.../issues/comments/<id>` is last-writer-wins, and a
# passing "re-fetch + grep the body" verification has a shelf life
# (observed: `#282` comment 4960082155, a correction silently restored
# to its refuted form ~10 min later by a concurrent consolidation).
#
# GitHub REST does NOT support server-side preconditions here: PATCH
# with `If-Match` (or `If-Unmodified-Since`) is rejected with HTTP 400
# "Conditional request headers are not allowed in unsafe requests
# unless supported by the endpoint" (verified live 2026-07-15 against
# api.github.com). So the compare-and-swap is client-side:
#
#   1. re-read the comment; abort LOUDLY if `updated_at` differs from
#      the caller's snapshot (someone wrote between read and write);
#   2. PATCH the new body;
#   3. post-write verify: the PATCH response's stored body must equal
#      what we sent (CR-normalized), else fail loud.
#
# Step 1 cannot close the read→write window entirely (no server-side
# precondition exists), but it fully catches the observed failure
# mode — a clobber landing minutes later — and two writers that BOTH
# use this path can no longer silently lose either edit. `updated_at`
# has 1-second granularity; the residual same-second blind spot is
# documented, not hidden.
#
# _comment_patch_cas <target> <cid> <new-body> <expect-updated-at>
#   stdout: comment html_url on success
#   rc 0   success
#   rc 4   concurrent edit detected (updated_at moved) — caller must
#          re-read the CURRENT body, re-apply its edit, and retry
#   rc 1   fetch/PATCH/verify failure
_comment_patch_cas() {
    local target="$1" cid="$2" new_body="$3" expect="$4"
    [[ -n "$expect" ]] || { echo "ng: comment $cid: empty expected updated_at (CAS token required)" >&2; return 1; }
    local meta cur_updated
    meta=$(api "/repos/$target/issues/comments/$cid" 2>/dev/null) \
        || { echo "ng: comment $cid: pre-write fetch failed" >&2; return 1; }
    cur_updated=$(jq -r '.updated_at // empty' <<<"$meta")
    [[ -n "$cur_updated" ]] \
        || { echo "ng: comment $cid: malformed metadata (no updated_at)" >&2; return 1; }
    if [[ "$cur_updated" != "$expect" ]]; then
        {
            printf 'ng: comment %s: CONCURRENT EDIT detected — updated_at moved (%s -> %s).\n' \
                "$cid" "$expect" "$cur_updated"
            printf 'ng: refusing to clobber. Re-read the CURRENT body (`ng show %s --meta`),\n' "$cid"
            printf 'ng: re-apply your edit against it, then retry with the fresh updated_at.\n'
        } >&2
        return 4
    fi
    local resp url got_body
    resp=$(jq -n --arg b "$new_body" '{body: $b}' \
           | api -X PATCH "/repos/$target/issues/comments/$cid" --input -) \
        || { echo "ng: comment $cid: PATCH failed" >&2; return 1; }
    url=$(jq -r '.html_url // empty' <<<"$resp")
    got_body=$(jq -r '.body // empty' <<<"$resp")
    [[ -n "$url" ]] \
        || { echo "ng: comment $cid: PATCH returned no html_url" >&2; return 1; }
    # Post-write verify — the response body IS the stored artifact.
    # Compare CR-normalized so a CRLF-vs-LF round-trip can't false-alarm.
    if [[ "${got_body//$'\r'/}" != "${new_body//$'\r'/}" ]]; then
        {
            printf 'ng: comment %s: PATCH succeeded but the stored body differs from what was sent.\n' "$cid"
            printf 'ng: treat the comment as contended — inspect it (`ng show %s --meta`) and re-edit.\n' "$cid"
        } >&2
        return 1
    fi
    printf '%s\n' "$url"
}

# Escape $1 for use inside a sed -E pattern (delimiter `%`).
_re_escape() { printf '%s' "$1" | sed -e 's/[][(){}.*+?^$|\\%]/\\&/g'; }
# Escape $1 for use as a sed replacement string (delimiter `%`).
_sed_rep_escape() { printf '%s' "$1" | sed -e 's/[\\&%]/\\&/g'; }

# Replace every http(s) URL token that ends in /<basename> — an
# asset-repo link to this report — with <new-url>. Token boundaries are
# whitespace, quotes, angle brackets, and `)` (the markdown-link
# closer); a URL whose path CONTINUES past the basename is left alone
# rather than corrupted. Pure text transform, no network.
#   _replace_asset_links <body> <basename> <new-url>
_replace_asset_links() {
    local body="$1" bname="$2" new_url="$3"
    local bname_re new_url_rep
    bname_re=$(_re_escape "$bname")
    new_url_rep=$(_sed_rep_escape "$new_url")
    printf '%s\n' "$body" \
        | sed -E "s%https?://[^[:space:]<>\"')]*/${bname_re}([^A-Za-z0-9._~/-]|\$)%${new_url_rep}\\1%g"
}

# ---- subcommands ----

cmd_react() {
    _help_check "$@"
    # Positionals and --repo may interleave so the call shape
    # `ng react <id> <content> --repo OWNER/NAME` (the natural one,
    # and the one the orchestrator uses) parses the same as
    # `ng react --repo OWNER/NAME <id> <content>`.
    local cid="" content="" repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --repo) repo_arg="${2:-}"; shift 2 ;;
            --*)    die "unknown flag: $1" ;;
            *)
                if   [[ -z "$cid"     ]]; then cid="$1"
                elif [[ -z "$content" ]]; then content="$1"
                else die "unexpected extra positional: $1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$cid" && -n "$content" ]] || die "usage: ng react <comment-id> <eyes|rocket> [--repo <owner/name>]"
    case "$content" in eyes|rocket) ;; *) die "react content must be eyes|rocket, got: $content" ;; esac
    local target
    target=$(_resolve_repo write "$repo_arg") || exit $?
    local rid
    rid=$(api -X POST "/repos/$target/issues/comments/$cid/reactions" \
              -f "content=$content" \
          | jq -r '.id // empty')
    [[ -n "$rid" ]] || die "react POST failed (id=$cid content=$content)"
    # EYES and ROCKET are processed-markers. Cache locally so the
    # watcher suppresses the comment during the GH-side propagation lag.
    # A ROCKET additionally records the dedicated `rocket:<id>` STOP marker
    # so the re-emit registry distinguishes 🚀 (done) from 👀 (slow nudge).
    if [[ "$content" == "eyes" || "$content" == "rocket" ]]; then
        _mark_processed comment "$cid"
    fi
    [[ "$content" == "rocket" ]] && _mark_processed rocket "$cid"
    printf 'reacted %s on comment %s\n' "$content" "$cid"
}

# React on an issue itself (not on one of its comments). Same shape
# as cmd_react but uses the /repos/{repo}/issues/{n}/reactions
# endpoint and writes "issue:<n>" to the propagation-lag cache.
cmd_react_issue() {
    _help_check "$@"
    local n="" content="" repo_arg=""
    while (( $# > 0 )); do
        case "$1" in
            --repo) repo_arg="${2:-}"; shift 2 ;;
            --*)    die "unknown flag: $1" ;;
            *)
                if   [[ -z "$n"       ]]; then n="$1"
                elif [[ -z "$content" ]]; then content="$1"
                else die "unexpected extra positional: $1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$n" && -n "$content" ]] || die "usage: ng react-issue <issue-number> <eyes|rocket> [--repo <owner/name>]"
    case "$content" in eyes|rocket) ;; *) die "react-issue content must be eyes|rocket, got: $content" ;; esac
    local target
    target=$(_resolve_repo write "$repo_arg") || exit $?
    local rid
    rid=$(api -X POST "/repos/$target/issues/$n/reactions" \
