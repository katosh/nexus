{
  "skipDangerousModePermissionPrompt": true,
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          { "type": "command",
            "command": "$NEXUS_ROOT/monitor/hooks/block-askuserquestion.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command",
            "command": "$NEXUS_ROOT/monitor/hooks/orchestrator-session-pin.sh" },
          { "type": "command",
            "command": "(mkdir -p \"$NEXUS_ROOT/monitor/.state\" && touch \"$NEXUS_ROOT/monitor/.state/orchestrator-paste-received\" &) >/dev/null 2>&1" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command",
            "command": "(mkdir -p \"$NEXUS_ROOT/monitor/.state\" && touch \"$NEXUS_ROOT/monitor/.state/orchestrator-heartbeat\" &) >/dev/null 2>&1" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command",
            "command": "(mkdir -p \"$NEXUS_ROOT/monitor/.state\" && touch \"$NEXUS_ROOT/monitor/.state/orchestrator-heartbeat\" &) >/dev/null 2>&1" },
          { "type": "command",
            "command": "rm -f \"$NEXUS_ROOT/monitor/.state/over-limit/${NEXUS_ORCHESTRATOR_WINDOW:-orchestrator}.json\"" }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          { "type": "command",
            "command": "$NEXUS_ROOT/monitor/hooks/over-limit-emit.sh" }
        ]
      }
    ]
  }
}
