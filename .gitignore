.bipartite/
bin/
.config/
# .claude/ is mostly local state, but the skills symlink that
# exposes the in-repo skills/ tree to Claude Code's discovery path
# (.claude/skills) must be tracked.
.claude/*
!.claude/skills
_ignore/
.epic-config.json
ISSUE-*.md
.epic-status.json
.epic-worklog.md
logs/
.mcp.json
config.yml
.jupyter/
nexus/

# Assets live in the asset repo (typically <your-org>/<your-nexus>
# `main`), cloned at /assets/ and pushed by monitor/upload-asset.sh.
# Legacy: status-assets/ from the original embedded-binary scheme,
# .wiki-checkout/ from the wiki-asset scheme that preceded the
# asset-repo cutover (still gitignored for orchestrators on older
# clones).
/assets/
/assets.lock
/assets.staging/
/monitor/status-assets/
/.wiki-checkout/

# Parallel-agent worktrees.
/.worktrees/

# npm-installed Claude Code. package.json + package-lock.json are
# tracked (reproducible install); node_modules/ is regenerated by
# `monitor/install-claude-local.sh` / `npm ci`.
/node_modules/

# Project-local npm cache. install-claude-local.sh points npm's cache here
# (default $HOME/.npm is read-only on sandboxed/HPC hosts → EROFS); the dir
# is overridable via npm_config_cache / NPM_CONFIG_CACHE.
/.npm-cache/

# NFS silly-rename artefacts.
**/.nfs*

# Nexus-wide, self-contained toolchain built by monitor/bootstrap-venv.sh
# and described by monitor/locals-env.sh: the standalone uv binary
# (locals/bin), shared managed Python interpreters + uv cache/tool store
# (locals/uv/*), and per-project venvs (locals/venvs/<name>). Keeps every
# byte out of $HOME and out of git; rebuilt on demand. ANCHORED on purpose:
# the toolchain lives ONLY at the nexus root, never inside a work/<project>
# repo (nexus infra does not extend into work-dir repos), so /locals/ is
# correct — an un-anchored locals/ would only matter for per-project locals,
# which this design deliberately avoids.
/locals/
# Belt-and-suspenders: an explicit in-tree venv (bootstrap-venv --dir .venv)
# at the nexus root. The default venv lives under locals/venvs/ instead.
/.venv/

# Python bytecode caches (e.g. from harness py_compile checks).
__pycache__/
*.pyc

# mkdocs build output.
/site/

